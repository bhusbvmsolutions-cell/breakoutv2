<!DOCTYPE html>
<html lang="en" class="light-theme">
  <head>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <script>
      (function () {
        var savedTheme = localStorage.getItem("theme") || "light";
        document.documentElement.classList.remove("dark-theme", "light-theme");
        document.documentElement.classList.add(savedTheme + "-theme");
      })();
    </script>

    <!-- loader-->
    <link href="/assets/css/pace.min.css" rel="stylesheet" />
    <script src="/assets/js/pace.min.js"></script>

    <!-- theme toggler / Manager -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
      $(document).ready(function () {
        function applyTheme(theme) {
          $("html")
            .removeClass("dark-theme light-theme")
            .addClass(theme + "-theme");

          if (theme === "dark") {
            $(".mode-icon ion-icon").attr("name", "sunny-outline");
          } else {
            $(".mode-icon ion-icon").attr("name", "moon-outline");
          }

          localStorage.setItem("theme", theme);
        }

        let savedTheme = localStorage.getItem("theme");

        if (savedTheme) {
          applyTheme(savedTheme);
        } else {
          applyTheme("light");
        }

        $(document).on("click", ".theme-toggle", function () {
          let currentTheme = localStorage.getItem("theme") || "light";
          let newTheme = currentTheme === "dark" ? "light" : "dark";
          applyTheme(newTheme);
        });
      });
    </script>

    <!--plugins-->
    <link
      href="/assets/plugins/simplebar/css/simplebar.css"
      rel="stylesheet"
    />
    <link
      href="/assets/plugins/perfect-scrollbar/css/perfect-scrollbar.css"
      rel="stylesheet"
    />
    <link
      href="/assets/plugins/metismenu/css/metisMenu.min.css"
      rel="stylesheet"
    />

    <!-- CSS Files -->
    <link href="/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/assets/css/bootstrap-extended.css" rel="stylesheet" />
    <link href="/assets/css/style.css" rel="stylesheet" />
    <link href="/assets/css/icons.css" rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <!--Theme Styles-->
    <link href="/assets/css/header-colors.css" rel="stylesheet" />
    <link href="/assets/css/custom.css" rel="stylesheet" />

    <link href="/assets/css/dark-theme.css" rel="stylesheet" />
    <link href="/assets/css/semi-dark.css" rel="stylesheet" />

    <link
      rel="shortcut icon"
      href="/assets/images/logo-icon-1.png"
      type="image/x-icon"
    />
    <title><%= title %> - Breakout Admin</title>
  </head>

  <body>
    <!--start wrapper-->
    <div class="wrapper">
      <!--start sidebar -->
      <aside class="sidebar-wrapper" data-simplebar="true">
        <div class="sidebar-header">
          <div>
            <h4 class="logo-text">Breakout</h4>
          </div>
        </div>
        <!--navigation-->
        <ul class="metismenu" id="menu">
          <li>
            <a href="/admin/dashboard" class="<%= currentUrl === '/admin/dashboard' ? 'mm-active' : '' %>">
              <div class="parent-icon">
                <ion-icon name="speedometer-outline"></ion-icon>
              </div>
              <div class="menu-title">Dashboard</div>
            </a>
          </li>

          <li>
            <a href="javascript:;" class="has-arrow">
              <div class="parent-icon">
                <ion-icon name="people-outline"></ion-icon>
              </div>
              <div class="menu-title">User Management</div>
            </a>
            <ul class="shadow-sm">
              <li>
                <a href="/admin/users" class="<%= currentUrl?.startsWith('/admin/users') ? 'mm-active' : '' %>">
                  <ion-icon name="people-circle-outline"></ion-icon>List Users
                </a>
              </li>
              <li>
                <a href="/admin/roles" class="<%= currentUrl?.startsWith('/admin/roles') ? 'mm-active' : '' %>">
                  <ion-icon name="shield-outline"></ion-icon>Roles
                </a>
              </li>
              <li>
                <a href="/admin/permissions" class="<%= currentUrl?.startsWith('/admin/permissions') ? 'mm-active' : '' %>">
                  <ion-icon name="key-outline"></ion-icon>Permissions
                </a>
              </li>
            </ul>
          </li>

          <li>
            <a href="javascript:;" class="has-arrow">
              <div class="parent-icon">
                <ion-icon name="cube-outline"></ion-icon>
              </div>
              <div class="menu-title">Products</div>
            </a>
            <ul class="shadow-sm">
              <li>
                <a href="/admin/products">
                  <ion-icon name="list-outline"></ion-icon>Products List
                </a>
              </li>
              <li>
                <a href="/admin/products/create">
                  <ion-icon name="add-circle-outline"></ion-icon>Add Product
                </a>
              </li>
            </ul>
          </li>

          <li>
            <a href="javascript:;" class="has-arrow">
              <div class="parent-icon">
                <ion-icon name="cart-outline"></ion-icon>
              </div>
              <div class="menu-title">Orders</div>
            </a>
            <ul class="shadow-sm">
              <li>
                <a href="/admin/orders">
                  <ion-icon name="list-outline"></ion-icon>Orders List
                </a>
              </li>
            </ul>
          </li>

          <li>
            <a href="javascript:;" class="has-arrow">
              <div class="parent-icon">
                <ion-icon name="settings-outline"></ion-icon>
              </div>
              <div class="menu-title">Settings</div>
            </a>
            <ul class="shadow-sm">
              <li>
                <a href="/admin/settings" class="<%= currentUrl === '/admin/settings' ? 'mm-active' : '' %>">
                  <ion-icon name="settings"></ion-icon> Site Settings
                </a>
              </li>
              <li>
                <a href="/admin/profile" class="<%= currentUrl === '/admin/profile' ? 'mm-active' : '' %>">
                  <ion-icon name="person-outline"></ion-icon> My Profile
                </a>
              </li>
            </ul>
          </li>

          <li>
            <a href="/api/health" target="_blank">
              <div class="parent-icon">
                <ion-icon name="hdd-stack-outline"></ion-icon>
              </div>
              <div class="menu-title">API Status</div>
            </a>
          </li>
        </ul>
        <!--end navigation-->
      </aside>
      <!--end sidebar -->

      <!--start top header-->
      <header class="top-header">
        <nav class="navbar navbar-expand gap-3">
          <div class="toggle-icon">
            <ion-icon name="menu-outline"></ion-icon>
          </div>
          <div class="top-navbar-right ms-auto">
            <ul class="navbar-nav align-items-center">
              <li class="nav-item">
                <a class="nav-link dark-mode-icon theme-toggle" href="javascript:;">
                  <div class="mode-icon">
                    <ion-icon name="moon-outline"></ion-icon>
                  </div>
                </a>
              </li>

              <li class="nav-item dropdown dropdown-user-setting">
                <% if(user?.avatar){ %>
                <a
                  class="nav-link dropdown-toggle dropdown-toggle-nocaret"
                  href="javascript:;"
                  data-bs-toggle="dropdown"
                >
                  <div class="user-setting">
                    <img
                      src="<%= user?.avatar %>"
                      class="user-img"
                      alt="User"
                    />
                  </div>
                </a>
                <% } else {%>
                <a
                  class="nav-link dropdown-toggle dropdown-toggle-nocaret p-0"
                  href="javascript:;"
                  data-bs-toggle="dropdown"
                >
                  <div
                    class="d-flex justify-content-center align-items-center rounded-circle bg-primary fw-bold text-white"
                    style="width: 40px; height: 40px"
                  >
                    <span class="text-uppercase">
                      <%= (user?.firstName?.charAt(0) || '') + (user?.lastName?.charAt(0) || '') %>
                    </span>
                  </div>
                </a>
                <% } %>

                <ul class="dropdown-menu dropdown-menu-end">
                  <!-- User Info -->
                  <li>
                    <div class="dropdown-item">
                      <div class="d-flex flex-row align-items-center gap-2">
                        <% if (user?.avatar) { %>
                        <img
                          src="<%= user?.avatar %>"
                          alt="User"
                          class="rounded-circle"
                          width="54"
                          height="54"
                        />
                        <% } else { %>
                        <div
                          class="d-flex justify-content-center align-items-center rounded-circle bg-primary fw-bold text-white"
                          style="width: 54px; height: 54px; font-size: 20px;"
                        >
                          <span class="text-uppercase">
                            <%= (user?.firstName?.charAt(0) || '') + (user?.lastName?.charAt(0) || '') %>
                          </span>
                        </div>
                        <% } %>

                        <div>
                          <h6 class="mb-0 dropdown-user-name">
                            <%= user?.firstName || '' %> <%= user?.lastName || '' %>
                          </h6>
                          <small class="mb-0 dropdown-user-designation text-secondary">
                            <%= user?.role || 'Admin' %>
                          </small>
                        </div>
                      </div>
                    </div>
                  </li>

                  <li><hr class="dropdown-divider" /></li>

                  <!-- Profile -->
                  <li>
                    <a class="dropdown-item" href="/admin/profile">
                      <div class="d-flex align-items-center">
                        <ion-icon name="person-outline"></ion-icon>
                        <div class="ms-3"><span>My Profile</span></div>
                      </div>
                    </a>
                  </li>

                  <!-- Change Password -->
                  <li>
                    <a class="dropdown-item" href="/admin/change-password">
                      <div class="d-flex align-items-center">
                        <ion-icon name="lock-closed-outline"></ion-icon>
                        <div class="ms-3"><span>Change Password</span></div>
                      </div>
                    </a>
                  </li>

                  <!-- Settings -->
                  <li>
                    <a class="dropdown-item" href="/admin/settings">
                      <div class="d-flex align-items-center">
                        <ion-icon name="settings-outline"></ion-icon>
                        <div class="ms-3"><span>Settings</span></div>
                      </div>
                    </a>
                  </li>

                  <!-- Logout -->
                  <li>
                    <a class="dropdown-item text-danger" href="/admin/logout">
                      <div class="d-flex align-items-center">
                        <ion-icon name="log-out-outline"></ion-icon>
                        <div class="ms-3"><span>Logout</span></div>
                      </div>
                    </a>
                  </li>
                </ul>
              </li>
            </ul>
          </div>
        </nav>
      </header>
      <!--end top header-->

      <!-- start page content wrapper-->
      <div class="page-content-wrapper">
        <!-- start page content-->
        <div class="page-content">
          <%- body %>
        </div>
      </div>
      <!--end page content wrapper-->
    </div>
    <!--end wrapper-->

    <!--start overlay-->
    <div class="overlay nav-toggle-icon"></div>
    <!--end overlay-->

    <!-- JS Files-->
    <script src="/assets/plugins/simplebar/js/simplebar.min.js"></script>
    <script src="/assets/plugins/metismenu/js/metisMenu.min.js"></script>
    <script src="/assets/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
    
    <!--plugins-->
    <script src="/assets/plugins/perfect-scrollbar/js/perfect-scrollbar.js"></script>
    <script src="/assets/plugins/chartjs/chart.min.js"></script>

    <!-- Main JS-->
    <script src="/assets/js/main.js"></script>

    <script>
      // Auto-hide alerts after 5 seconds
      setTimeout(function() {
        $('.alert').fadeOut('slow');
      }, 5000);

      // Toggle sidebar on mobile
      $('.toggle-icon').on('click', function() {
        $('.wrapper').toggleClass('toggled');
      });
    </script>
  </body>
</html>