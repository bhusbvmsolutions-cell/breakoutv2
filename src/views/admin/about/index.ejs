<%- contentFor('title') %> About Us Page
<%- contentFor('head') %>
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
<style>
  body { background: #f5f7fb; }
  .form-container { max-width: 100%; margin: 0 auto; }
  .card-custom { border-radius: 1rem; overflow: hidden; border: none; box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.08); }
  .card-header-custom { background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%); padding: 0.75rem 1.25rem; }
  .card-header-custom h4 { margin: 0; color: #2c3e50; font-weight: 600; font-size: 1.1rem; }
  .card-header-custom p { margin: 0; font-size: 0.8rem; color: #2c3e50; opacity: 0.9; }
  .form-section { background: #fff; border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1.5rem; border: 1px solid #eef2f6; }
  .section-title { font-size: 1rem; font-weight: 600; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #fcad00; display: inline-block; }
  .form-label { font-weight: 500; margin-bottom: 0.25rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; }
  .form-control, .form-select { border-radius: 0.5rem; border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; font-size: 0.9rem; transition: all 0.2s; }
  .form-control:focus, .form-select:focus { border-color: #fcad00; box-shadow: 0 0 0 0.2rem rgba(252,173,0,0.25); }
  .image-preview { max-width: 80px; max-height: 60px; margin-top: 0.5rem; border-radius: 0.5rem; border: 1px solid #e2e8f0; padding: 2px; background: #fff; display: none; }
  .repeater-item { background: #f8f9fa; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 1rem; margin-bottom: 1rem; position: relative; }
  .remove-item { position: absolute; top: 0.5rem; right: 0.5rem; cursor: pointer; color: #dc3545; background: white; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; z-index: 10; }
  .btn-submit { background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%); border: none; border-radius: 2rem; padding: 0.5rem 1.5rem; font-weight: 600; transition: transform 0.2s; }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 0.5rem 1rem rgba(252,173,0,0.3); }
  @media (max-width: 768px) { .form-container { max-width: 100%; } .form-section { padding: 1rem; } }
</style>

<%- contentFor('body') %>
<div class="py-4">
  <div class="form-container">
    <div class="card card-custom">
      <div class="card-header-custom">
        <h4><i class="bx bx-info-circle me-2"></i> About Us Page</h4>
        <p>Manage the about us page content</p>
      </div>
      <div class="card-body p-4">
        <form id="aboutUsForm" action="/admin/about" method="POST" enctype="multipart/form-data">
          <!-- Banner Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-image-alt me-2"></i> Banner Section</h5>
            <div class="row g-3">
              <div class="col-12"><label class="form-label">Heading</label><input type="text" name="banner_heading" class="form-control" value="<%= about?.banner_heading || '' %>"></div>
              <div class="col-12"><label class="form-label">Description</label><input type="text" name="banner_description" class="form-control" value="<%= about?.banner_description || '' %>"></div>
              <div class="col-12"><label class="form-label">Image</label><input type="file" name="banner_image" class="form-control" accept="image/*"><% if (about?.banner_image) { %><img src="<%= about.banner_image %>" class="image-preview mt-2" style="display:block"><% } %></div>
            </div>
          </div>

          <!-- Vision Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-eye me-2"></i> Vision Section</h5>
            <div class="row g-3">
              <div class="col-12"><label class="form-label">Image</label><input type="file" name="vision_image" class="form-control" accept="image/*"><% if (about?.vision_image) { %><img src="<%= about.vision_image %>" class="image-preview mt-2" style="display:block"><% } %></div>
              <div class="col-12"><label class="form-label">Heading 1</label><input type="text" name="vision_heading1" class="form-control" value="<%= about?.vision_heading1 || '' %>"></div>
              <div class="col-12"><label class="form-label">Description 1</label><textarea name="vision_description1" class="form-control" rows="3"><%= about?.vision_description1 || '' %></textarea></div>
              <div class="col-12"><label class="form-label">Heading 2</label><input type="text" name="vision_heading2" class="form-control" value="<%= about?.vision_heading2 || '' %>"></div>
              <div class="col-12"><label class="form-label">Description 2</label><textarea name="vision_description2" class="form-control" rows="3"><%= about?.vision_description2 || '' %></textarea></div>
            </div>
          </div>

          <!-- Counters Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-stats me-2"></i> Counters Section</h5>
            <div class="row g-3 mb-3">
              <div class="col-md-10"><label class="form-label">Counter Heading</label><input type="text" name="counters_heading" class="form-control" value="<%= about?.counters_heading || '' %>"></div>
              <div class="col-md-2"><label class="form-label">Rating (0-5)</label><input type="number" step="0.1" name="counters_rating" class="form-control" value="<%= about?.counters_rating || '' %>" min="0" max="5"></div>
            </div>
            <label class="form-label fw-bold mt-2">Counter Cards (3 items)</label>
            <div class="row">
              <% for (let i = 0; i < 3; i++) {
                const card = about?.counterCards?.[i];
              %>
              <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm h-100">
                  <div class="card-body">
                    <label class="form-label">Image</label>
                    <input type="file" name="counter_cards[<%= i %>][image]" class="form-control" accept="image/*">
                    <% if (card?.image) { %><img src="<%= card.image %>" class="image-preview mt-2" style="display:block"><% } %>
                    <input type="hidden" name="counter_cards[<%= i %>][image]" value="<%= card?.image || '' %>">
                    <hr class="my-2">
                    <label class="form-label">Count</label>
                    <input type="text" name="counter_cards[<%= i %>][count]" class="form-control" value="<%= card?.count || '' %>">
                    <label class="form-label mt-2">Description</label>
                    <input type="text" name="counter_cards[<%= i %>][description]" class="form-control" value="<%= card?.description || '' %>">
                  </div>
                </div>
              </div>
              <% } %>
            </div>
          </div>

          <!-- Content Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-file me-2"></i> Content Section</h5>
            <div class="row g-3">
              <div class="col-12"><label class="form-label">Heading</label><input type="text" name="content_heading" class="form-control" value="<%= about?.content_heading || '' %>"></div>
              <div class="col-12"><label class="form-label">Description</label><textarea name="content_description" class="form-control summernote" rows="5"><%= about?.content_description || '' %></textarea></div>
            </div>
          </div>

          <!-- Cards Section (Repeater) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-images me-2"></i> Cards Section</h5>
            <div class="row g-3 mb-2">
              <div class="col-12"><label class="form-label">Section Heading</label><input type="text" name="cards_heading" class="form-control" value="<%= about?.cards_heading || '' %>"></div>
            </div>
            <div id="cardsContainer">
              <% if (about?.cards && about.cards.length) {
                about.cards.forEach((item, idx) => { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="cards[<%= idx %>][image]" class="form-control" accept="image/*"><% if (item.image) { %><img src="<%= item.image %>" class="image-preview mt-2" style="display:block"><% } %><input type="hidden" name="cards[<%= idx %>][image]" value="<%= item.image || '' %>"></div>
                  <div class="col-md-4"><label class="form-label">Heading</label><input type="text" name="cards[<%= idx %>][heading]" class="form-control" value="<%= item.heading %>"></div>
                  <div class="col-md-4"><label class="form-label">Description</label><input type="text" name="cards[<%= idx %>][description]" class="form-control" value="<%= item.description || '' %>"></div>
                </div>
              </div>
              <% });
              } else { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="cards[0][image]" class="form-control" accept="image/*"><img class="image-preview mt-2"><input type="hidden" name="cards[0][image]" value=""></div>
                  <div class="col-md-4"><label class="form-label">Heading</label><input type="text" name="cards[0][heading]" class="form-control"></div>
                  <div class="col-md-4"><label class="form-label">Description</label><input type="text" name="cards[0][description]" class="form-control"></div>
                </div>
              </div>
              <% } %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-card"><i class="bx bx-plus"></i> Add Card</button>
          </div>

          <!-- Our Story Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-book-open me-2"></i> Our Story Section</h5>
            <div class="row g-3">
              <div class="col-md-6"><label class="form-label">Image</label><input type="file" name="our_story_image" class="form-control" accept="image/*"><% if (about?.our_story_image) { %><img src="<%= about.our_story_image %>" class="image-preview mt-2" style="display:block"><% } %></div>
              <div class="col-md-6"><label class="form-label">Heading</label><input type="text" name="our_story_heading" class="form-control" value="<%= about?.our_story_heading || '' %>"></div>
              <div class="col-12"><label class="form-label">Description</label><input type="text" name="our_story_description" class="form-control" value="<%= about?.our_story_description || '' %>"></div>
            </div>
          </div>

          <!-- Our Founders Section (Single) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-user-circle me-2"></i> Our Founders Section</h5>
            <div class="row g-3">
              <div class="col-12"><label class="form-label">Heading</label><input type="text" name="founders_heading" class="form-control" value="<%= about?.founders_heading || 'Our <span>Founder</span>' %>"></div>
              <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="founders_image" class="form-control" accept="image/*"><% if (about?.founders_image) { %><img src="<%= about.founders_image %>" class="image-preview mt-2" style="display:block"><% } %></div>
              <div class="col-md-4"><label class="form-label">Name</label><input type="text" name="founders_name" class="form-control" value="<%= about?.founders_name || '' %>"></div>
              <div class="col-md-4"><label class="form-label">Designation</label><input type="text" name="founders_designation" class="form-control" value="<%= about?.founders_designation || '' %>"></div>
              <div class="col-12"><label class="form-label">Description</label><textarea name="founders_description" class="form-control" rows="4"><%= about?.founders_description || '' %></textarea></div>
              <div class="col-md-6"><label class="form-label">Whatsapp</label><input type="text" name="founders_whatsapp" class="form-control" value="<%= about?.founders_whatsapp || '' %>"></div>
              <div class="col-md-6"><label class="form-label">Instagram</label><input type="text" name="founders_instagram" class="form-control" value="<%= about?.founders_instagram || '' %>"></div>
              <div class="col-md-6"><label class="form-label">Linkedin</label><input type="text" name="founders_linkedin" class="form-control" value="<%= about?.founders_linkedin || '' %>"></div>
              <div class="col-md-6"><label class="form-label">Twitter</label><input type="text" name="founders_twitter" class="form-control" value="<%= about?.founders_twitter || '' %>"></div>
              <div class="col-md-6"><label class="form-label">Gmail</label><input type="text" name="founders_gmail" class="form-control" value="<%= about?.founders_gmail || '' %>"></div>
              <div class="col-md-6"><label class="form-label">Link</label><input type="text" name="founders_link" class="form-control" value="<%= about?.founders_link || '' %>"></div>
            </div>
          </div>

          <!-- Our Leaders Section (Repeater) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-group me-2"></i> Our Leaders Section</h5>
            <div class="row g-3 mb-2">
              <div class="col-12"><label class="form-label">Heading</label><input type="text" name="leaders_heading" class="form-control" value="<%= about?.leaders_heading || 'Our <span>Leaders</span>' %>"></div>
            </div>
            <div id="leadersContainer">
              <% if (about?.leaders && about.leaders.length) {
                about.leaders.forEach((item, idx) => { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="leaders[<%= idx %>][image]" class="form-control" accept="image/*"><% if (item.image) { %><img src="<%= item.image %>" class="image-preview mt-2" style="display:block"><% } %><input type="hidden" name="leaders[<%= idx %>][image]" value="<%= item.image || '' %>"></div>
                  <div class="col-md-4"><label class="form-label">Name</label><input type="text" name="leaders[<%= idx %>][name]" class="form-control" value="<%= item.name %>"></div>
                  <div class="col-md-4"><label class="form-label">Designation</label><input type="text" name="leaders[<%= idx %>][designation]" class="form-control" value="<%= item.designation %>"></div>
                  <div class="col-12"><label class="form-label">Description</label><textarea name="leaders[<%= idx %>][description]" class="form-control" rows="4"><%= item.description || '' %></textarea></div>
                  <div class="col-md-6"><label class="form-label">Whatsapp</label><input type="text" name="leaders[<%= idx %>][whatsapp]" class="form-control" value="<%= item.whatsapp || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Instagram</label><input type="text" name="leaders[<%= idx %>][instagram]" class="form-control" value="<%= item.instagram || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Linkedin</label><input type="text" name="leaders[<%= idx %>][linkedin]" class="form-control" value="<%= item.linkedin || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Twitter</label><input type="text" name="leaders[<%= idx %>][twitter]" class="form-control" value="<%= item.twitter || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Gmail</label><input type="text" name="leaders[<%= idx %>][gmail]" class="form-control" value="<%= item.gmail || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Link</label><input type="text" name="leaders[<%= idx %>][link]" class="form-control" value="<%= item.link || '' %>"></div>
                </div>
              </div>
              <% });
              } else { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="leaders[0][image]" class="form-control" accept="image/*"><img class="image-preview mt-2"><input type="hidden" name="leaders[0][image]" value=""></div>
                  <div class="col-md-4"><label class="form-label">Name</label><input type="text" name="leaders[0][name]" class="form-control"></div>
                  <div class="col-md-4"><label class="form-label">Designation</label><input type="text" name="leaders[0][designation]" class="form-control"></div>
                  <div class="col-12"><label class="form-label">Description</label><textarea name="leaders[0][description]" class="form-control" rows="4"></textarea></div>
                  <div class="col-md-6"><label class="form-label">Whatsapp</label><input type="text" name="leaders[0][whatsapp]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Instagram</label><input type="text" name="leaders[0][instagram]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Linkedin</label><input type="text" name="leaders[0][linkedin]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Twitter</label><input type="text" name="leaders[0][twitter]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Gmail</label><input type="text" name="leaders[0][gmail]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Link</label><input type="text" name="leaders[0][link]" class="form-control"></div>
                </div>
              </div>
              <% } %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-leader"><i class="bx bx-plus"></i> Add Leader</button>
          </div>

          <!-- Our Advisors Section (Repeater) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-user-check me-2"></i> Our Advisors Section</h5>
            <div class="row g-3 mb-2">
              <div class="col-12"><label class="form-label">Heading</label><input type="text" name="advisors_heading" class="form-control" value="<%= about?.advisors_heading || 'Our <span>Advisors</span>' %>"></div>
            </div>
            <div id="advisorsContainer">
              <% if (about?.advisors && about.advisors.length) {
                about.advisors.forEach((item, idx) => { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="advisors[<%= idx %>][image]" class="form-control" accept="image/*"><% if (item.image) { %><img src="<%= item.image %>" class="image-preview mt-2" style="display:block"><% } %><input type="hidden" name="advisors[<%= idx %>][image]" value="<%= item.image || '' %>"></div>
                  <div class="col-md-4"><label class="form-label">Name</label><input type="text" name="advisors[<%= idx %>][name]" class="form-control" value="<%= item.name %>"></div>
                  <div class="col-md-4"><label class="form-label">Designation</label><input type="text" name="advisors[<%= idx %>][designation]" class="form-control" value="<%= item.designation %>"></div>
                  <div class="col-12"><label class="form-label">Description</label><textarea name="advisors[<%= idx %>][description]" class="form-control" rows="4"><%= item.description || '' %></textarea></div>
                  <div class="col-md-6"><label class="form-label">Whatsapp</label><input type="text" name="advisors[<%= idx %>][whatsapp]" class="form-control" value="<%= item.whatsapp || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Instagram</label><input type="text" name="advisors[<%= idx %>][instagram]" class="form-control" value="<%= item.instagram || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Linkedin</label><input type="text" name="advisors[<%= idx %>][linkedin]" class="form-control" value="<%= item.linkedin || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Twitter</label><input type="text" name="advisors[<%= idx %>][twitter]" class="form-control" value="<%= item.twitter || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Gmail</label><input type="text" name="advisors[<%= idx %>][gmail]" class="form-control" value="<%= item.gmail || '' %>"></div>
                  <div class="col-md-6"><label class="form-label">Link</label><input type="text" name="advisors[<%= idx %>][link]" class="form-control" value="<%= item.link || '' %>"></div>
                </div>
              </div>
              <% });
              } else { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="advisors[0][image]" class="form-control" accept="image/*"><img class="image-preview mt-2"><input type="hidden" name="advisors[0][image]" value=""></div>
                  <div class="col-md-4"><label class="form-label">Name</label><input type="text" name="advisors[0][name]" class="form-control"></div>
                  <div class="col-md-4"><label class="form-label">Designation</label><input type="text" name="advisors[0][designation]" class="form-control"></div>
                  <div class="col-12"><label class="form-label">Description</label><textarea name="advisors[0][description]" class="form-control" rows="4"></textarea></div>
                  <div class="col-md-6"><label class="form-label">Whatsapp</label><input type="text" name="advisors[0][whatsapp]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Instagram</label><input type="text" name="advisors[0][instagram]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Linkedin</label><input type="text" name="advisors[0][linkedin]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Twitter</label><input type="text" name="advisors[0][twitter]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Gmail</label><input type="text" name="advisors[0][gmail]" class="form-control"></div>
                  <div class="col-md-6"><label class="form-label">Link</label><input type="text" name="advisors[0][link]" class="form-control"></div>
                </div>
              </div>
              <% } %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-advisor"><i class="bx bx-plus"></i> Add Advisor</button>
          </div>

          <!-- Status -->
          <div class="form-section">
            <div class="row g-3">
              <div class="col-12"><div class="form-check"><input class="form-check-input" type="checkbox" name="isActive" value="on" <%= about?.isActive !== false ? 'checked' : '' %>><label class="form-check-label">Active</label></div></div>
            </div>
          </div>

          <div class="d-flex justify-content-end mt-3">
            <button type="submit" class="btn btn-submit"><i class="bx bx-save me-1"></i> Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- contentFor('js') %>
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>
<script>
  const pageData = <%- JSON.stringify(about || {}) %>;

  $(document).ready(function() {
    $('.summernote').summernote({
        placeholder: 'Write your content here...',
        tabsize: 2,
        height: 300,
        fontNames: [
          'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New',
          'Georgia', 'Tahoma', 'Times New Roman', 'Verdana',

          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontNamesIgnoreCheck: [
          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontSizes: ['8', '10', '12', '14', '16', '18', '20', '24', '28', '32', '36', '48', '64'],
        toolbar: [
          ['style', ['style']],
          ['font', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
          ['fontname', ['fontname']],
          ['fontsize', ['fontsize']],
          ['color', ['forecolor', 'backcolor']],
          ['para', ['ul', 'ol', 'paragraph', 'height']],
          ['insert', ['link', 'picture', 'video', 'table']],
          ['view', ['fullscreen', 'codeview']]
        ],
        lineHeights: ['0.8', '1.0', '1.2', '1.5', '2.0', '3.0'],
        callbacks: {
          onChange: function(contents) {
            // Update the hidden textarea when content changes
            const textarea = $(this).closest('.text-editor').find('.text-content');
            textarea.val(contents);
          }
        }
      });

    // Image preview
    function setupImagePreview(inputElem, previewElem) {
      inputElem.on('change', function() {
        const file = this.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) { previewElem.attr('src', e.target.result).show(); };
          reader.readAsDataURL(file);
        } else {
          previewElem.hide().attr('src', '');
        }
      });
    }
    $('input[type="file"]').each(function() {
      const preview = $(this).next('.image-preview');
      if (preview.length) setupImagePreview($(this), preview);
    });

    // ---------- Cards Repeater ----------
    let cardIndex = $('#cardsContainer .repeater-item').length;
    $('.add-card').click(function() {
      const newIndex = cardIndex++;
      const newItem = `
        <div class="repeater-item">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="cards[${newIndex}][image]" class="form-control" accept="image/*"><img class="image-preview mt-2"><input type="hidden" name="cards[${newIndex}][image]" value=""></div>
            <div class="col-md-4"><label class="form-label">Heading</label><input type="text" name="cards[${newIndex}][heading]" class="form-control"></div>
            <div class="col-md-4"><label class="form-label">Description</label><input type="text" name="cards[${newIndex}][description]" class="form-control"></div>
          </div>
        </div>
      `;
      $('#cardsContainer').append(newItem);
      const fileInput = $(`#cardsContainer .repeater-item:last input[type="file"]`);
      const preview = fileInput.next('.image-preview');
      setupImagePreview(fileInput, preview);
    });

    // ---------- Leaders Repeater ----------
    let leaderIndex = $('#leadersContainer .repeater-item').length;
    $('.add-leader').click(function() {
      const newIndex = leaderIndex++;
      const newItem = `
        <div class="repeater-item">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="leaders[${newIndex}][image]" class="form-control" accept="image/*"><img class="image-preview mt-2"><input type="hidden" name="leaders[${newIndex}][image]" value=""></div>
            <div class="col-md-4"><label class="form-label">Name</label><input type="text" name="leaders[${newIndex}][name]" class="form-control"></div>
            <div class="col-md-4"><label class="form-label">Designation</label><input type="text" name="leaders[${newIndex}][designation]" class="form-control"></div>
            <div class="col-12"><label class="form-label">Description</label><textarea name="leaders[${newIndex}][description]" class="form-control" rows="4"></textarea></div>
            <div class="col-md-6"><label class="form-label">Whatsapp</label><input type="text" name="leaders[${newIndex}][whatsapp]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Instagram</label><input type="text" name="leaders[${newIndex}][instagram]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Linkedin</label><input type="text" name="leaders[${newIndex}][linkedin]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Twitter</label><input type="text" name="leaders[${newIndex}][twitter]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Gmail</label><input type="text" name="leaders[${newIndex}][gmail]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Link</label><input type="text" name="leaders[${newIndex}][link]" class="form-control"></div>
          </div>
        </div>
      `;
      $('#leadersContainer').append(newItem);
      const fileInput = $(`#leadersContainer .repeater-item:last input[type="file"]`);
      const preview = fileInput.next('.image-preview');
      setupImagePreview(fileInput, preview);
    });

    // ---------- Advisors Repeater ----------
    let advisorIndex = $('#advisorsContainer .repeater-item').length;
    $('.add-advisor').click(function() {
      const newIndex = advisorIndex++;
      const newItem = `
        <div class="repeater-item">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Image</label><input type="file" name="advisors[${newIndex}][image]" class="form-control" accept="image/*"><img class="image-preview mt-2"><input type="hidden" name="advisors[${newIndex}][image]" value=""></div>
            <div class="col-md-4"><label class="form-label">Name</label><input type="text" name="advisors[${newIndex}][name]" class="form-control"></div>
            <div class="col-md-4"><label class="form-label">Designation</label><input type="text" name="advisors[${newIndex}][designation]" class="form-control"></div>
            <div class="col-12"><label class="form-label">Description</label><textarea name="advisors[${newIndex}][description]" class="form-control" rows="4"></textarea></div>
            <div class="col-md-6"><label class="form-label">Whatsapp</label><input type="text" name="advisors[${newIndex}][whatsapp]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Instagram</label><input type="text" name="advisors[${newIndex}][instagram]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Linkedin</label><input type="text" name="advisors[${newIndex}][linkedin]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Twitter</label><input type="text" name="advisors[${newIndex}][twitter]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Gmail</label><input type="text" name="advisors[${newIndex}][gmail]" class="form-control"></div>
            <div class="col-md-6"><label class="form-label">Link</label><input type="text" name="advisors[${newIndex}][link]" class="form-control"></div>
          </div>
        </div>
      `;
      $('#advisorsContainer').append(newItem);
      const fileInput = $(`#advisorsContainer .repeater-item:last input[type="file"]`);
      const preview = fileInput.next('.image-preview');
      setupImagePreview(fileInput, preview);
    });
  });

  function removeItem(btn) {
    $(btn).closest('.repeater-item').remove();
  }
</script>