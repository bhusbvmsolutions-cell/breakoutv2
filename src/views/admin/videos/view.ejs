<%- contentFor('title') %>
<%- contentFor('head') %>
<%- contentFor('body') %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h4><i class="bi bi-eye"></i> View Video</h4>
      </div>
    </div>
  </div>
</div>

<div class="row mt-3">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <div class="card-body">
        <!-- Video Player -->
        <div class="text-center mb-4">
          <video controls style="max-width: 100%; max-height: 400px;">
            <source src="<%= video.url %>" type="<%= video.mimeType %>">
            Your browser does not support the video tag.
          </video>
        </div>
        
        <!-- Video Details -->
        <ul class="nav nav-tabs mb-3" id="videoTabs">
          <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#details">Details</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#edit">Edit</a>
          </li>
        </ul>
        
        <div class="tab-content">
          <!-- Details Tab -->
          <div class="tab-pane fade show active" id="details">
            <table class="table">
              <!-- <tr>
                <th style="width: 150px;">ID:</th>
                <td><%= video.id %></td>
              </tr> -->
              <tr>
                <th>Filename:</th>
                <td><%= video.filename %></td>
              </tr>
              <tr>
                <th>Title:</th>
                <td><%= video.title || '-' %></td>
              </tr>
              <tr>
                <th>Description:</th>
                <td><%= video.description || '-' %></td>
              </tr>
              <tr>
                <th>Size:</th>
                <td><%= (video.size / (1024 * 1024)).toFixed(2) %> MB</td>
              </tr>
              <tr>
                <th>MIME Type:</th>
                <td><%= video.mimeType %></td>
              </tr>
              <tr>
                <th>Status:</th>
                <td>
                  <span class="badge bg-<%= 
                    video.status === 'active' ? 'success' : 
                    video.status === 'processing' ? 'warning' : 
                    video.status === 'failed' ? 'danger' : 'secondary' 
                  %>"><%= video.status %></span>
                </td>
              </tr>
              <tr>
                <th>Uploaded:</th>
                <td><%= new Date(video.createdAt).toLocaleString() %></td>
              </tr>
              <tr>
                <th>URL:</th>
                <td><%= video.url %></td>
              </tr>
              <tr>
                <th>Last Updated:</th>
                <td><%= new Date(video.updatedAt).toLocaleString() %></td>
              </tr>
            </table>
          </div>
          
          <!-- Edit Tab -->
          <div class="tab-pane fade" id="edit">
            <form id="editVideoForm">
              <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" class="form-control" id="title" name="title" value="<%= video.title || '' %>">
              </div>
              
              <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" id="description" name="description" rows="4"><%= video.description || '' %></textarea>
              </div>
              
              <div class="mb-3">
                <label for="status" class="form-label">Status</label>
                <select class="form-select" id="status" name="status">
                  <option value="active" <%= video.status === 'active' ? 'selected' : '' %>>Active</option>
                  <option value="inactive" <%= video.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                  <option value="processing" <%= video.status === 'processing' ? 'selected' : '' %>>Processing</option>
                  <option value="failed" <%= video.status === 'failed' ? 'selected' : '' %>>Failed</option>
                </select>
              </div>
              
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Save Changes
              </button>
            </form>
          </div>
        </div>
        
        <hr>
        <div class="d-flex justify-content-between">
          <a href="/admin/videos" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
          </a>
          <button type="button" class="btn btn-danger" id="deleteBtn">
            <i class="bi bi-trash"></i> Delete Video
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  $(document).ready(function() {
    // Edit form submission
    $('#editVideoForm').on('submit', function(e) {
      e.preventDefault();
      
      const formData = {
        title: $('#title').val(),
        description: $('#description').val(),
        status: $('#status').val()
      };
      
      $.ajax({
        url: '/admin/videos/<%= video.id %>',
        method: 'PUT',
        data: formData,
        success: function(response) {
          if (response.success) {
            alert('Video updated successfully');
            window.location.reload();
          } else {
            alert(response.error || 'Failed to update video');
          }
        },
        error: function() {
          alert('Failed to update video');
        }
      });
    });
    
    // Delete button
    $('#deleteBtn').on('click', function() {
      if (confirm('Are you sure you want to delete this video?')) {
        $.ajax({
          url: '/admin/videos/<%= video.id %>',
          method: 'DELETE',
          success: function(response) {
            if (response.success) {
              window.location.href = '/admin/videos';
            } else {
              alert(response.error || 'Failed to delete video');
            }
          },
          error: function() {
            alert('Failed to delete video');
          }
        });
      }
    });
  });
</script>