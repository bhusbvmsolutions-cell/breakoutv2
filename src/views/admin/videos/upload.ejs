<%- contentFor('title') %> Upload Videos
<%- contentFor('head') %>
<style>
  /* Optional: Add some animation to the progress bar */
  .progress-bar {
    transition: width 0.3s ease;
  }
  
  /* Style for the preview video */
  #previewVideo {
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    max-width: 100%;
    max-height: 300px;
  }
  
  /* Loading spinner animation */
  @keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
  }
  
  #loadingSpinner {
    animation: pulse 1.5s infinite;
  }
  
  /* Progress bar container */
  #uploadProgressContainer {
    margin-top: 20px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #dee2e6;
  }
  
  /* Disabled button style */
  .btn-primary:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
  
  /* Upload speed text */
  #uploadSpeed {
    font-size: 0.875rem;
    color: #6c757d;
  }
</style>


<%- contentFor('body') %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h4><i class="bi bi-cloud-upload"></i> Upload Video</h4>
      </div>
    </div>
  </div>
</div>

<div class="row mt-3">
  <div class="col-12">
    <div class="card">
      <div class="card-body">        
        <form id="uploadForm" action="/admin/videos/upload" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label for="video" class="form-label">Select Video <span class="text-danger">*</span></label>
            <input type="file" class="form-control" id="video" name="video" accept="video/*" required>
            <small class="text-muted">
              Allowed: MP4, WEBM, OGG, MOV, AVI (Max: 500MB)
            </small>
          </div>
          
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" class="form-control" id="title" name="title" placeholder="Video title">
            <small class="text-muted">If not provided, filename will be used</small>
          </div>
          
          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea class="form-control" id="description" name="description" rows="3" placeholder="Video description"></textarea>
          </div>
          
          <div class="mb-3">
            <div id="preview" class="text-center p-3 border rounded" style="display: none; background: #f8f9fa;">
              <h6>Preview:</h6>
              <video id="previewVideo" controls>
                <source src="#" id="videoSource">
                Your browser does not support the video tag.
              </video>
              <div id="videoInfo" class="mt-2 text-start small">
                <strong>Filename:</strong> <span id="fileName"></span><br>
                <strong>Size:</strong> <span id="fileSize"></span>
              </div>
            </div>
          </div>
          
          <!-- Upload Progress Section -->
          <div id="uploadProgressContainer" style="display: none;">
            <div class="d-flex justify-content-between mb-1">
              <span><i class="bi bi-arrow-up-circle"></i> Uploading...</span>
              <span id="uploadPercentage" class="fw-bold">0%</span>
            </div>
            <div class="progress" style="height: 25px;">
              <div id="uploadProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
                   role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                <span id="progressText">0%</span>
              </div>
            </div>
            <div id="uploadSpeed" class="small text-muted mt-2 text-end"></div>
            <div id="uploadStatus" class="small text-muted mt-1"></div>
          </div>
          
          <hr>
          
          <div class="d-flex align-items-center">
            <button type="submit" class="btn btn-primary" id="submitBtn">
              <i class="bi bi-cloud-upload"></i> Upload Video
            </button>
            
            <!-- Loading Spinner (initially hidden) -->
            <div id="loadingSpinner" class="ms-3" style="display: none;">
              <div class="spinner-border spinner-border-sm text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
              <span class="ms-2">Upload in progress...</span>
            </div>
            
            <a href="/admin/videos" class="btn btn-secondary ms-auto" id="cancelBtn">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>


<%- contentFor('js') %> 
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Get DOM elements
    const videoInput = document.getElementById('video');
    const uploadForm = document.getElementById('uploadForm');
    const submitBtn = document.getElementById('submitBtn');
    const loadingSpinner = document.getElementById('loadingSpinner');
    const uploadProgressContainer = document.getElementById('uploadProgressContainer');
    const uploadProgressBar = document.getElementById('uploadProgressBar');
    const uploadPercentage = document.getElementById('uploadPercentage');
    const progressText = document.getElementById('progressText');
    const uploadSpeed = document.getElementById('uploadSpeed');
    const uploadStatus = document.getElementById('uploadStatus');
    const cancelBtn = document.getElementById('cancelBtn');
    
    let startTime = null;
    let uploadedBytes = 0;
    let currentXHR = null;
    let isUploading = false; // Flag to track upload state

    // Preview functionality
    videoInput.addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (file) {
        // Check file size (500MB limit - matching backend)
        const maxSize = 500 * 1024 * 1024; // 500MB in bytes
        if (file.size > maxSize) {
          alert('File size exceeds 500MB limit. Please select a smaller file.');
          videoInput.value = '';
          document.getElementById('preview').style.display = 'none';
          return;
        }

        // Check file type (basic validation)
        const validTypes = ['video/mp4', 'video/webm', 'video/ogg', 'video/quicktime', 'video/x-msvideo'];
        const fileName = file.name.toLowerCase();
        const validExtensions = ['.mp4', '.webm', '.ogg', '.mov', '.avi'];
        const hasValidExtension = validExtensions.some(ext => fileName.endsWith(ext));
        
        if (!validTypes.includes(file.type) && !hasValidExtension) {
          alert('Invalid file type. Please select MP4, WEBM, OGG, MOV, or AVI file.');
          videoInput.value = '';
          document.getElementById('preview').style.display = 'none';
          return;
        }

        // Show preview
        const videoURL = URL.createObjectURL(file);
        document.getElementById('videoSource').src = videoURL;
        document.getElementById('previewVideo').load();
        document.getElementById('preview').style.display = 'block';
        
        // Show basic file info
        const sizeInMB = (file.size / (1024 * 1024)).toFixed(2);
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = sizeInMB + ' MB';
      }
    });

    // Handle form submission with progress
    uploadForm.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const file = videoInput.files[0];
      if (!file) {
        alert('Please select a video file');
        return;
      }

      // Double-check file size
      const maxSize = 500 * 1024 * 1024;
      if (file.size > maxSize) {
        alert('File size exceeds 500MB limit. Please select a smaller file.');
        return;
      }

      // Disable submit button and show loading UI
      submitBtn.disabled = true;
      cancelBtn.classList.add('disabled');
      loadingSpinner.style.display = 'inline-block';
      uploadProgressContainer.style.display = 'block';
      
      // Set uploading flag
      isUploading = true;
      
      // Reset progress
      updateProgress(0);
      startTime = Date.now();
      uploadedBytes = 0;
      
      if (uploadStatus) {
        uploadStatus.textContent = 'Preparing upload...';
      }

      const formData = new FormData(uploadForm);
      
      // Create new XHR request
      currentXHR = new XMLHttpRequest();
      
      // Track upload progress
      currentXHR.upload.addEventListener('progress', function(e) {
        if (e.lengthComputable) {
          const percentComplete = Math.round((e.loaded / e.total) * 100);
          updateProgress(percentComplete);
          
          // Calculate upload speed
          if (startTime) {
            const elapsedSeconds = (Date.now() - startTime) / 1000;
            const speed = e.loaded / elapsedSeconds; // bytes per second
            uploadedBytes = e.loaded;
            
            // Format speed
            let speedText;
            if (speed > 1024 * 1024) {
              speedText = (speed / (1024 * 1024)).toFixed(2) + ' MB/s';
            } else if (speed > 1024) {
              speedText = (speed / 1024).toFixed(2) + ' KB/s';
            } else {
              speedText = speed.toFixed(2) + ' B/s';
            }
            
            // Calculate remaining time
            const remainingBytes = e.total - e.loaded;
            const remainingSeconds = remainingBytes / speed;
            const remainingTime = formatTime(remainingSeconds);
            
            // Update UI
            if (uploadSpeed) {
              uploadSpeed.textContent = `Speed: ${speedText} | Remaining: ${remainingTime}`;
            }
            
            // Update status with file info
            if (uploadStatus) {
              const uploadedMB = (e.loaded / (1024 * 1024)).toFixed(2);
              const totalMB = (e.total / (1024 * 1024)).toFixed(2);
              uploadStatus.textContent = `Uploaded: ${uploadedMB} MB of ${totalMB} MB`;
            }
          }
        }
      });

      // Handle completion
      currentXHR.addEventListener('load', function() {
        // Clear uploading flag
        isUploading = false;
        
        if (currentXHR.status === 200) {
          // Success - update progress to 100%
          updateProgress(100);
          if (uploadStatus) {
            uploadStatus.textContent = 'Upload complete! Redirecting...';
          }
          
          // Remove beforeunload event listener before redirect
          window.removeEventListener('beforeunload', beforeUnloadHandler);
          
          // Redirect immediately
          window.location.href = '/admin/videos';
        } else {
          // Error - try to parse error message from response
          let errorMessage = 'Upload failed';
          try {
            const response = JSON.parse(currentXHR.responseText);
            errorMessage = response.error || response.message || errorMessage;
          } catch(e) {
            // If response is HTML, try to extract flash message
            const match = currentXHR.responseText.match(/alert-danger[^>]*>([^<]+)/);
            if (match) {
              errorMessage = match[1].trim();
            } else {
              errorMessage = currentXHR.statusText || 'Server error occurred';
            }
          }
          
          alert('Error: ' + errorMessage);
          resetUploadForm();
        }
      });

      // Handle network error
      currentXHR.addEventListener('error', function() {
        isUploading = false;
        alert('Network error occurred during upload. Please check your connection and try again.');
        resetUploadForm();
      });

      // Handle abort
      currentXHR.addEventListener('abort', function() {
        isUploading = false;
        alert('Upload was cancelled');
        resetUploadForm();
      });

      // Open and send (no timeout - removed as requested)
      currentXHR.open('POST', uploadForm.action, true);
      currentXHR.send(formData);
    });

    // Helper function to update progress bar
    function updateProgress(percent) {
      if (!uploadProgressBar || !uploadPercentage || !progressText) return;
      
      // Ensure percent is between 0 and 100
      percent = Math.min(100, Math.max(0, percent));
      
      uploadProgressBar.style.width = percent + '%';
      uploadProgressBar.setAttribute('aria-valuenow', percent);
      uploadPercentage.textContent = percent + '%';
      progressText.textContent = percent + '%';
      
      // Change color based on progress
      uploadProgressBar.className = 'progress-bar progress-bar-striped progress-bar-animated';
      if (percent < 30) {
        uploadProgressBar.classList.add('bg-info');
      } else if (percent < 70) {
        uploadProgressBar.classList.add('bg-primary');
      } else if (percent < 90) {
        uploadProgressBar.classList.add('bg-warning');
      } else {
        uploadProgressBar.classList.add('bg-success');
      }
    }

    // Helper function to format time
    function formatTime(seconds) {
      if (!seconds || seconds < 0 || !isFinite(seconds)) return 'calculating...';
      
      const hrs = Math.floor(seconds / 3600);
      const mins = Math.floor((seconds % 3600) / 60);
      const secs = Math.floor(seconds % 60);
      
      if (hrs > 0) {
        return hrs + 'h ' + mins + 'm ' + secs + 's';
      } else if (mins > 0) {
        return mins + 'm ' + secs + 's';
      } else {
        return secs + 's';
      }
    }

    // Helper function to reset form after error
    function resetUploadForm() {
      submitBtn.disabled = false;
      cancelBtn.classList.remove('disabled');
      loadingSpinner.style.display = 'none';
      uploadProgressContainer.style.display = 'none';
      if (uploadSpeed) uploadSpeed.textContent = '';
      if (uploadStatus) uploadStatus.textContent = '';
      
      // Reset progress bar
      updateProgress(0);
      
      currentXHR = null;
    }

    // Before unload handler function
    function beforeUnloadHandler(e) {
      if (isUploading) {
        // Cancel the event and show confirmation
        e.preventDefault();
        e.returnValue = 'Upload in progress. Are you sure you want to leave?';
        return e.returnValue;
      }
    }

    // Add beforeunload event listener
    window.addEventListener('beforeunload', beforeUnloadHandler);

    // Clean up object URLs when leaving
    window.addEventListener('unload', function() {
      const videoSource = document.getElementById('videoSource');
      if (videoSource && videoSource.src) {
        URL.revokeObjectURL(videoSource.src);
      }
    });

    // Add keyboard shortcut to cancel upload (Escape key)
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && currentXHR && isUploading) {
        if (confirm('Cancel upload?')) {
          currentXHR.abort();
        }
      }
    });

    // Auto-hide flash messages after 5 seconds
    setTimeout(() => {
      document.querySelectorAll('.alert').forEach(alert => {
        alert.classList.add('fade');
        setTimeout(() => {
          alert.remove();
        }, 500);
      });
    }, 5000);
  });
</script>