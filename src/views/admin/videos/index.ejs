<%- contentFor('title') %>
<%- contentFor('head') %>
<%- contentFor('body') %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <div class="row align-items-center">
          <div class="col-sm-6">
            <h4><i class="bi bi-camera-reels"></i> Video Management</h4>
          </div>
          <div class="col-sm-6">
            <div class="d-flex justify-content-end gap-2">
              <a href="/admin/videos/upload" class="btn btn-primary">
                <i class="bi bi-cloud-upload"></i> Upload Video
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mt-3">
  <div class="col-md-6">
    <div class="card bg-primary text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">Total Videos</h6>
            <h2 class="mb-0"><%= stats.totalVideos %></h2>
          </div>
          <i class="bi bi-camera-reels fs-1"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card bg-success text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">Total Size</h6>
            <h2 class="mb-0"><%= stats.totalSize %></h2>
          </div>
          <i class="bi bi-hdd-stack fs-1"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filters -->
<div class="row mt-3">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <form action="/admin/videos" method="GET" class="row g-3">
          <div class="col-md-8">
            <input type="text" class="form-control" name="search" placeholder="Search by filename, title, or description..." value="<%= search %>">
          </div>
          <div class="col-md-2">
            <select name="status" class="form-select">
              <option value="">All Status</option>
              <option value="active" <%= selectedStatus === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= selectedStatus === 'inactive' ? 'selected' : '' %>>Inactive</option>
              <option value="processing" <%= selectedStatus === 'processing' ? 'selected' : '' %>>Processing</option>
              <option value="failed" <%= selectedStatus === 'failed' ? 'selected' : '' %>>Failed</option>
            </select>
          </div>
          <div class="col-md-2">
            <button class="btn btn-primary w-100" type="submit">
              <i class="bi bi-search"></i> Filter
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Bulk Actions -->
<div class="row mt-3">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="d-flex gap-2 align-items-center">
          <button type="button" class="btn btn-danger" id="bulkDeleteBtn" style="display: none;">
            <i class="bi bi-trash"></i> Delete Selected
          </button>
          <select class="form-select w-auto" id="bulkStatusSelect" style="display: none;">
            <option value="active">Set Active</option>
            <option value="inactive">Set Inactive</option>
          </select>
          <button type="button" class="btn btn-info" id="bulkUpdateStatusBtn" style="display: none;">
            <i class="bi bi-check-circle"></i> Update Status
          </button>
          <span class="text-muted" id="selectedCount"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Videos Grid -->
<div class="row mt-3">
  <% if (videos && videos.length > 0) { %>
    <% videos.forEach(video => { %>
      <div class="col-md-3 mb-4">
        <div class="card h-100 video-card">
          <div class="position-relative">
            <input type="checkbox" class="form-check-input position-absolute top-0 start-0 m-2 video-checkbox" value="<%= video.id %>" style="z-index: 10;">
            <span class="position-absolute top-0 end-0 m-2 badge bg-<%= 
              video.status === 'active' ? 'success' : 
              video.status === 'processing' ? 'warning' : 
              video.status === 'failed' ? 'danger' : 'secondary' 
            %>"><%= video.status %></span>
            <a href="/admin/videos/<%= video.id %>">
              <!-- REMOVED: video.getThumbnail() call, using placeholder directly -->
              <img src="/assets/images/839.jpg" class="card-img-top" alt="<%= video.title %>" style="height: 150px; object-fit: cover;">
            </a>
            <!-- REMOVED: Duration badge -->
          </div>
          <div class="card-body">
            <h6 class="card-title text-truncate" title="<%= video.title %>"><%= video.title %></h6>
            <p class="card-text small text-muted mb-1">
              <i class="bi bi-file-earmark"></i> <%= video.filename.length > 30 ? video.filename.substring(0, 27) + '...' : video.filename %>
            </p>
            <p class="card-text small text-muted mb-1">
              <i class="bi bi-calendar"></i> <%= new Date(video.createdAt).toLocaleDateString() %>
            </p>
            <!-- REMOVED: Quality and dimensions -->
            <p class="card-text small text-muted">
              <i class="bi bi-hdd"></i> <%= (video.size / (1024 * 1024)).toFixed(2) %> MB
            </p>
          </div>
          <div class="card-footer bg-transparent">
            <div class="btn-group w-100">
              <a href="/admin/videos/<%= video.id %>" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-eye"></i> View
              </a>
              <button type="button" class="btn btn-sm btn-outline-danger delete-video" data-id="<%= video.id %>">
                <i class="bi bi-trash"></i> Delete
              </button>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col-12">
      <div class="card">
        <div class="card-body text-center py-5">
          <i class="bi bi-camera-reels fs-1 text-muted"></i>
          <h5 class="mt-3">No videos found</h5>
          <p class="text-muted">Get started by uploading your first video</p>
          <a href="/admin/videos/upload" class="btn btn-primary">
            <i class="bi bi-cloud-upload"></i> Upload Video
          </a>
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (pagination.pages > 1) { %>
  <nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.page - 1 %><%= search ? '&search=' + search : '' %><%= selectedStatus ? '&status=' + selectedStatus : '' %>">Previous</a>
      </li>
      
      <% for (let i = 1; i <= pagination.pages; i++) { %>
        <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= selectedStatus ? '&status=' + selectedStatus : '' %>"><%= i %></a>
        </li>
      <% } %>
      
      <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.page + 1 %><%= search ? '&search=' + search : '' %><%= selectedStatus ? '&status=' + selectedStatus : '' %>">Next</a>
      </li>
    </ul>
  </nav>
<% } %>

<script>
  $(document).ready(function() {
    let selectedVideos = [];
    
    // Individual delete
    $('.delete-video').on('click', function() {
      const videoId = $(this).data('id');
      
      if (confirm('Are you sure you want to delete this video?')) {
        $.ajax({
          url: '/admin/videos/' + videoId,
          method: 'DELETE',
          success: function(response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || 'Failed to delete video');
            }
          },
          error: function() {
            alert('Failed to delete video');
          }
        });
      }
    });

    // Handle checkbox selection
    $('.video-checkbox').on('change', function() {
      const videoId = $(this).val();
      
      if ($(this).is(':checked')) {
        selectedVideos.push(videoId);
      } else {
        selectedVideos = selectedVideos.filter(id => id !== videoId);
      }
      
      // Show/hide bulk action buttons
      if (selectedVideos.length > 0) {
        $('#bulkDeleteBtn').show();
        $('#bulkStatusSelect').show();
        $('#bulkUpdateStatusBtn').show();
        $('#selectedCount').text(selectedVideos.length + ' video(s) selected');
      } else {
        $('#bulkDeleteBtn').hide();
        $('#bulkStatusSelect').hide();
        $('#bulkUpdateStatusBtn').hide();
        $('#selectedCount').text('');
      }
    });

    // Bulk delete
    $('#bulkDeleteBtn').on('click', function() {
      if (selectedVideos.length === 0) return;
      
      if (confirm(`Are you sure you want to delete ${selectedVideos.length} video(s)?`)) {
        $.ajax({
          url: '/admin/videos/bulk-delete',
          method: 'POST',
          data: { videoIds: selectedVideos },
          success: function(response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || 'Failed to delete videos');
            }
          },
          error: function() {
            alert('Failed to delete videos');
          }
        });
      }
    });

    // Bulk update status
    $('#bulkUpdateStatusBtn').on('click', function() {
      if (selectedVideos.length === 0) return;
      
      const status = $('#bulkStatusSelect').val();
      
      if (confirm(`Are you sure you want to set status to "${status}" for ${selectedVideos.length} video(s)?`)) {
        $.ajax({
          url: '/admin/videos/bulk-update-status',
          method: 'POST',
          data: { 
            videoIds: selectedVideos,
            status: status
          },
          success: function(response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || 'Failed to update videos');
            }
          },
          error: function() {
            alert('Failed to update videos');
          }
        });
      }
    });
  });
</script>

<style>
  .video-card {
    transition: transform 0.2s;
  }
  .video-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }
  .video-checkbox {
    width: 20px;
    height: 20px;
    cursor: pointer;
  }
</style>