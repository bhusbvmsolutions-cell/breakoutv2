<%- contentFor('title') %> <%= title %>
<%- contentFor('head') %>

<style>
  .hover-lift {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .hover-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 1rem 2rem rgba(0,0,0,0.1) !important;
  }
</style>
<%- contentFor('body') %>


<div class="row">
  <div class="col-12 col-lg-12">
    <div class="card">
      <div class="card-header">
        <h4><i class="bi bi-speedometer2"></i> Dashboard</h4>
      </div>
    </div>
  </div>
</div>




<!-- Media Section -->
<div class="row mt-4">
  <div class="col-12">
    <div class="card radius-10 border-0 shadow-sm">
      <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
        <h5 class="mb-0"><i class="bi bi-collection-play me-2"></i> Media Library</h5>
        <p class="text-secondary small mb-0 mt-1">Manage your visual assets – images, logos, and videos</p>
      </div>
      <div class="card-body">
        <div class="row g-4">
          
          <!-- Images Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-primary text-primary mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-images"></i>
                </div>
                <h5 class="card-title">Images</h5>
                <p class="card-text text-secondary">
                  Total: <strong><%= stats?.totalImages || 0 %></strong> images
                </p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                </div>
                <a href="/admin/images" class="btn btn-outline-primary mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Images
                </a>
              </div>
            </div>
          </div>

          <!-- Logos Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-warning text-warning mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-brush"></i>
                </div>
                <h5 class="card-title">Logos</h5>
                <p class="card-text text-secondary">
                  Total: <strong><%= stats?.totalLogos || 0 %></strong> logos
                </p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                </div>
                <a href="/admin/logos" class="btn btn-outline-warning mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Logos
                </a>
              </div>
            </div>
          </div>

          <!-- Videos Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-success text-success mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-camera-reels"></i>
                </div>
                <h5 class="card-title">Videos</h5>
                <div class="d-flex justify-content-evenly align-items-center">
                  <p class="card-text text-secondary mb-0">
                    Total: <strong><%= stats?.totalVideos || 0 %></strong> videos
                  </p>
                  <p class="card-text text-secondary">
                    Active: <strong><%= stats?.activeVideos || 0 %></strong> videos
                  </p>
                </div>
                  <a href="/admin/videos" class="btn btn-outline-success mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Videos
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>





<!-- Blogs Section -->
<div class="row mt-4">
  <div class="col-12">
    <div class="card radius-10 border-0 shadow-sm">
      <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
        <h5 class="mb-0"><i class="bi bi-body-text"></i> Blogs Library</h5>
        <p class="text-secondary small mb-0 mt-1">Manage your Blogs – SEO/Places, Breakout Party</p>
      </div>
      <div class="card-body">
        <div class="row g-4">
          
          <!-- SEO Blogs Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-primary text-primary mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-search"></i>
                </div>
                <h5 class="card-title">SEO/Places Blogs</h5>
                <p class="card-text text-secondary">
                  Total: <strong><%= stats?.TotalSEOBlogs || 0 %></strong> Blogs
                </p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                </div>
                <a href="/admin/birthday-blog" class="btn btn-outline-primary mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Blogs
                </a>
              </div>
            </div>
          </div>

          <!-- BreakOut Party Blogs Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-warning text-warning mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-search"></i>
                </div>
                <h5 class="card-title">Breakout Party Blogs</h5>
                <p class="card-text text-secondary">
                  Total: <strong><%= stats?.TotalBreakoutBlogs || 0 %></strong> logos
                </p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                </div>
                <a href="/admin/breakout-party-blog" class="btn btn-outline-warning mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Blogs
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>




<!-- EscapeRooms Section -->
<div class="row mt-4">
  <div class="col-12">
    <div class="card radius-10 border-0 shadow-sm">
      <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
        <h5 class="mb-0"><i class="bi bi-controller"></i> EscapeRooms</h5>
        <p class="text-secondary small mb-0 mt-1">Manage your EscapeRooms</p>
      </div>
      <div class="card-body">
        <div class="row g-4">
          
          <!-- EscapeRoom Locations Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-primary text-primary mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-geo-alt"></i>
                </div>
                <h5 class="card-title">EscapeRoom Locations</h5>
                <p class="card-text text-secondary">
                  Total: <strong><%= stats?.totalEscapeRoomLocation || 0 %></strong> Locations
                </p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                </div>
                <a href="/admin/escape/locations" class="btn btn-outline-primary mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Locations
                </a>
              </div>
            </div>
          </div>

          <!-- EscapeRooms Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-warning text-warning mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-door-open"></i>
                </div>
                <h5 class="card-title">EscapeRooms</h5>
                <p class="card-text text-secondary">
                  Total: <strong><%= stats?.totalEscapeRooms || 0 %></strong> Rooms
                </p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                </div>
                <a href="/admin/escape/rooms" class="btn btn-outline-warning mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Rooms
                </a>
              </div>
            </div>
          </div>


          <!-- VirtualRooms Grid -->
          <div class="col-12 col-md-4">
            <div class="card h-100 radius-10 border-0 shadow-sm hover-lift">
              <div class="card-body text-center">
                <div class="widgets-icons bg-light-warning text-warning mx-auto mb-3" style="width: 64px; height: 64px; font-size: 2rem;">
                  <i class="bi bi-display"></i>
                </div>
                <h5 class="card-title">VirtualRooms</h5>
                <p class="card-text text-secondary">
                  Total: <strong><%= stats?.totalVirtualRooms || 0 %></strong> Rooms
                </p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                </div>
                <a href="/admin/virtual/game" class="btn btn-outline-warning mt-3 w-100">
                  <i class="bi bi-box-arrow-up-right me-1"></i> View All Rooms
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>