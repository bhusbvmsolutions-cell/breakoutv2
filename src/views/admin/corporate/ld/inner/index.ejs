<%- contentFor('title') %> Corporate L&D Inner Pages
<%- contentFor('head') %>
<style>
  body {
    background: #f5f7fb;
  }

  .stats-card {
    background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%);
    border-radius: 10px;
    padding: 0.75rem;
    color: #2c3e50;
    text-align: center;
    transition: transform 0.2s ease;
  }

  .stats-card:hover {
    transform: translateY(-3px);
  }

  .stats-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0;
  }

  .stats-card p {
    margin-bottom: 0;
    font-size: 0.7rem;
    opacity: 0.9;
  }

  .search-box {
    position: relative;
    max-width: 300px;
  }

  .search-box input {
    padding-left: 2rem;
    border-radius: 20px;
    border: 1px solid #dee2e6;
    font-size: 0.8rem;
    height: 32px;
  }

  .search-box input:focus {
    border-color: #fcad00;
    box-shadow: 0 0 0 0.2rem rgba(252, 173, 0, 0.25);
  }

  .search-box i {
    position: absolute;
    left: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.9rem;
    color: #adb5bd;
  }

  .pages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .pages-grid-empty {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100%, 1fr)) !important;
    gap: 1rem;
  }

  .page-card {
    background: #fff;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    transition: all 0.2s ease;
  }

  .page-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .page-card-image {
    height: 140px;
    background: #f8f9fa;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .page-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .page-card:hover .page-card-image img {
    transform: scale(1.03);
  }

  .page-card-content {
    padding: 0.75rem;
  }

  .page-card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: #2c3e50;
  }

  .page-card-slug {
    font-size: 0.7rem;
    color: #6c757d;
    margin-bottom: 0.5rem;
    word-break: break-all;
  }

  .page-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .page-card-status {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .page-card-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .no-pages {
    text-align: center;
    padding: 2rem;
    background: #f8f9fa;
    border-radius: 12px;
    color: #6c757d;
  }

  .btn-sm {
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
  }

  @media (max-width: 768px) {
    .pages-grid {
      grid-template-columns: 1fr;
    }
    .pages-grid-empty{
      grid-template-columns: 3fr;

    }
  }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-3">
  <div class="row mb-3 align-items-center">
    <div class="col-md-8">
      <h4 class="mb-0 fw-bold">Corporate L&D Inner Pages</h4>
      <p class="text-muted small mb-0">Manage all corporate L&D inner content pages</p>
    </div>
    <div class="col-md-4 text-md-end mt-2 mt-md-0">
      <a href="/admin/corporate/ld/inner/create" class="btn btn-primary btn-sm">
        <i class="bx bx-plus-circle me-1"></i> Add New Page
      </a>
    </div>
  </div>

  <div class="row g-2 mb-3">
    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="totalPages">0</h3>
        <p>Total Pages</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="activePages">0</h3>
        <p>Active Pages</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="inactivePages">0</h3>
        <p>Inactive Pages</p>
      </div>
    </div>
  </div>

  <div class="row mb-3 align-items-center">
    <div class="col-md-6">
      <div class="search-box">
        <i class="bx bx-search"></i>
        <input type="text" id="searchPages" class="form-control" placeholder="Search by title or slug...">
      </div>
    </div>
    <div class="col-md-6 text-md-end">
      <div class="btn-group btn-group-sm">
        <button class="btn btn-outline-secondary filter-status active" data-status="all">All</button>
        <button class="btn btn-outline-secondary filter-status" data-status="active">Active</button>
        <button class="btn btn-outline-secondary filter-status" data-status="inactive">Inactive</button>
      </div>
    </div>
  </div>

  <% if (pages && pages.length) { %>
  <div id="pagesContainer" class="pages-grid">
    <% pages.forEach(page => { %>
    <div class="page-card" data-title="<%= page.title.toLowerCase() %>" data-slug="<%= page.slug.toLowerCase() %>" data-status="<%= page.isActive ? 'active' : 'inactive' %>">
      <div class="page-card-image">
        <% if (page.banner_image) { %>
        <img src="<%= page.banner_image %>" alt="<%= page.title %>">
        <% } else { %>
        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
          <i class="bx bx-image-alt fs-3"></i>
          <span class="small mt-1">No image</span>
        </div>
        <% } %>
      </div>
      <div class="page-card-content">
        <h5 class="page-card-title"><%= page.title %></h5>
        <div class="page-card-slug"><i class="bx bx-link-alt me-1"></i> <%= page.slug %></div>
        <div class="page-card-meta">
          <span class="page-card-status badge <%= page.isActive ? 'bg-success' : 'bg-secondary' %>"><%= page.isActive ? 'Active' : 'Inactive' %></span>
          <span class="page-card-date small"><i class="bx bx-calendar me-1"></i> <%= new Date(page.createdAt).toLocaleDateString() %></span>
        </div>
        <div class="page-card-actions">
          <a href="/admin/corporate/ld/inner/view/<%= page.id %>" class="btn btn-sm btn-info"><i class="bx bx-show"></i> View</a>
          <a href="/admin/corporate/ld/inner/edit/<%= page.id %>" class="btn btn-sm btn-warning"><i class="bx bx-edit"></i> Edit</a>
          <button class="btn btn-sm btn-danger delete-page" data-id="<%= page.id %>"><i class="bx bx-trash"></i> Delete</button>
        </div>
      </div>
    </div>
  </div>
  <% }); %>
  <% } else { %>
  <div id="pagesContainer" class="pages-grid-empty">
    <div class="no-pages">
      <i class="bx bx-ghost fs-2"></i>
      <h5 class="mt-2">No pages found</h5>
      <p class="small">Get started by creating your first corporate L&D inner page.</p>
      <a href="/admin/corporate/ld/inner/create" class="btn btn-primary btn-sm mt-1">Add New Page</a>
    </div>
  </div>
  <% } %>
</div>

<%- contentFor('js') %>
<script>
  const pages = document.querySelectorAll('.page-card');

  function updateStats() {
    const total = pages.length;
    const active = Array.from(pages).filter(p => p.dataset.status === 'active').length;
    document.getElementById('totalPages').innerText = total;
    document.getElementById('activePages').innerText = active;
    document.getElementById('inactivePages').innerText = total - active;
  }

  function filterPages() {
    const term = document.getElementById('searchPages').value.toLowerCase().trim();
    const status = document.querySelector('.filter-status.active').dataset.status;
    pages.forEach(card => {
      const title = card.dataset.title,
        slug = card.dataset.slug,
        cardStatus = card.dataset.status;
      const match = (term === '' || title.includes(term) || slug.includes(term)) && (status === 'all' || cardStatus === status);
      card.style.display = match ? '' : 'none';
    });
  }
  document.getElementById('searchPages').addEventListener('input', filterPages);
  document.querySelectorAll('.filter-status').forEach(btn => btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-status').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    filterPages();
  }));
  updateStats();
  document.querySelectorAll('.delete-page').forEach(btn => btn.addEventListener('click', async e => {
    if (!confirm('Delete this page?')) return;
    const id = btn.dataset.id,
      res = await fetch(`/admin/corporate/ld/inner/delete/${id}`, {
        method: 'DELETE'
      });
    const data = await res.json();
    if (data.success) location.reload();
    else alert(data.message);
  }));
</script>