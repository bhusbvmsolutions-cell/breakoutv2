<div class="row">
    <div class="col-12 col-lg-12">
      <div class="card">
        <div class="card-header">
          <h4><i class="bi bi-key"></i> Permission Management</h4>
        </div>
      </div>
    </div>
  </div>
  
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle"></i> <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle"></i> <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  
  <div class="card">
    <div class="card-header">
      <div class="row align-items-center">
        <div class="col-sm-6">
          <h5 class="mb-0">All Permissions</h5>
        </div>
        <div class="col-sm-6">
          <div class="d-flex justify-content-end gap-2">
            <form action="/admin/permissions" method="GET" class="d-flex">
              <select name="resource" class="form-select form-select-sm me-2" style="width: 150px;">
                <option value="">All Resources</option>
                <% resources.forEach(res => { %>
                  <option value="<%= res %>" <%= selectedResource === res ? 'selected' : '' %>><%= res %></option>
                <% }); %>
              </select>
              <input type="text" name="search" class="form-control form-control-sm me-2" placeholder="Search permissions..." value="<%= search || '' %>" style="width: 200px;">
              <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-search"></i>
              </button>
            </form>
            
            <% if (canGeneratePermissions) { %>
              <button type="button" class="btn btn-sm btn-success" id="generatePermissions">
                <i class="bi bi-magic"></i> Auto-Generate
              </button>
            <% } %>

            <% if (canRefreshPermissions) { %>
              <button type="button" class="btn btn-sm btn-warning" id="refreshPermissions">
                <i class="bi bi-arrow-repeat"></i> Refresh
              </button>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <div class="card-body">
      <!-- Grouped by Resource -->
      <ul class="nav nav-tabs mb-3" id="permissionTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button">All</button>
        </li>
        <% Object.keys(groupedPermissions).forEach(resource => { %>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="<%= resource %>-tab" data-bs-toggle="tab" data-bs-target="#<%= resource %>" type="button">
              <%= resource.charAt(0).toUpperCase() + resource.slice(1) %>
            </button>
          </li>
        <% }); %>
      </ul>
      
      <div class="tab-content" id="permissionTabsContent">
        <div class="tab-pane fade show active" id="all" role="tabpanel">
          <div class="table-responsive">
            <table class="table table-hover">
              <thead class="table-light">
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Resource</th>
                  <th>Action</th>
                  <th>Description</th>
                  <th>Type</th>
                  <th>Roles</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (permissions && permissions.length > 0) { %>
                  <% permissions.forEach(perm => { %>
                    <tr>
                      <td><%= perm.id %></td>
                      <td><code><%= perm.name %></code></td>
                      <td><span class="badge bg-info"><%= perm.resource %></span></td>
                      <td><span class="badge bg-secondary"><%= perm.action %></span></td>
                      <td><%= perm.description || '-' %></td>
                      <td>
                        <% if (perm.isSystem) { %>
                          <span class="badge bg-danger">System</span>
                        <% } else { %>
                          <span class="badge bg-success">Custom</span>
                        <% } %>
                      </td>
                      <td>
                        <button type="button" class="btn btn-sm btn-outline-info view-roles" data-perm-id="<%= perm.id %>">
                          <i class="bi bi-people"></i> View
                        </button>
                      </td>
                      <td>
                        <% if (canUpdatePermissions) { %>
                          <button type="button" class="btn btn-sm btn-outline-warning edit-permission" data-perm-id="<%= perm.id %>">
                            <i class="bi bi-pencil"></i>
                          </button>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="8" class="text-center py-4">No permissions found</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        
        <% Object.keys(groupedPermissions).forEach(resource => { %>
          <div class="tab-pane fade" id="<%= resource %>" role="tabpanel">
            <div class="table-responsive">
              <table class="table table-hover">
                <thead class="table-light">
                  <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Action</th>
                    <th>Description</th>
                    <th>Type</th>
                    <th>Roles</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% groupedPermissions[resource].forEach(perm => { %>
                    <tr>
                      <td><%= perm.id %></td>
                      <td><code><%= perm.name %></code></td>
                      <td><span class="badge bg-secondary"><%= perm.action %></span></td>
                      <td><%= perm.description || '-' %></td>
                      <td>
                        <% if (perm.isSystem) { %>
                          <span class="badge bg-danger">System</span>
                        <% } else { %>
                          <span class="badge bg-success">Custom</span>
                        <% } %>
                      </td>
                      <td>
                        <button type="button" class="btn btn-sm btn-outline-info view-roles" data-perm-id="<%= perm.id %>">
                          <i class="bi bi-people"></i> View
                        </button>
                      </td>
                      <td>
                        <% if (canUpdatePermissions) { %>
                          <button type="button" class="btn btn-sm btn-outline-warning edit-permission" data-perm-id="<%= perm.id %>">
                            <i class="bi bi-pencil"></i>
                          </button>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        <% }); %>
      </div>
  
      <!-- Pagination -->
      <% if (pagination.pages > 1) { %>
        <nav aria-label="Page navigation" class="mt-3">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page - 1 %><%= search ? '&search=' + search : '' %><%= selectedResource ? '&resource=' + selectedResource : '' %>">Previous</a>
            </li>
            
            <% for (let i = 1; i <= pagination.pages; i++) { %>
              <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= selectedResource ? '&resource=' + selectedResource : '' %>"><%= i %></a>
              </li>
            <% } %>
            
            <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page + 1 %><%= search ? '&search=' + search : '' %><%= selectedResource ? '&resource=' + selectedResource : '' %>">Next</a>
            </li>
          </ul>
        </nav>
      <% } %>
    </div>
  </div>
  
  <!-- View Roles Modal -->
  <div class="modal fade" id="viewRolesModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Roles with Permission</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div id="rolesList"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Edit Permission Modal -->
  <div class="modal fade" id="editPermissionModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Permission</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="editPermissionForm">
          <div class="modal-body">
            <input type="hidden" id="editPermId" name="id">
            <div class="mb-3">
              <label class="form-label">Permission Name</label>
              <input type="text" class="form-control" id="editPermName" readonly>
            </div>
            <div class="mb-3">
              <label class="form-label">Resource</label>
              <input type="text" class="form-control" id="editPermResource" readonly>
            </div>
            <div class="mb-3">
              <label class="form-label">Action</label>
              <input type="text" class="form-control" id="editPermAction" readonly>
            </div>
            <div class="mb-3">
              <label for="editPermDescription" class="form-label">Description</label>
              <textarea class="form-control" id="editPermDescription" name="description" rows="3"></textarea>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  
  <script>
    $(document).ready(function() {
      // View roles with permission
      $('.view-roles').on('click', function() {
        const permId = $(this).data('perm-id');
        
        $('#rolesList').html('<div class="text-center"><div class="spinner-border"></div></div>');
        $('#viewRolesModal').modal('show');
        
        $.ajax({
          url: '/admin/permissions/' + permId + '/roles',
          method: 'GET',
          success: function(response) {
            if (response.success) {
              let html = '';
              
              if (response.roles.length === 0) {
                html = '<p class="text-center text-muted">No roles have this permission</p>';
              } else {
                html = '<ul class="list-group">';
                response.roles.forEach(role => {
                  html += `<li class="list-group-item d-flex justify-content-between align-items-center">
                    <strong>${role.displayName}</strong>
                    <span class="badge bg-info">Level ${role.level}</span>
                  </li>`;
                });
                html += '</ul>';
              }
              
              $('#rolesList').html(html);
            }
          },
          error: function() {
            $('#rolesList').html('<p class="text-danger text-center">Failed to load roles</p>');
          }
        });
      });
      
      // Edit permission
      $('.edit-permission').on('click', function() {
        const permId = $(this).data('perm-id');
        
        $.ajax({
          url: '/admin/permissions/' + permId,
          method: 'GET',
          success: function(response) {
            if (response.success) {
              const perm = response.permission;
              $('#editPermId').val(perm.id);
              $('#editPermName').val(perm.name);
              $('#editPermResource').val(perm.resource);
              $('#editPermAction').val(perm.action);
              $('#editPermDescription').val(perm.description || '');
              
              $('#editPermissionModal').modal('show');
            }
          }
        });
      });
      
      // Submit edit permission form
      $('#editPermissionForm').on('submit', function(e) {
        e.preventDefault();
        
        const permId = $('#editPermId').val();
        const description = $('#editPermDescription').val();
        
        $.ajax({
          url: '/admin/permissions/' + permId,
          method: 'PUT',
          data: { description },
          success: function(response) {
            if (response.success) {
              $('#editPermissionModal').modal('hide');
              window.location.reload();
            } else {
              alert(response.error || 'Failed to update permission');
            }
          },
          error: function() {
            alert('Failed to update permission');
          }
        });
      });
      
      // Generate permissions
      $('#generatePermissions').on('click', function() {
        if (confirm('This will generate all missing permissions based on models. Continue?')) {
          $.ajax({
            url: '/admin/permissions/generate',
            method: 'POST',
            success: function(response) {
              if (response.success) {
                alert(response.message);
                window.location.reload();
              } else {
                alert(response.error || 'Failed to generate permissions');
              }
            },
            error: function() {
              alert('Failed to generate permissions');
            }
          });
        }
      });
      
      // Refresh permissions
      $('#refreshPermissions').on('click', function() {
        if (confirm('This will regenerate all permissions and reassign them to super admin. Continue?')) {
          $.ajax({
            url: '/admin/permissions/refresh',
            method: 'POST',
            success: function(response) {
              if (response.success) {
                alert(response.message);
                window.location.reload();
              } else {
                alert(response.error || 'Failed to refresh permissions');
              }
            },
            error: function() {
              alert('Failed to refresh permissions');
            }
          });
        }
      });
    });
  </script>
