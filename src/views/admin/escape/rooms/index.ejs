<%- contentFor('title') %><%= title ? title : '' %>

<%- contentFor('head') %>
<style>
/* for now nothing */    
</style>

<%- contentFor('body') %>
<div class="container-fluid px-0">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-1">Escape Rooms</h5>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 fs-6">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Escape Rooms</li>
                </ol>
            </nav>
        </div>
        <a href="/admin/escape/rooms/add" class="btn btn-primary btn-sm">
            <i class="fas fa-plus me-1"></i> Add New Room
        </a>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3">
            <form id="filter-form" class="row g-2 align-items-center">
                <div class="col-lg-4 col-md-6">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" class="form-control form-control-sm border-0 bg-light" 
                               id="search" placeholder="Search rooms..." style="box-shadow: none;">
                    </div>
                </div>
                <div class="col-lg-2 col-md-3">
                    <select class="form-select form-select-sm bg-light border-0" id="location-filter">
                        <option value="">All Locations</option>
                        <% locations?.forEach(loc => { %>
                            <option value="<%= loc.id %>"><%= loc.title %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <select class="form-select form-select-sm bg-light border-0" id="status-filter">
                        <option value="">All Status</option>
                        <option value="1">Active</option>
                        <option value="0">Inactive</option>
                    </select>
                </div>
                <div class="col-lg-auto ms-auto">
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="reset-filters">
                        <i class="fas fa-redo-alt me-1"></i> Reset
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Rooms Grid -->
    <div class="row g-3" id="rooms-container">
        <% if (rooms && rooms.length > 0) { %>
            <% rooms.forEach(room => { %>
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="card h-100 shadow-sm border-0 hover-shadow transition">
                        <!-- Image -->
                        <div class="position-relative">
                            <% if (room.banner_image) { %>
                                <img src="<%= room.banner_image %>" class="card-img-top" alt="<%= room.title %>" 
                                     style="height: 140px; object-fit: cover;">
                            <% } else { %>
                                <div class="bg-light d-flex align-items-center justify-content-center" 
                                     style="height: 140px;">
                                    <i class="fas fa-image fa-3x text-muted opacity-50"></i>
                                </div>
                            <% } %>
                            
                            <!-- Status Badge -->
                            <span class="position-absolute top-0 end-0 m-2 badge bg-<%= room.isActive ? 'success' : 'secondary' %> px-2 py-1" 
                                  style="font-size: 0.7rem;">
                                <%= room.isActive ? 'Active' : 'Inactive' %>
                            </span>

                            <!-- Location Badges -->
                            <% if (room.locations && room.locations.length > 0) { %>
                                <div class="position-absolute bottom-0 start-0 m-2 d-flex gap-1">
                                    <% room.locations.slice(0, 2).forEach(loc => { %>
                                        <span class="badge bg-dark bg-opacity-75 px-2 py-1" style="font-size: 0.65rem;">
                                            <%= loc.title.substring(0, 3) %>..
                                        </span>
                                    <% }) %>
                                    <% if (room.locations.length > 2) { %>
                                        <span class="badge bg-dark bg-opacity-75 px-2 py-1" style="font-size: 0.65rem;">
                                            +<%= room.locations.length - 2 %>
                                        </span>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>

                        <!-- Content -->
                        <div class="card-body p-3">
                            <h6 class="card-title mb-2 text-truncate" style="font-size: 0.95rem;">
                                <%= room.title %>
                            </h6>
                            
                            <!-- Tags -->
                            <% if (room.tag && room.tag.length > 0) { %>
                                <div class="mb-2 d-flex flex-wrap gap-1">
                                    <% room.tag.slice(0, 3).forEach(tag => { %>
                                        <span class="badge bg-light text-dark px-2 py-1" style="font-size: 0.65rem;">
                                            <%= tag %>
                                        </span>
                                    <% }) %>
                                    <% if (room.tag.length > 3) { %>
                                        <span class="badge bg-light text-dark px-2 py-1" style="font-size: 0.65rem;">
                                            +<%= room.tag.length - 3 %>
                                        </span>
                                    <% } %>
                                </div>
                            <% } %>

                            <!-- Meta Info -->
                            <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                <small class="text-muted">
                                    <i class="far fa-calendar me-1"></i>
                                    <%= new Date(room.createdAt).toLocaleDateString() %>
                                </small>
                                <div class="btn-group btn-group-sm">
                                    <a href="/admin/escape/rooms/<%= room.id %>" 
                                       class="btn btn-outline-info" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/admin/escape/rooms/edit/<%= room.id %>" 
                                       class="btn btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button" class="btn btn-outline-danger delete-room" 
                                            data-id="<%= room.id %>" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-door-open fa-4x text-muted mb-3"></i>
                    <h6 class="text-muted">No escape rooms found</h6>
                    <a href="/admin/escape/rooms/add" class="btn btn-primary btn-sm mt-2">
                        <i class="fas fa-plus me-1"></i> Add Your First Room
                    </a>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
        <nav class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="/admin/escape/rooms?page=<%= currentPage - 1 %>">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                        <a class="page-link" href="/admin/escape/rooms?page=<%= i %>"><%= i %></a>
                    </li>
                <% } %>
                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="/admin/escape/rooms?page=<%= currentPage + 1 %>">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    <% } %>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title">Delete Room</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="small mb-0">Are you sure you want to delete this escape room? This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-danger" id="confirm-delete">Delete</button>
            </div>
        </div>
    </div>
</div>




<%- contentFor('js') %>
<script>
document.addEventListener('DOMContentLoaded', function() {
    let deleteId = null;
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    // Handle delete buttons
    document.querySelectorAll('.delete-room').forEach(btn => {
        btn.addEventListener('click', function() {
            deleteId = this.dataset.id;
            deleteModal.show();
        });
    });

    // Confirm delete
    document.getElementById('confirm-delete').addEventListener('click', async function() {
        if (!deleteId) return;

        try {
            const response = await fetch(`/admin/escape/rooms/${deleteId}`, {
                method: 'DELETE',
                headers: {
                    'Authorization': `Bearer ${localStorage.getItem('token')}`,
                    'Content-Type': 'application/json'
                }
            });

            if (response.ok) {
                window.location.reload();
            } else {
                alert('Failed to delete room');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('An error occurred');
        } finally {
            deleteModal.hide();
            deleteId = null;
        }
    });

    // Filter functionality
    const searchInput = document.getElementById('search');
    const locationFilter = document.getElementById('location-filter');
    const statusFilter = document.getElementById('status-filter');

    function applyFilters() {
        const params = new URLSearchParams(window.location.search);
        if (searchInput.value) params.set('search', searchInput.value);
        else params.delete('search');
        
        if (locationFilter.value) params.set('location', locationFilter.value);
        else params.delete('location');
        
        if (statusFilter.value) params.set('status', statusFilter.value);
        else params.delete('status');
        
        params.set('page', '1');
        
        window.location.search = params.toString();
    }

    searchInput.addEventListener('keyup', debounce(applyFilters, 500));
    locationFilter.addEventListener('change', applyFilters);
    statusFilter.addEventListener('change', applyFilters);

    document.getElementById('reset-filters').addEventListener('click', function() {
        window.location.search = '';
    });

    function debounce(func, wait) {
        let timeout;
        return function() {
            clearTimeout(timeout);
            timeout = setTimeout(func, wait);
        };
    }
});
</script>

<style>
.hover-shadow {
    transition: all 0.2s ease;
}
.hover-shadow:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.08) !important;
}
.transition {
    transition: all 0.2s ease;
}
</style>