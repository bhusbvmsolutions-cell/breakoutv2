<%- contentFor('title') %><%= room.title %>

<%- contentFor('head') %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
    :root {
      --primary-color: #fcad00;
      --primary-light: rgba(252, 173, 0, 0.1);
      --primary-dark: #e59c00;
      --detail-card-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
      --detail-card-hover: 0 6px 16px rgba(252, 173, 0, 0.08);
    }
  
    /* Base Layout */
    body {
      background-color: #f8fafc;
    }
  
    .container-fluid {
      max-width: 1600px;
      margin: 0 auto;
    }
  
    /* Action Bar */
    .action-bar-wrapper {
      background: white;
      border-radius: 2rem;
      padding: 0.3rem;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      display: inline-flex;
      margin-bottom: 1rem;
      border: 1px solid rgba(0,0,0,0.05);
    }
  
    .action-bar {
      display: flex;
      align-items: center;
    }
  
    .action-btn {
      padding: 0.25rem 0.9rem;
      border-radius: 2rem;
      font-size: 0.7rem;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition: all 0.15s ease;
      border: none;
      background: transparent;
      color: #6b7280;
      text-decoration: none;
      cursor: pointer;
    }
  
    .action-btn:hover {
      background: #f3f4f6;
      color: #1f2937;
    }
  
    .action-btn.primary {
      background: var(--primary-color);
      color: white;
    }
  
    .action-btn.primary:hover {
      background: var(--primary-dark);
    }
  
    .action-btn.danger:hover {
      background: #fee2e2;
      color: #dc2626;
    }
  
    .separator {
      width: 1px;
      height: 18px;
      background: #e5e7eb;
      margin: 0 0.15rem;
    }
  
    /* Detail Header - More Compact */
    .detail-header {
      background: white;
      border-radius: 0.6rem;
      padding: 0.75rem 1rem;
      margin-bottom: 1rem;
      border: 1px solid rgba(0, 0, 0, 0.05);
      box-shadow: var(--detail-card-shadow);
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  
    .header-icon {
      width: 36px;
      height: 36px;
      background: var(--primary-light);
      border-radius: 0.4rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  
    .header-icon i {
      color: var(--primary-color);
      font-size: 1rem;
    }
  
    .header-content {
      flex: 1;
    }
  
    .header-title {
      font-size: 1rem;
      font-weight: 600;
      color: #1f2937;
      margin-bottom: 0.15rem;
    }
  
    .header-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
  
    /* Status Banner - More Compact */
    .status-banner {
      padding: 0.25rem 0.75rem;
      border-radius: 2rem;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.65rem;
      font-weight: 500;
    }
  
    .status-banner.active {
      background: var(--primary-light);
      color: var(--primary-dark);
      border: 1px solid var(--primary-color);
    }
  
    .status-banner.inactive {
      background: #fee2e2;
      color: #991b1b;
    }
  
    /* Cards - More Compact */
    .detail-card {
      background: white;
      border-radius: 0.6rem;
      border: 1px solid rgba(0, 0, 0, 0.05);
      overflow: hidden;
      box-shadow: var(--detail-card-shadow);
      transition: all 0.2s ease;
      margin-bottom: 0.75rem;
    }
  
    .detail-card:last-child {
      margin-bottom: 0;
    }
  
    .detail-card:hover {
      box-shadow: var(--detail-card-hover);
      border-color: rgba(252, 173, 0, 0.2);
    }
  
    .detail-card-header {
      padding: 0.5rem 0.75rem;
      background: #f9fafb;
      border-bottom: 1px solid #e5e7eb;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
  
    .detail-card-header i {
      width: 22px;
      height: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      border-radius: 0.35rem;
      color: var(--primary-color);
      font-size: 0.75rem;
    }
  
    .detail-card-header h6 {
      font-size: 0.8rem;
      font-weight: 600;
      color: #1f2937;
      margin: 0;
    }
  
    .detail-card-body {
      padding: 0.75rem;
    }
  
    /* Info Grid - More Compact with Reduced Height */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 0.5rem;
    }
  
    .info-item {
      padding: 0.4rem 0.5rem;
      background: #f9fafb;
      border-radius: 0.4rem;
      border: 1px solid #e5e7eb;
      min-height: auto;
    }
  
    .info-label {
      font-size: 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.2px;
      color: #6b7280;
      margin-bottom: 0.1rem;
      line-height: 1.2;
    }
  
    .info-value {
      font-size: 0.75rem;
      font-weight: 500;
      color: #1f2937;
      word-break: break-word;
      line-height: 1.3;
    }
  
    /* Badges - More Compact */
    .badge-container {
      display: flex;
      flex-wrap: wrap;
      gap: 0.2rem;
    }
  
    .custom-badge {
      background: #f3f4f6;
      color: #4b5563;
      padding: 0.15rem 0.5rem;
      border-radius: 2rem;
      font-size: 0.6rem;
      font-weight: 500;
      border: 1px solid #e5e7eb;
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
    }
  
    .custom-badge.location {
      background: #e0f2fe;
      color: #0369a1;
      border-color: #bae6fd;
    }
  
    .custom-badge.tag {
      background: var(--primary-light);
      color: var(--primary-dark);
      border-color: var(--primary-color);
    }
  
    /* Banner Preview - Compact */
    .banner-preview {
      border-radius: 0.4rem;
      overflow: hidden;
      border: 1px solid #e5e7eb;
      margin-bottom: 0.6rem;
      cursor: pointer;
      transition: all 0.15s ease;
    }
  
    .banner-preview:hover {
      border-color: var(--primary-color);
      box-shadow: 0 2px 8px rgba(252, 173, 0, 0.2);
    }
  
    .banner-preview img {
      width: 100%;
      max-height: 140px;
      object-fit: cover;
      display: block;
    }
  
    /* Gallery Grid - Compact */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
      gap: 0.4rem;
    }
  
    .gallery-grid img {
      width: 100%;
      height: 60px;
      object-fit: cover;
      border-radius: 0.35rem;
      border: 1px solid #e5e7eb;
      transition: all 0.15s ease;
      cursor: pointer;
      display: block;
    }
  
    .gallery-grid img:hover {
      transform: scale(1.05);
      border-color: var(--primary-color);
      box-shadow: 0 2px 8px rgba(252, 173, 0, 0.2);
    }
  
    /* Pricing Table - Compact */
    .pricing-table {
      width: 100%;
    }
  
    .pricing-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.4rem 0;
      border-bottom: 1px dashed #e5e7eb;
      font-size: 0.75rem;
    }
  
    .pricing-row:last-child {
      border-bottom: none;
    }
  
    .pricing-day {
      font-size: 0.7rem;
      font-weight: 500;
      color: #1f2937;
    }
  
    .pricing-price {
      display: flex;
      gap: 0.75rem;
    }
  
    .price-item {
      text-align: right;
    }
  
    .price-item small {
      font-size: 0.55rem;
      color: #6b7280;
      display: block;
    }
  
    .price-item strong {
      font-size: 0.7rem;
      color: #1f2937;
    }
  
    /* Stat Cards - Compact */
    .stat-card {
      background: #f9fafb;
      border-radius: 0.4rem;
      padding: 0.5rem;
      text-align: center;
      border: 1px solid #e5e7eb;
      transition: all 0.15s ease;
    }
  
    .stat-card:hover {
      border-color: var(--primary-color);
      box-shadow: 0 2px 8px rgba(252, 173, 0, 0.1);
    }
  
    .stat-number {
      font-size: 1rem;
      font-weight: 600;
      color: var(--primary-color);
      line-height: 1.2;
    }
  
    .stat-label {
      font-size: 0.55rem;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.2px;
    }
  
    /* Buttons - Compact */
    .btn-sm {
      padding: 0.2rem 0.6rem;
      font-size: 0.65rem;
      border-radius: 0.35rem;
    }
  
    .btn-outline-primary {
      color: var(--primary-color);
      border-color: var(--primary-color);
    }
  
    .btn-outline-primary:hover {
      background-color: var(--primary-color);
      border-color: var(--primary-color);
      color: white;
    }
  
    .btn-outline-danger {
      color: #dc2626;
      border-color: #dc2626;
    }
  
    .btn-outline-danger:hover {
      background-color: #dc2626;
      border-color: #dc2626;
      color: white;
    }
  
    /* Modal - Compact */
    .modal-content {
      border-radius: 0.6rem;
      border: none;
    }
  
    .modal-sm {
      max-width: 280px;
    }
  
    .modal-body {
      padding: 1rem;
    }
  
    .modal-circle-icon {
      width: 40px;
      height: 40px;
      background: var(--primary-light);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 0.75rem;
    }
  
    .modal-circle-icon i {
      color: var(--primary-color);
      font-size: 1rem;
    }
  
    .modal-circle-icon.danger {
      background: #fee2e2;
    }
  
    .modal-circle-icon.danger i {
      color: #dc2626;
    }
  
    /* Image Modal */
    .image-modal .modal-content {
      background: transparent;
    }
  
    .image-modal .modal-body {
      padding: 0;
      position: relative;
    }
  
    .image-modal img {
      width: 100%;
      border-radius: 0.6rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }
  
    .image-modal .btn-close {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
      padding: 0.4rem;
      opacity: 1;
      font-size: 0.7rem;
    }
  
    .image-modal .btn-close:hover {
      background: rgba(255,255,255,0.3);
    }
  
    /* Empty State - Compact */
    .empty-state {
      text-align: center;
      padding: 1.5rem;
      background: #f9fafb;
      border-radius: 0.6rem;
      border: 2px dashed #e5e7eb;
    }
  
    .empty-state i {
      font-size: 2rem;
      color: #9ca3af;
      margin-bottom: 0.5rem;
    }
  
    .empty-state p {
      color: #6b7280;
      margin-bottom: 0;
      font-size: 0.75rem;
    }
  
    /* Utilities */
    .text-primary {
      color: var(--primary-color) !important;
    }
  
    .bg-primary {
      background-color: var(--primary-color) !important;
    }
  
    .bg-opacity-10 {
      --bs-bg-opacity: 0.1;
    }
  
    a {
      color: var(--primary-color);
      text-decoration: none;
    }
  
    a:hover {
      color: var(--primary-dark);
    }
  
    .bi {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      vertical-align: middle;
    }
  
    .row.g-3 {
      --bs-gutter-y: 0.75rem;
    }
  
    /* Responsive */
    @media (max-width: 768px) {
      .action-bar-wrapper {
        width: 100%;
        justify-content: center;
      }
      
      .header-meta {
        gap: 0.4rem;
      }
      
      .detail-card-body {
        padding: 0.6rem;
      }
    }
  </style>

<%- contentFor('body') %>
<div class="container-fluid px-3 py-3">
  <!-- Sticky Action Bar -->
  <div class="action-bar-wrapper">
    <div class="action-bar">
      <a href="/admin/escape/rooms" class="action-btn">
        <i class="bi bi-arrow-left"></i>
        Back
      </a>
      <span class="separator"></span>
      <a href="/admin/escape/rooms/edit/<%= room.id %>" class="action-btn primary">
        <i class="bi bi-pencil"></i>
        Edit
      </a>
      <button class="action-btn danger" onclick="deleteRoom(<%= room.id %>, '<%= room.title.replace(/'/g, "\\'") %>')">
        <i class="bi bi-trash"></i>
        Delete
      </button>
    </div>
  </div>

  <!-- Header with Status -->
  <div class="detail-header">
    <div class="d-flex align-items-center gap-2">
      <div class="header-icon">
        <i class="bi bi-controller"></i>
      </div>
      <div class="header-content">
        <h5 class="header-title"><%= room.title %></h5>
        <div class="header-meta">
          <span class="status-banner <%= room.isActive ? 'active' : 'inactive' %>">
            <i class="bi bi-circle-fill" style="font-size: 0.35rem;"></i>
            <%= room.isActive ? 'Active' : 'Inactive' %>
          </span>
          <span class="text-muted small">
            <i class="bi bi-calendar3 me-1"></i>
            <%= new Date(room.createdAt).toLocaleDateString('en-US', { 
              month: 'short', 
              day: 'numeric' 
            }) %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <!-- Left Column -->
    <div class="col-lg-8">
      <!-- Basic Info Card - Height Reduced -->
      <div class="detail-card">
        <div class="detail-card-header">
          <i class="bi bi-info-circle"></i>
          <h6>Basic Info</h6>
        </div>
        <div class="detail-card-body">
          <div class="info-grid">
            <div class="info-item">
              <div class="info-label">Slug</div>
              <div class="info-value text-truncate" title="<%= room.slug %>"><%= room.slug %></div>
            </div>
            <div class="info-item">
              <div class="info-label">Locations</div>
              <div class="badge-container">
                <% if (room.locations && room.locations.length > 0) { %>
                  <% room.locations.slice(0, 2).forEach(loc => { %>
                    <span class="custom-badge location" title="<%= loc.title %>">
                      <i class="bi bi-geo-alt-fill"></i><%= loc.title.length > 10 ? loc.title.substring(0, 8) + '..' : loc.title %>
                    </span>
                  <% }) %>
                  <% if (room.locations.length > 2) { %>
                    <span class="custom-badge">+<%= room.locations.length - 2 %></span>
                  <% } %>
                <% } else { %>
                  <span class="text-muted small">None</span>
                <% } %>
              </div>
            </div>
            <div class="info-item">
              <div class="info-label">Tags</div>
              <div class="badge-container">
                <% if (room.tag && room.tag.length > 0) { %>
                  <% room.tag.slice(0, 2).forEach(tag => { %>
                    <span class="custom-badge tag"><%= tag %></span>
                  <% }) %>
                  <% if (room.tag.length > 2) { %>
                    <span class="custom-badge">+<%= room.tag.length - 2 %></span>
                  <% } %>
                <% } else { %>
                  <span class="text-muted small">None</span>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Banner Section - Height Reduced -->
      <% if (room.banner_heading || room.banner_image || room.banner_description) { %>
      <div class="detail-card">
        <div class="detail-card-header">
          <i class="bi bi-image"></i>
          <h6>Banner</h6>
        </div>
        <div class="detail-card-body">
          <% if (room.banner_image) { %>
          <div class="banner-preview" onclick="viewImage('<%= room.banner_image %>')">
            <img src="<%= room.banner_image %>" alt="Banner" loading="lazy">
          </div>
          <% } %>

          <div class="info-grid">
            <% if (room.banner_heading) { %>
            <div class="info-item">
              <div class="info-label">Heading</div>
              <div class="info-value text-truncate" title="<%= room.banner_heading %>"><%= room.banner_heading %></div>
            </div>
            <% } %>

            <% if (room.banner_success_rate) { %>
            <div class="info-item">
              <div class="info-label">Success</div>
              <div class="info-value"><%= room.banner_success_rate %></div>
            </div>
            <% } %>

            <% if (room.banner_age_group) { %>
            <div class="info-item">
              <div class="info-label">Age</div>
              <div class="info-value"><%= room.banner_age_group %></div>
            </div>
            <% } %>

            <% if (room.banner_duration) { %>
            <div class="info-item">
              <div class="info-label">Duration</div>
              <div class="info-value"><%= room.banner_duration %></div>
            </div>
            <% } %>
          </div>

          <% if (room.banner_description) { %>
          <div class="info-item mt-2">
            <div class="info-label">Description</div>
            <div class="info-value small"><%= room.banner_description.length > 100 ? room.banner_description.substring(0, 100) + '...' : room.banner_description %></div>
          </div>
          <% } %>

          <% if (room.banner_cta_label || room.banner_cta_link) { %>
          <div class="mt-2">
            <a href="<%= room.banner_cta_link %>" target="_blank" class="btn btn-sm btn-outline-primary w-100">
              <i class="bi bi-box-arrow-up-right me-1"></i><%= room.banner_cta_label || 'Book Now' %>
            </a>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Gallery - Height Reduced -->
      <% if (room.images && room.images.length > 0) { %>
      <div class="detail-card">
        <div class="detail-card-header">
          <i class="bi bi-images"></i>
          <h6>Gallery (<%= room.images.length %>)</h6>
        </div>
        <div class="detail-card-body">
          <div class="gallery-grid">
            <% room.images.sort((a, b) => a.sort_order - b.sort_order).slice(0, 8).forEach(img => { %>
            <img src="<%= img.image_url %>" alt="Gallery" onclick="viewImage('<%= img.image_url %>')" loading="lazy">
            <% }) %>
            <% if (room.images.length > 8) { %>
            <div class="gallery-item-more" onclick="viewAllImages()">
              <span>+<%= room.images.length - 8 %></span>
            </div>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Right Column -->
    <div class="col-lg-4">
      <!-- Pricing Cards - Height Reduced -->
      <% if (room.pricingCards && room.pricingCards.length > 0) { %>
      <div class="detail-card">
        <div class="detail-card-header" style="display: block;">
            <div class="d-flex">
                <i class="bi bi-tag"></i>
                <h6>Pricing</h6>
            </div>
            <div class="mt-3">
                <p><%- room.pricing_heading %></p>
              </div>
        </div>
        
        <div class="detail-card-body">
          <div class="pricing-table">
            <% room.pricingCards.sort((a, b) => a.sort_order - b.sort_order).slice(0, 3).forEach((card, index) => { %>
            <div class="pricing-row">
              <span class="pricing-day"><%= card.day_range ? (card.day_range.length > 12 ? card.day_range : card.day_range) : 'All Days' %></span>
              <div class="pricing-price">
                <div class="price-item">
                    
                    <% if (index !==0) {%>

                    <small>2-3</small>
                        
                    <% } %>
                        
                  <strong><%= card.price_2_3_players || '—' %></strong>
                </div>
              </div>
              <div class="pricing-price">

                  <div class="price-item">
                    <% if (index !==0) {%>
                      <small>4-6</small>
                      <% } %>
                      <strong><%= card.price_4_6_players || '—' %></strong>
                    </div>
                </div>
            </div>
            <% }) %>
            <% if (room.pricingCards.length > 3) { %>
            <div class="text-center mt-1">
              <small class="text-muted">+<%= room.pricingCards.length - 3 %> more</small>
            </div>
            <% } %>
          </div>

          <% if (room.pricing_note) { %>
          <div class="mt-2 p-2 bg-info bg-opacity-10 rounded-2">
            <div class="info-label text-info mb-1">
              <i class="bi bi-info-circle me-1"></i>Note
            </div>
            <div class="info-value small"><%= room.pricing_note.length > 60 ? room.pricing_note.substring(0, 60) + '...' : room.pricing_note %></div>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Quick Stats - Height Reduced -->
      <div class="detail-card">
        <div class="detail-card-header">
          <i class="bi bi-bar-chart"></i>
          <h6>Stats</h6>
        </div>
        <div class="detail-card-body">
          <div class="row g-2">
            <div class="col-6">
              <div class="stat-card">
                <div class="stat-number"><%= room.images?.length || 0 %></div>
                <div class="stat-label">Images</div>
              </div>
            </div>
            <div class="col-6">
              <div class="stat-card">
                <div class="stat-number"><%= room.pricingCards?.length || 0 %></div>
                <div class="stat-label">Pricing</div>
              </div>
            </div>
            <div class="col-6">
              <div class="stat-card">
                <div class="stat-number"><%= room.locations?.length || 0 %></div>
                <div class="stat-label">Locations</div>
              </div>
            </div>
            <div class="col-6">
              <div class="stat-card">
                <div class="stat-number"><%= room.tag?.length || 0 %></div>
                <div class="stat-label">Tags</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Image View Modal -->
<div class="modal fade image-modal" id="imageViewModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content bg-transparent border-0">
      <div class="modal-body">
        <img src="" alt="View" id="viewImage" class="img-fluid rounded-3">
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-body text-center p-3">
        <div class="modal-circle-icon danger mb-2">
          <i class="bi bi-trash"></i>
        </div>
        <h6 class="mb-2" style="font-size: 0.9rem;">Delete Room</h6>
        <p class="small text-muted mb-3" id="deleteRoomName" style="font-size: 0.7rem;"></p>
        <div class="d-flex gap-2 justify-content-center">
          <button type="button" class="btn btn-light btn-sm px-3" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger btn-sm px-3" id="confirmDelete">Delete</button>
        </div>
      </div>
    </div>
  </div>
</div>

<%- contentFor('js') %>
<script>
  let deleteId = null;
  const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
  const imageViewModal = new bootstrap.Modal(document.getElementById('imageViewModal'));

  window.viewImage = function(imageUrl) {
    document.getElementById('viewImage').src = imageUrl;
    imageViewModal.show();
  };

  window.deleteRoom = function(id, title) {
    deleteId = id;
    document.getElementById('deleteRoomName').textContent = `"${title}"`;
    deleteModal.show();
  };

  document.getElementById('confirmDelete').addEventListener('click', async function() {
    if (!deleteId) return;

    const btn = this;
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>';

    try {
      const response = await fetch(`/admin/escape/rooms/${deleteId}`, {
        method: 'DELETE',
        headers: {
          'Authorization': `Bearer ${localStorage.getItem('token')}`,
          'Content-Type': 'application/json'
        }
      });

      if (response.ok) {
        showNotification('Room deleted', 'success');
        setTimeout(() => {
          window.location.href = '/admin/escape/rooms';
        }, 1000);
      } else {
        showNotification('Failed to delete', 'error');
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    } catch (error) {
      showNotification('Error occurred', 'error');
      btn.disabled = false;
      btn.innerHTML = originalText;
    } finally {
      deleteModal.hide();
      deleteId = null;
    }
  });

  function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed top-0 end-0 m-3 shadow-sm`;
    notification.style.zIndex = '9999';
    notification.style.animation = 'slideIn 0.2s ease';
    notification.style.minWidth = '200px';
    notification.style.fontSize = '0.7rem';
    notification.style.padding = '0.4rem 0.75rem';
    notification.style.borderRadius = '0.4rem';
    notification.innerHTML = `
      <div class="d-flex align-items-center">
        <i class="bi ${type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill'} me-2"></i>
        <span class="flex-grow-1">${message}</span>
      </div>
    `;
    document.body.appendChild(notification);
    setTimeout(() => notification.remove(), 2000);
  }

  const style = document.createElement('style');
  style.textContent = `
    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
  `;
  document.head.appendChild(style);
</script>