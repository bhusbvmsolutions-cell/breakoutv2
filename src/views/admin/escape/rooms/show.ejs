<%- contentFor('title') %><%= title ? title : '' %>

<%- contentFor('head') %>
<style>
    .gallery-item {
      display: inline-block;
      margin-right: 10px;
      margin-bottom: 10px;
    }
  
    .grab-handle {
      cursor: move;
    }
  
    .image-upload-wrapper {
      transition: all 0.2s ease;
    }
  
    .image-upload-wrapper:hover {
      border-color: #0d6efd;
    }
  </style>


<%- contentFor('body') %>
<div class="container-fluid px-0">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-1"><%= room.title %></h5>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 fs-6">
                    <li class="breadcrumb-item"><a href="<%= basePath %>/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="<%= basePath %>/admin/escape/rooms">Escape Rooms</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a href="<%= basePath %>/admin/escape/rooms/edit/<%= room.id %>" class="btn btn-primary btn-sm">
                <i class="fas fa-edit me-1"></i> Edit
            </a>
            <button type="button" class="btn btn-danger btn-sm" onclick="deleteRoom(<%= room.id %>)">
                <i class="fas fa-trash me-1"></i> Delete
            </button>
        </div>
    </div>

    <!-- Status Banner -->
    <div class="alert <%= room.isActive ? 'alert-success' : 'alert-secondary' %> py-2 mb-4 d-flex align-items-center">
        <i class="fas <%= room.isActive ? 'fa-check-circle' : 'fa-clock' %> me-2"></i>
        <span>This room is currently <strong><%= room.isActive ? 'Active' : 'Inactive' %></strong></span>
    </div>

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-8">
            <!-- Basic Info Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0">Basic Information</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Title</small>
                                <strong><%= room.title %></strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Slug</small>
                                <strong><%= room.slug %></strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Created</small>
                                <strong><%= new Date(room.createdAt).toLocaleDateString() %></strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Locations</small>
                                <div>
                                    <% if (room.locations && room.locations.length > 0) { %>
                                        <% room.locations.forEach(loc => { %>
                                            <span class="badge bg-primary me-1"><%= loc.title %></span>
                                        <% }) %>
                                    <% } else { %>
                                        <span class="text-muted">No locations assigned</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Tags</small>
                                <div>
                                    <% if (room.tag && room.tag.length > 0) { %>
                                        <% room.tag.forEach(tag => { %>
                                            <span class="badge bg-secondary me-1"><%= tag %></span>
                                        <% }) %>
                                    <% } else { %>
                                        <span class="text-muted">No tags</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Banner Section -->
            <% if (room.banner_heading || room.banner_image || room.banner_description) { %>
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0">Banner Section</h6>
                </div>
                <div class="card-body">
                    <% if (room.banner_image) { %>
                        <img src="<%= room.banner_image %>" class="img-fluid rounded mb-3" style="max-height: 200px; width: auto;">
                    <% } %>
                    
                    <div class="row g-3">
                        <% if (room.banner_heading) { %>
                        <div class="col-md-12">
                            <small class="text-muted d-block">Heading</small>
                            <p class="mb-2"><%= room.banner_heading %></p>
                        </div>
                        <% } %>
                        
                        <% if (room.banner_description) { %>
                        <div class="col-md-12">
                            <small class="text-muted d-block">Description</small>
                            <p class="mb-2"><%= room.banner_description %></p>
                        </div>
                        <% } %>

                        <div class="row g-2">
                            <% if (room.banner_success_rate) { %>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Success Rate</small>
                                <span class="badge bg-info"><%= room.banner_success_rate %></span>
                            </div>
                            <% } %>
                            
                            <% if (room.banner_age_group) { %>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Age Group</small>
                                <span class="badge bg-info"><%= room.banner_age_group %></span>
                            </div>
                            <% } %>
                            
                            <% if (room.banner_character) { %>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Character</small>
                                <span class="badge bg-info"><%= room.banner_character %></span>
                            </div>
                            <% } %>
                            
                            <% if (room.banner_min_team) { %>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Min Team</small>
                                <span class="badge bg-info"><%= room.banner_min_team %></span>
                            </div>
                            <% } %>
                            
                            <% if (room.banner_scare_factor) { %>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Scare Factor</small>
                                <span class="badge bg-info"><%= room.banner_scare_factor %></span>
                            </div>
                            <% } %>
                            
                            <% if (room.banner_duration) { %>
                            <div class="col-md-3">
                                <small class="text-muted d-block">Duration</small>
                                <span class="badge bg-info"><%= room.banner_duration %></span>
                            </div>
                            <% } %>
                        </div>

                        <% if (room.banner_cta_label || room.banner_cta_link) { %>
                        <div class="col-md-12">
                            <small class="text-muted d-block">CTA</small>
                            <a href="<%= room.banner_cta_link %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                <%= room.banner_cta_label || 'Book Now' %>
                            </a>
                        </div>
                        <% } %>

                        <% if (room.banner_important_note) { %>
                        <div class="col-md-12">
                            <small class="text-muted d-block">Important Note</small>
                            <div class="alert alert-warning py-2 mb-0">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <%= room.banner_important_note %>
                            </div>
                        </div>
                        <% } %>

                        <% if (room.banner_video_trailer) { %>
                        <div class="col-md-12">
                            <small class="text-muted d-block">Video Trailer</small>
                            <a href="<%= room.banner_video_trailer %>" target="_blank" class="btn btn-sm btn-outline-danger">
                                <i class="fab fa-youtube me-1"></i> Watch Trailer
                            </a>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <% } %>

            <!-- Gallery -->
            <% if (room.images && room.images.length > 0) { %>
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0">Gallery (<%= room.images.length %> images)</h6>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <% room.images.sort((a, b) => a.sort_order - b.sort_order).forEach(img => { %>
                            <div class="col-md-3 col-6">
                                <img src="<%= img.image_url %>" class="img-fluid rounded" style="height: 100px; width: 100%; object-fit: cover;">
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
            <% } %>
        </div>

        <!-- Right Column -->
        <div class="col-lg-4">
            <!-- Pricing Cards -->
            <% if (room.pricingCards && room.pricingCards.length > 0) { %>
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0">Pricing</h6>
                </div>
                <div class="card-body">
                    <% room.pricingCards.sort((a, b) => a.sort_order - b.sort_order).forEach(card => { %>
                        <div class="border-bottom pb-2 mb-2">
                            <small class="text-muted"><%= card.day_range || 'All Days' %></small>
                            <div class="d-flex justify-content-between mt-1">
                                <span>2-3 Players</span>
                                <strong><%= card.price_2_3_players || 'N/A' %></strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>4-6 Players</span>
                                <strong><%= card.price_4_6_players || 'N/A' %></strong>
                            </div>
                        </div>
                    <% }) %>
                    
                    <% if (room.pricing_note) { %>
                        <div class="mt-3 small text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            <%= room.pricing_note %>
                        </div>
                    <% } %>
                </div>
            </div>
            <% } %>

            <!-- Quick Stats -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0">Quick Stats</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Images</span>
                        <strong><%= room.images?.length || 0 %></strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Pricing Cards</span>
                        <strong><%= room.pricingCards?.length || 0 %></strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Locations</span>
                        <strong><%= room.locations?.length || 0 %></strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Tags</span>
                        <strong><%= room.tag?.length || 0 %></strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<%- contentFor('js') %>
<script>
function deleteRoom(id) {
    if (confirm('Are you sure you want to delete this escape room?')) {
        fetch(`<%= basePath %>/admin/escape/rooms/${id}`, {
            method: 'DELETE',
            headers: {
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            }
        })
        .then(response => {
            if (response.ok) {
                window.location.href = '<%= basePath %>/admin/escape/rooms';
            } else {
                alert('Failed to delete room');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred');
        });
    }
}
</script>