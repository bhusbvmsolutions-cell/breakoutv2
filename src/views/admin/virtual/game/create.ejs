<%- contentFor('title') %> Add Virtual Game
<%- contentFor('head') %>
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
<style>
  /* Modern form styling */
  .form-section {
    background: #fff;
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
  }
  .section-title {
    font-size: 1.35rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #fcad00;
    display: inline-block;
  }
  .form-label {
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: #2c3e50;
  }
  .form-label i {
    margin-right: 0.5rem;
    color: #fcad00;
  }
  .form-control, .form-select {
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 0.75rem 1rem;
    transition: all 0.2s;
  }
  .form-control:focus, .form-select:focus {
    border-color: #fcad00;
    box-shadow: 0 0 0 0.2rem rgba(252,173,0,0.25);
  }
  .image-preview-container {
    position: relative;
    display: inline-block;
    margin-top: 0.5rem;
  }
  .image-preview {
    max-width: 120px;
    max-height: 90px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    padding: 4px;
    background: #fff;
    display: none;
  }
  .remove-image {
    position: absolute;
    top: -8px;
    right: -8px;
    background: #dc3545;
    color: white;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    cursor: pointer;
    display: none;
  }
  .btn-submit {
    background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%);
    border: none;
    border-radius: 50px;
    padding: 0.75rem 2rem;
    font-weight: 600;
    transition: transform 0.2s;
  }
  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(252,173,0,0.3);
  }
  .btn-cancel {
    background: #6c757d;
    border: none;
    border-radius: 50px;
    padding: 0.75rem 2rem;
    margin-left: 1rem;
  }
  .slug-hint {
    font-size: 0.8rem;
    color: #6c757d;
    margin-top: 0.25rem;
  }
  .slug-hint i {
    margin-right: 0.25rem;
  }
  .form-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .form-row .form-group {
    flex: 1;
    min-width: 200px;
  }
  @media (max-width: 768px) {
    .form-section {
      padding: 1rem;
    }
    .form-row .form-group {
      min-width: 100%;
    }
  }
</style>

<%- contentFor('body') %>
<div class="">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <div class="bg-light p-4 border-bottom">
            <h4 class="card-title mb-0">
              <i class="bx bx-game me-2"></i> Add Virtual Game
            </h4>
            <p class="text-muted mt-2 mb-0">Create a new virtual escape room game experience</p>
          </div>
          <form id="virtualGameForm" action="/admin/virtual/game/store" method="POST" enctype="multipart/form-data" class="p-4">
            <div class="form-section">
              <h5 class="section-title">
                <i class="bx bx-image-alt me-2"></i> Banner Section
              </h5>
              <div class="row g-4">
                <div class="col-md-6">
                  <label class="form-label"><i class="bx bx-text"></i> Title *</label>
                  <input type="text" name="title" id="title" class="form-control" placeholder="e.g., The Lost Temple" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label"><i class="bx bx-link"></i> Slug</label>
                  <input type="text" name="slug" id="slug" class="form-control" placeholder="auto-generated">
                  <div class="slug-hint"><i class="bx bx-info-circle"></i> Leave blank to auto-generate from title</div>
                </div>
                <div class="col-12">
                  <label class="form-label"><i class="bx bx-heading"></i> Heading</label>
                  <input type="text" name="banner_heading" class="form-control" placeholder="Main heading for the banner">
                </div>
                <div class="col-12">
                  <label class="form-label"><i class="bx bx-image"></i> Banner Image</label>
                  <input type="file" name="banner_image" id="bannerImage" class="form-control" accept="image/*">
                  <div class="image-preview-container mt-2">
                    <img id="imagePreview" class="image-preview">
                    <span id="removeImage" class="remove-image">×</span>
                  </div>
                </div>
                <div class="col-12">
                  <label class="form-label"><i class="bx bx-message-alt-detail"></i> Description</label>
                  <textarea name="banner_description" class="form-control" rows="3" placeholder="Short description of the game"></textarea>
                </div>
                <div class="col-12">
                  <label class="form-label"><i class="bx bx-file"></i> Content</label>
                  <textarea name="banner_content" class="form-control summernote" rows="5" placeholder="Full content with formatting"></textarea>
                </div>
                <div class="col-md-4">
                  <label class="form-label"><i class="bx bx-trending-up"></i> Success Rate (%)</label>
                  <input type="text" name="success_rate" class="form-control" placeholder="e.g., 60">
                </div>
                <div class="col-md-4">
                  <label class="form-label"><i class="bx bx-group"></i> Capacity</label>
                  <input type="text" name="capacity" class="form-control" placeholder="e.g., 4 - 10">
                </div>
                <div class="col-md-6">
                  <label class="form-label"><i class="bx bx-message-square"></i> CTA Label</label>
                  <input type="text" name="cta_label" class="form-control" placeholder="e.g., Book Now">
                </div>
                <div class="col-md-6">
                  <label class="form-label"><i class="bx bx-link-external"></i> CTA Link</label>
                  <input type="text" name="cta_link" class="form-control" placeholder="e.g., /book">
                </div>
                <div class="col-12">
                  <label class="form-label"><i class="bx bx-video-recording"></i> Video Trailer Link</label>
                  <input type="text" name="video_trailer" class="form-control" placeholder="YouTube or Vimeo URL">
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="isActive" id="isActive" value="on" checked>
                    <label class="form-check-label" for="isActive">
                      <i class="bx bx-check-circle"></i> Active
                    </label>
                  </div>
                </div>
              </div>
            </div>
            <div class="d-flex justify-content-end mt-4">
              <a href="/admin/virtual/game" class="btn btn-cancel me-2">
                <i class="bx bx-x-circle me-1"></i> Cancel
              </a>
              <button type="submit" class="btn btn-submit">
                <i class="bx bx-save me-1"></i> Save Game
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- contentFor('js') %>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>
<script>
  $(document).ready(function() {
    // Summernote initialization
    $('.summernote').summernote({
        placeholder: 'Write your content here...',
        tabsize: 2,
        height: 300,
        fontNames: [
          'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New',
          'Georgia', 'Tahoma', 'Times New Roman', 'Verdana',

          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontNamesIgnoreCheck: [
          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontSizes: ['8', '10', '12', '14', '16', '18', '20', '24', '28', '32', '36', '48', '64'],
        toolbar: [
          ['style', ['style']],
          ['font', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
          ['fontname', ['fontname']],
          ['fontsize', ['fontsize']],
          ['color', ['forecolor', 'backcolor']],
          ['para', ['ul', 'ol', 'paragraph', 'height']],
          ['insert', ['link', 'picture', 'video', 'table']],
          ['view', ['fullscreen', 'codeview']]
        ],
        lineHeights: ['0.8', '1.0', '1.2', '1.5', '2.0', '3.0'],
        callbacks: {
          onChange: function(contents) {
            // Update the hidden textarea when content changes
            const textarea = $(this).closest('.text-editor').find('.text-content');
            textarea.val(contents);
          }
        }
      });

    // Slug auto-generation
    $('#title').on('blur', function() {
      if ($('#slug').val() === '') {
        let slug = $(this).val().toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/[\s_-]+/g, '-')
          .replace(/^-+|-+$/g, '');
        $('#slug').val(slug);
      }
    });

    // Image preview and remove
    const $imageInput = $('#bannerImage');
    const $imagePreview = $('#imagePreview');
    const $removeImage = $('#removeImage');

    $imageInput.on('change', function() {
      const file = this.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          $imagePreview.attr('src', e.target.result).show();
          $removeImage.show();
        };
        reader.readAsDataURL(file);
      } else {
        $imagePreview.hide().attr('src', '');
        $removeImage.hide();
      }
    });

    $removeImage.on('click', function() {
      $imageInput.val('');
      $imagePreview.hide().attr('src', '');
      $removeImage.hide();
    });

    // Optional: Character count for description (if needed)
    $('#banner_description').on('input', function() {
      const maxLength = 500;
      const currentLength = $(this).val().length;
      if (currentLength > maxLength) {
        $(this).val($(this).val().substring(0, maxLength));
      }
      // You could show a counter, but optional
    });
  });
</script>