<%- contentFor('title') %> Virtual Game List
<%- contentFor('head') %>
<style>
  /* Stats cards */
  .stats-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 15px;
    padding: 1.5rem;
    color: white;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .stats-card:hover {
    transform: translateY(-5px);
  }

  .stats-card h3 {
    font-size: 2rem;
    margin-bottom: 0;
  }

  .stats-card p {
    margin-bottom: 0;
    opacity: 0.9;
  }

  /* Search bar */
  .search-box {
    position: relative;
    max-width: 400px;
  }

  .search-box input {
    padding-left: 2.5rem;
    border-radius: 30px;
    border: 1px solid #dee2e6;
    transition: all 0.2s;
  }

  .search-box input:focus {
    border-color: #fcad00;
    box-shadow: 0 0 0 0.2rem rgba(252, 173, 0, 0.25);
  }

  .search-box i {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #adb5bd;
  }

  /* Game cards grid */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .game-card {
    background: #fff;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    position: relative;
  }

  .game-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.12);
  }

  .game-card-image {
    height: 180px;
    background: #f8f9fa;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .game-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .game-card:hover .game-card-image img {
    transform: scale(1.05);
  }

  .game-card-content {
    padding: 1.25rem;
  }

  .game-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #2c3e50;
  }

  .game-card-slug {
    font-size: 0.85rem;
    color: #6c757d;
    margin-bottom: 0.75rem;
    word-break: break-all;
  }

  .game-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .game-card-status {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .game-card-date {
    font-size: 0.75rem;
    color: #6c757d;
  }

  .game-card-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .game-card-actions .btn {
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
  }

  .no-games {
    text-align: center;
    padding: 3rem;
    background: #f8f9fa;
    border-radius: 15px;
    color: #6c757d;
  }

  @media (max-width: 768px) {
    .games-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-md-8">
      <h2 class="display-6 fw-bold">Virtual Games</h2>
      <p class="text-muted">Manage all your virtual escape room games</p>
    </div>
    <div class="col-md-4 text-md-end">
      <a href="/admin/virtual/game/create" class="btn btn-primary btn-sm">
        <i class="bx bx-plus-circle me-1"></i> Add New Game
      </a>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="row mb-4">
    <div class="col-md-4 mb-3">
      <div class="stats-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
        <h3 id="totalGames">0</h3>
        <p>Total Games</p>
      </div>
    </div>
    <div class="col-md-4 mb-3">
      <div class="stats-card" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
        <h3 id="activeGames">0</h3>
        <p>Active Games</p>
      </div>
    </div>
    <div class="col-md-4 mb-3">
      <div class="stats-card" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
        <h3 id="inactiveGames">0</h3>
        <p>Inactive Games</p>
      </div>
    </div>
  </div>

  <!-- Search and Filter Row -->
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="search-box">
        <i class="bx bx-search"></i>
        <input type="text" id="searchGames" class="form-control" placeholder="Search by title or slug...">
      </div>
    </div>
    <div class="col-md-6 text-md-end">
      <div class="btn-group" role="group">
        <button type="button" class="btn btn-outline-secondary filter-status active" data-status="all">All</button>
        <button type="button" class="btn btn-outline-secondary filter-status" data-status="active">Active</button>
        <button type="button" class="btn btn-outline-secondary filter-status" data-status="inactive">Inactive</button>
      </div>
    </div>
  </div>

  <!-- Games Grid -->
  <div id="gamesContainer" class="games-grid">
    <% if (games && games.length) { %>
    <% games.forEach(game => { %>
    <div class="game-card" data-title="<%= game.title.toLowerCase() %>" data-slug="<%= game.slug.toLowerCase() %>" data-status="<%= game.isActive ? 'active' : 'inactive' %>">
      <div class="game-card-image">
        <% if (game.banner_image) { %>
        <img src="<%= game.banner_image %>" alt="<%= game.title %>">
        <% } else { %>
        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
          <i class="bx bx-image-alt fs-1"></i>
          <span class="mt-2">No image</span>
        </div>
        <% } %>
      </div>
      <div class="game-card-content">
        <h5 class="game-card-title"><%= game.title %></h5>
        <div class="game-card-slug"><i class="bx bx-link-alt me-1"></i> <%= game.slug %></div>
        <div class="game-card-meta">
          <span class="game-card-status badge <%= game.isActive ? 'bg-success' : 'bg-secondary' %>">
            <%= game.isActive ? 'Active' : 'Inactive' %>
          </span>
          <span class="game-card-date"><i class="bx bx-calendar me-1"></i> <%= new Date(game.createdAt).toLocaleDateString() %></span>
        </div>
        <div class="game-card-actions">
          <a href="/admin/googlereviews/slug/vg:<%= game.slug %>" class="bg-secondary py-1 px-2 text-white rounded" title="View Google Reviews" style="font-size: 14px;">
            <i class="bi bi-google"></i>
          </a>
          <a href="/admin/faqs/slug/vg:<%= game.slug %>" class="bg-primary py-1 px-2 text-white rounded" title="View FAQs" style="font-size: 14px;">
            <i class="bi bi-patch-question"></i>
          </a>

          <a href="/admin/virtual/game/view/<%= game.id %>" class="btn btn-sm btn-info">
            <i class="bx bx-show"></i>
          </a>
          <a href="/admin/virtual/game/edit/<%= game.id %>" class="btn btn-sm btn-warning">
            <i class="bx bx-edit"></i>
          </a>
          <button class="btn btn-sm btn-danger delete-game" data-id="<%= game.id %>">
            <i class="bx bx-trash"></i>
          </button>
        </div>
      </div>
    </div>
    <% }); %>
    <% } else { %>
    <div class="no-games">
      <i class="bx bx-ghost fs-1"></i>
      <h5 class="mt-3">No games found</h5>
      <p>Get started by adding your first virtual game.</p>
      <a href="/admin/virtual/game/create" class="btn btn-primary mt-2">Add New Game</a>
    </div>
    <% } %>
  </div>
</div>

<%- contentFor('js') %>
<script>
  // Filtering and search
  const gamesContainer = document.getElementById('gamesContainer');
  const searchInput = document.getElementById('searchGames');
  let currentStatus = 'all';

  // Update stats counts
  function updateStats() {
    const games = document.querySelectorAll('.game-card');
    const total = games.length;
    const active = Array.from(games).filter(card => card.dataset.status === 'active').length;
    const inactive = total - active;
    document.getElementById('totalGames').innerText = total;
    document.getElementById('activeGames').innerText = active;
    document.getElementById('inactiveGames').innerText = inactive;
  }

  function filterGames() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    const games = document.querySelectorAll('.game-card');
    let visibleCount = 0;
    games.forEach(card => {
      const title = card.dataset.title;
      const slug = card.dataset.slug;
      const status = card.dataset.status;
      const matchesSearch = searchTerm === '' || title.includes(searchTerm) || slug.includes(searchTerm);
      const matchesStatus = currentStatus === 'all' || status === currentStatus;
      if (matchesSearch && matchesStatus) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });
    // Show "No results" message if needed
    let noResults = document.querySelector('.no-results-message');
    if (visibleCount === 0 && games.length > 0) {
      if (!noResults) {
        noResults = document.createElement('div');
        noResults.className = 'no-games no-results-message';
        noResults.innerHTML = '<i class="bx bx-search-alt fs-1"></i><h5 class="mt-3">No matching games</h5><p>Try a different search term or clear the filter.</p>';
        gamesContainer.appendChild(noResults);
      }
    } else if (noResults) {
      noResults.remove();
    }
  }

  // Event listeners
  searchInput.addEventListener('input', filterGames);
  document.querySelectorAll('.filter-status').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-status').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentStatus = btn.dataset.status;
      filterGames();
    });
  });

  // Delete with confirmation and AJAX
  document.querySelectorAll('.delete-game').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      if (!confirm('Are you sure you want to delete this game? This action cannot be undone.')) return;
      const id = btn.dataset.id;
      try {
        const response = await fetch(`/admin/virtual/game/delete/${id}`, {
          method: 'DELETE'
        });
        const data = await response.json();
        if (data.success) {
          location.reload(); // Reload the page to reflect changes
          // Remove the card from DOM
          const card = btn.closest('.game-card');
          card.remove();
          updateStats();
          filterGames(); // re-run filter to update counts and "no results"
          // Show a brief success message (optional)
          const msgDiv = document.createElement('div');
          msgDiv.className = 'alert alert-success alert-dismissible fade show position-fixed bottom-0 end-0 m-3';
          msgDiv.innerHTML = `Game deleted successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
          document.body.appendChild(msgDiv);
          setTimeout(() => msgDiv.remove(), 3000);
        } else {
          alert(data.message || 'Failed to delete game');
        }
      } catch (err) {
        location.reload(); // Reload the page to ensure consistency
        console.error(err);
      }
    });
  });

  // Initialize stats after DOM is ready
  updateStats();
</script>