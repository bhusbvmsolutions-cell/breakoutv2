<%- contentFor('title') %> <%= type === 'bachelor' ? 'Bachelor Archive' : 'Farewell Archive' %>
<%- contentFor('head') %>
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<style>
  /* Same styles as Birthday Archive – copy from earlier */
  body { background: #f5f7fb; }
  .form-container { margin: 0 auto; }
  .card-custom { border-radius: 1rem; overflow: hidden; border: none; box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.08); }
  .card-header-custom { background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%); padding: 1.25rem 1.5rem; border-bottom: none; }
  .card-header-custom h4 { margin: 0; color: #2c3e50; font-weight: 600; }
  .card-header-custom p { margin: 0.25rem 0 0; color: #2c3e50; opacity: 0.9; }
  .form-section { background: #fff; border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1.5rem; box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.05); border: 1px solid #eef2f6; }
  .section-title { font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #fcad00; display: inline-block; }
  .form-label { font-weight: 500; margin-bottom: 0.25rem; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; }
  .form-control, .form-select { border-radius: 0.5rem; border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; font-size: 0.9rem; transition: all 0.2s; }
  .form-control:focus, .form-select:focus { border-color: #fcad00; box-shadow: 0 0 0 0.2rem rgba(252,173,0,0.25); }
  .image-preview { max-width: 80px; max-height: 60px; margin-top: 0.5rem; border-radius: 0.5rem; border: 1px solid #e2e8f0; padding: 2px; background: #fff; display: none; }
  .repeater-item { background: #f8f9fa; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 1rem; margin-bottom: 1rem; position: relative; }
  .remove-item { position: absolute; top: 0.5rem; right: 0.5rem; cursor: pointer; color: #dc3545; background: white; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; z-index: 10; }
  .btn-submit { background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%); border: none; border-radius: 2rem; padding: 0.6rem 2rem; font-weight: 600; transition: transform 0.2s, box-shadow 0.2s; }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 0.5rem 1rem rgba(252,173,0,0.3); }
  .select2-container--default .select2-selection--multiple { border-radius: 0.5rem !important; border: 1px solid #e2e8f0 !important; }
  .select2-container--default .select2-selection--multiple .select2-selection__choice { background-color: #fcad00 !important; border: none; color: #2c3e50 !important; }
  .btn-sm { padding: 0.25rem 0.5rem; font-size: 0.75rem; }
  @media (max-width: 768px) { .form-container { max-width: 100%; } .form-section { padding: 1rem; } }
</style>

<%- contentFor('body') %>
<div class="container py-4">
  <div class="form-container">
    <div class="card card-custom">
      <div class="card-header-custom">
        <h4> <%- type === 'bachelor' ? `<i class="bi bi-book me-2"></i>` : `<i class="bx bx-heart me-2"></i>` %> <%= type === 'bachelor' ? 'Bachelor Archive' : 'Farewell Archive' %></h4>
        <p>Manage the <%= type === 'bachelor' ? 'bachelor' : 'farewell' %> party page</p>
      </div>
      <div class="card-body p-4">
        <form id="archiveForm" action="/admin/party/<%= type %>/archive" method="POST" enctype="multipart/form-data">
          <!-- Banner Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-image-alt me-2"></i> Banner Section</h5>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Heading</label>
                <input type="text" name="banner_heading" class="form-control" value="<%= archive?.banner_heading || '' %>">
              </div>
              <div class="col-12">
                <label class="form-label">Description</label>
                <input type="text" name="banner_description" class="form-control" value="<%= archive?.banner_description || '' %>">
              </div>
              <div class="col-12">
                <label class="form-label">Banner Video</label>
                <select name="banner_video_id" class="form-control select2-single">
                  <option value="">-- Select a video --</option>
                  <% videos.forEach(video => { %>
                    <option value="<%= video.id %>" <%= archive?.banner_video_id == video.id ? 'selected' : '' %>>
                      <%= video.title || video.filename %>
                    </option>
                  <% }); %>
                </select>
                <small class="form-text text-muted">Select a video for the banner section</small>
              </div>
            </div>
          </div>

          <!-- Counters Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-stats me-2"></i> Counters Section</h5>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Heading</label>
                <input type="text" name="counters_heading" class="form-control" value="<%= archive?.counters_heading || '' %>">
              </div>
              <div class="col-12">
                <label class="form-label">Content</label>
                <textarea name="counters_content" class="form-control" rows="3"><%= archive?.counters_content || '' %></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">Note</label>
                <input type="text" name="counters_note" class="form-control" value="<%= archive?.counters_note || '' %>">
              </div>
              <div class="col-md-10">
                <label class="form-label">Counter Heading</label>
                <input type="text" name="counters_counter_heading" class="form-control" value="<%= archive?.counters_counter_heading || '' %>">
              </div>
              <div class="col-md-2">
                <label class="form-label">Rating (0-5)</label>
                <input type="number" step="0.1" name="counters_rating" class="form-control" value="<%= archive?.counters_rating || '' %>" min="0" max="5">
              </div>
            </div>
            <label class="form-label fw-bold mt-3">Counter Cards (3 items)</label>
            <div class="row">
              <% for (let i = 0; i < 3; i++) {
                const card = archive?.counterCards?.[i];
              %>
              <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm h-100">
                  <div class="card-body">
                    <label class="form-label">Image</label>
                    <input type="file" name="counter_cards[<%= i %>][image]" class="form-control" accept="image/*">
                    <% if (card?.image) { %>
                      <img src="<%= card.image %>" class="image-preview mt-2" style="display:block">
                    <% } else { %>
                      <img class="image-preview mt-2">
                    <% } %>
                    <input type="hidden" name="counter_cards[<%= i %>][image]" value="<%= card?.image || '' %>">
                    <hr class="my-2">
                    <label class="form-label">Count</label>
                    <input type="text" name="counter_cards[<%= i %>][count]" class="form-control" value="<%= card?.count || '' %>">
                    <label class="form-label mt-2">Description</label>
                    <input type="text" name="counter_cards[<%= i %>][description]" class="form-control" value="<%= card?.description || '' %>">
                  </div>
                </div>
              </div>
              <% } %>
            </div>
          </div>

          <!-- Image Card Section (Repeater) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-images me-2"></i> Image Card Section</h5>
            <div class="row g-3 mb-3">
              <div class="col-12">
                <label class="form-label">Heading</label>
                <input type="text" name="image_card_heading" class="form-control" value="<%= archive?.image_card_heading || '' %>">
              </div>
            </div>
            <div id="imageCardsContainer">
              <% if (archive?.imageCards && archive.imageCards.length) {
                archive.imageCards.forEach((item, idx) => { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Heading</label>
                    <input type="text" name="image_cards[<%= idx %>][heading]" class="form-control" value="<%= item.heading %>">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Image</label>
                    <input type="file" name="image_cards[<%= idx %>][image]" class="form-control" accept="image/*">
                    <% if (item.image) { %>
                      <img src="<%= item.image %>" class="image-preview mt-2" style="display:block">
                    <% } else { %>
                      <img class="image-preview mt-2">
                    <% } %>
                    <input type="hidden" name="image_cards[<%= idx %>][image]" value="<%= item.image || '' %>">
                  </div>
                </div>
              </div>
              <% });
              } else { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Heading</label>
                    <input type="text" name="image_cards[0][heading]" class="form-control">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Image</label>
                    <input type="file" name="image_cards[0][image]" class="form-control" accept="image/*">
                    <img class="image-preview mt-2">
                    <input type="hidden" name="image_cards[0][image]" value="">
                  </div>
                </div>
              </div>
              <% } %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-image-card"><i class="bx bx-plus"></i> Add Image Card</button>
          </div>

          <!-- Party Inclusions Section (Repeater) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-gift me-2"></i> Party Inclusions</h5>
            <div class="row g-3 mb-3">
              <div class="col-12">
                <label class="form-label">Heading</label>
                <input type="text" name="party_inclusions_heading" class="form-control" value="<%= archive?.party_inclusions_heading || '' %>">
              </div>
            </div>
            <div id="inclusionsContainer">
              <% if (archive?.inclusionItems && archive.inclusionItems.length) {
                archive.inclusionItems.forEach((item, idx) => { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Heading</label>
                    <input type="text" name="inclusion_items[<%= idx %>][heading]" class="form-control" value="<%= item.heading %>">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Link</label>
                    <input type="text" name="inclusion_items[<%= idx %>][link]" class="form-control" value="<%= item.link || '' %>" placeholder="https://example.com">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Image</label>
                    <input type="file" name="inclusion_items[<%= idx %>][image]" class="form-control" accept="image/*">
                    <% if (item.image) { %>
                      <img src="<%= item.image %>" class="image-preview mt-2" style="display:block">
                    <% } else { %>
                      <img class="image-preview mt-2">
                    <% } %>
                    <input type="hidden" name="inclusion_items[<%= idx %>][image]" value="<%= item.image || '' %>">
                  </div>
                </div>
              </div>
              <% });
              } else { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Heading</label>
                    <input type="text" name="inclusion_items[0][heading]" class="form-control">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Link</label>
                    <input type="text" name="inclusion_items[0][link]" class="form-control" placeholder="https://example.com">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Image</label>
                    <input type="file" name="inclusion_items[0][image]" class="form-control" accept="image/*">
                    <img class="image-preview mt-2">
                    <input type="hidden" name="inclusion_items[0][image]" value="">
                  </div>
                </div>
              </div>
              <% } %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-inclusion"><i class="bx bx-plus"></i> Add Inclusion</button>
            <div class="row mt-3">
              <div class="col-12">
                <label class="form-label">Note</label>
                <input type="text" name="party_inclusions_note" class="form-control" value="<%= archive?.party_inclusions_note || '' %>">
              </div>
            </div>
          </div>

          <!-- Slider Section (Repeater) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-slider me-2"></i> Slider Section</h5>
            <div class="row g-3 mb-3">
              <div class="col-12">
                <label class="form-label">Heading</label>
                <input type="text" name="slider_heading" class="form-control" value="<%= archive?.slider_heading || '' %>">
              </div>
              <div class="col-12">
                <label class="form-label">Description</label>
                <input type="text" name="slider_description" class="form-control" value="<%= archive?.slider_description || '' %>">
              </div>
            </div>
            <div id="sliderContainer">
              <% if (archive?.sliderItems && archive.sliderItems.length) {
                archive.sliderItems.forEach((item, idx) => { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Heading</label>
                    <input type="text" name="slider_items[<%= idx %>][heading]" class="form-control" value="<%= item.heading %>">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Description</label>
                    <textarea name="slider_items[<%= idx %>][description]" class="form-control" rows="2"><%= item.description || '' %></textarea>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Image</label>
                    <input type="file" name="slider_items[<%= idx %>][image]" class="form-control" accept="image/*">
                    <% if (item.image) { %>
                      <img src="<%= item.image %>" class="image-preview mt-2" style="display:block">
                    <% } else { %>
                      <img class="image-preview mt-2">
                    <% } %>
                    <input type="hidden" name="slider_items[<%= idx %>][image]" value="<%= item.image || '' %>">
                  </div>
                </div>
              </div>
              <% });
              } else { %>
              <div class="repeater-item">
                <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Heading</label>
                    <input type="text" name="slider_items[0][heading]" class="form-control">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Description</label>
                    <textarea name="slider_items[0][description]" class="form-control" rows="2"></textarea>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Image</label>
                    <input type="file" name="slider_items[0][image]" class="form-control" accept="image/*">
                    <img class="image-preview mt-2">
                    <input type="hidden" name="slider_items[0][image]" value="">
                  </div>
                </div>
              </div>
              <% } %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-slider"><i class="bx bx-plus"></i> Add Slider Item</button>
          </div>

          <!-- Images Section (3 fixed images) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-images me-2"></i> Images Section</h5>
            <div class="row g-3">
              <% for (let i = 1; i <= 3; i++) { %>
              <div class="col-md-4">
                <label class="form-label">Image <%= i %></label>
                <input type="file" name="image<%= i %>" class="form-control" accept="image/*">
                <% if (archive?.['image' + i]) { %>
                  <img src="<%= archive['image' + i] %>" class="image-preview mt-2" style="display:block">
                <% } else { %>
                  <img class="image-preview mt-2">
                <% } %>
              </div>
              <% } %>
            </div>
          </div>

          <!-- Pricing Section (Matrix) -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-dollar-circle me-2"></i> Pricing Section</h5>
            <div id="packageMatrixContainer"></div>
          </div>

          <!-- Video Testimonials Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-video me-2"></i> Video Testimonials</h5>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Select Testimonial Videos</label>
                <select name="video_ids[]" id="videoSelect" class="form-control select2-multiple" multiple>
                  <% videos.forEach(video => { %>
                  <option value="<%= video.id %>" <%= archive?.videos?.some(v => v.id == video.id) ? 'selected' : '' %>>
                    <%= video.title || video.filename %>
                  </option>
                  <% }); %>
                </select>
                <small class="form-text text-muted">Search and select multiple videos</small>
              </div>
              <div id="videoTitlesContainer" class="col-12 mt-3"></div>
            </div>
          </div>

          <!-- Footer Section -->
          <div class="form-section">
            <h5 class="section-title"><i class="bx bx-footer me-2"></i> Footer Section</h5>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Heading</label>
                <input type="text" name="footer_heading" class="form-control" value="<%= archive?.footer_heading || '' %>">
              </div>
              <div class="col-12">
                <label class="form-label">Content</label>
                <textarea name="footer_content" class="form-control" rows="3"><%= archive?.footer_content || '' %></textarea>
              </div>
              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="isActive" value="on" <%= archive?.isActive !== false ? 'checked' : '' %>>
                  <label class="form-check-label">Active</label>
                </div>
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-end mt-3">
            <button type="submit" class="btn btn-submit">
              <i class="bx bx-save me-1"></i> Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- contentFor('js') %>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>
<script>
  const archiveData = <%- JSON.stringify(archive || {}) %>;
  const packageColumns = archiveData?.packageColumns || [];
  const packageRows = archiveData?.packageRows || [];

  $(document).ready(function() {
    $('.select2-multiple').select2({
      theme: 'bootstrap-5',
      width: '100%',
      placeholder: 'Select videos...',
      allowClear: true
    });
    $('.select2-single').select2({
        theme: 'bootstrap-5',
        width: '100%',
        placeholder: 'Select a video',
        allowClear: true
      });

    $('.summernote').summernote({
        placeholder: 'Write your content here...',
        tabsize: 2,
        height: 300,
        fontNames: [
          'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New',
          'Georgia', 'Tahoma', 'Times New Roman', 'Verdana',

          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontNamesIgnoreCheck: [
          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontSizes: ['8', '10', '12', '14', '16', '18', '20', '24', '28', '32', '36', '48', '64'],
        toolbar: [
          ['style', ['style']],
          ['font', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
          ['fontname', ['fontname']],
          ['fontsize', ['fontsize']],
          ['color', ['forecolor', 'backcolor']],
          ['para', ['ul', 'ol', 'paragraph', 'height']],
          ['insert', ['link', 'picture', 'video', 'table']],
          ['view', ['fullscreen', 'codeview']]
        ],
        lineHeights: ['0.8', '1.0', '1.2', '1.5', '2.0', '3.0'],
        callbacks: {
          onChange: function(contents) {
            // Update the hidden textarea when content changes
            const textarea = $(this).closest('.text-editor').find('.text-content');
            textarea.val(contents);
          }
        }
      });

    // Image preview
    function setupImagePreview(inputElem, previewElem) {
      inputElem.on('change', function() {
        const file = this.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) { previewElem.attr('src', e.target.result).show(); };
          reader.readAsDataURL(file);
        } else {
          previewElem.hide().attr('src', '');
        }
      });
    }
    $('input[type="file"]').each(function() {
      const preview = $(this).siblings('.image-preview');
      if (preview.length) setupImagePreview($(this), preview);
    });

    // Image Cards repeater
    let imageCardIndex = $('#imageCardsContainer .repeater-item').length;
    $('.add-image-card').click(function() {
      const newIndex = imageCardIndex++;
      const newItem = `
        <div class="repeater-item">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Heading</label>
              <input type="text" name="image_cards[${newIndex}][heading]" class="form-control">
            </div>
            <div class="col-md-6">
              <label class="form-label">Image</label>
              <input type="file" name="image_cards[${newIndex}][image]" class="form-control" accept="image/*">
              <img class="image-preview mt-2">
              <input type="hidden" name="image_cards[${newIndex}][image]" value="">
            </div>
          </div>
        </div>
      `;
      $('#imageCardsContainer').append(newItem);
      const fileInput = $(`#imageCardsContainer .repeater-item:last input[type="file"]`);
      const preview = fileInput.siblings('.image-preview');
      setupImagePreview(fileInput, preview);
    });

    // Inclusions repeater
    let inclusionIndex = $('#inclusionsContainer .repeater-item').length;
    $('.add-inclusion').click(function() {
      const newIndex = inclusionIndex++;
      const newItem = `
        <div class="repeater-item">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Heading</label>
              <input type="text" name="inclusion_items[${newIndex}][heading]" class="form-control">
            </div>
            <div class="col-md-6">
              <label class="form-label">Link</label>
              <input type="text" name="inclusion_items[${newIndex}][link]" class="form-control" placeholder="https://example.com">
            </div>
            <div class="col-md-6">
              <label class="form-label">Image</label>
              <input type="file" name="inclusion_items[${newIndex}][image]" class="form-control" accept="image/*">
              <img class="image-preview mt-2">
              <input type="hidden" name="inclusion_items[${newIndex}][image]" value="">
            </div>
          </div>
        </div>
      `;
      $('#inclusionsContainer').append(newItem);
      const fileInput = $(`#inclusionsContainer .repeater-item:last input[type="file"]`);
      const preview = fileInput.siblings('.image-preview');
      setupImagePreview(fileInput, preview);
    });

    // Slider repeater
    let sliderIndex = $('#sliderContainer .repeater-item').length;
    $('.add-slider').click(function() {
      const newIndex = sliderIndex++;
      const newItem = `
        <div class="repeater-item">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Heading</label>
              <input type="text" name="slider_items[${newIndex}][heading]" class="form-control">
            </div>
            <div class="col-md-6">
              <label class="form-label">Description</label>
              <textarea name="slider_items[${newIndex}][description]" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label">Image</label>
              <input type="file" name="slider_items[${newIndex}][image]" class="form-control" accept="image/*">
              <img class="image-preview mt-2">
              <input type="hidden" name="slider_items[${newIndex}][image]" value="">
            </div>
          </div>
        </div>
      `;
      $('#sliderContainer').append(newItem);
      const fileInput = $(`#sliderContainer .repeater-item:last input[type="file"]`);
      const preview = fileInput.siblings('.image-preview');
      setupImagePreview(fileInput, preview);
    });

    // Package matrix (same as in virtual archive)
    function buildPackageMatrix() {
      let columns = packageColumns.map(col => ({ ...col }));
      let rows = packageRows.map(row => ({ ...row, cells: row.cells || [] }));

      if (columns.length === 0) {
        columns = [{ title: '', duration: '', image: '' }];
        rows = [{ feature: '', cells: [] }];
      }

      const html = `
        <div class="table-responsive">
          <table class="package-table" id="packageTable">
            <thead>
              <tr>
                <th>Feature</th>
                ${columns.map((col, colIndex) => `
                  <th>
                    <div class="mb-2">
                      <button type="button" class="btn btn-sm btn-primary select-package-image" data-col="${colIndex}">Image</button>
                      <input type="hidden" name="package_columns[${colIndex}][image]" value="${escapeHtml(col.image || '')}">
                      ${col.image ? `<img src="${col.image}" style="max-width:60px; display:block; margin-top:5px;">` : ''}
                    </div>
                    <input type="text" name="package_columns[${colIndex}][title]" class="form-control form-control-sm mb-1" placeholder="Title" value="${escapeHtml(col.title || '')}">
                    <input type="text" name="package_columns[${colIndex}][duration]" class="form-control form-control-sm" placeholder="Duration" value="${escapeHtml(col.duration || '')}">
                  </th>
                `).join('')}
                <th><button type="button" class="btn btn-sm btn-warning add-column">+ Column</button></th>
               </tr>
            </thead>
            <tbody>
              ${rows.map((row, rowIndex) => `
                <tr>
                  <td><input type="text" name="package_rows[${rowIndex}][feature]" class="form-control" value="${escapeHtml(row.feature || '')}"></td>
                  ${columns.map((col, colIndex) => {
                    const cellValue = row.cells.find(c => c.column_id === col.id)?.value || row[`col${colIndex}`] || 'No';
                    return `<td><input type="text" name="package_rows[${rowIndex}][col${colIndex}]" class="form-control" value="${escapeHtml(cellValue)}"></td>`;
                  }).join('')}
                  <td><button type="button" class="btn btn-sm btn-danger remove-row">Remove</button></td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
        <div class="mt-2 text-end">
          <button type="button" class="btn btn-sm btn-dark add-row">+ Row</button>
        </div>
      `;

      $('#packageMatrixContainer').html(html);

      $('#packageMatrixContainer').off('click', '.add-column').on('click', '.add-column', addPackageColumn);
      $('#packageMatrixContainer').off('click', '.add-row').on('click', '.add-row', addPackageRow);
      $('#packageMatrixContainer').off('click', '.remove-row').on('click', '.remove-row', function() {
        $(this).closest('tr').remove();
        reindexPackageRows();
      });
      $('#packageMatrixContainer').off('click', '.select-package-image').on('click', '.select-package-image', function() {
        const colIndex = $(this).data('col');
        const fileInput = $('<input type="file" accept="image/*">');
        fileInput.on('change', function(e) {
          const file = e.target.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = function(ev) {
              const dataUrl = ev.target.result;
              $(`input[name="package_columns[${colIndex}][image]"]`).val(dataUrl);
              $(this).closest('th').find('img').remove();
              $(this).closest('th').append(`<img src="${dataUrl}" style="max-width:60px; display:block; margin-top:5px;">`);
            }.bind(this);
            reader.readAsDataURL(file);
          }
        });
        fileInput.trigger('click');
      });
    }

    function addPackageColumn() {
      const colCount = $('.package-table thead tr th').length - 2;
      const newIndex = colCount;
      const newTh = `
        <th>
          <div class="mb-2">
            <button type="button" class="btn btn-sm btn-primary select-package-image" data-col="${newIndex}">Image</button>
            <input type="hidden" name="package_columns[${newIndex}][image]" value="">
          </div>
          <input type="text" name="package_columns[${newIndex}][title]" class="form-control form-control-sm mb-1" placeholder="Title">
          <input type="text" name="package_columns[${newIndex}][duration]" class="form-control form-control-sm" placeholder="Duration">
        </th>
      `;
      $('.package-table thead tr').find('th:last-child').before(newTh);

      $('.package-table tbody tr').each(function(rowIndex) {
        const newTd = `<td><input type="text" name="package_rows[${rowIndex}][col${newIndex}]" class="form-control" value="No"></td>`;
        $(this).find('td:last-child').before(newTd);
      });
      reindexPackageRows();
    }

    function addPackageRow() {
      const rowCount = $('.package-table tbody tr').length;
      const newIndex = rowCount;
      const colCount = $('.package-table thead tr th').length - 2;
      let rowHtml = `<tr><td><input type="text" name="package_rows[${newIndex}][feature]" class="form-control"></td>`;
      for (let i = 0; i < colCount; i++) {
        rowHtml += `<td><input type="text" name="package_rows[${newIndex}][col${i}]" class="form-control" value="No"></td>`;
      }
      rowHtml += `<td><button type="button" class="btn btn-sm btn-danger remove-row">Remove</button></td></tr>`;
      $('.package-table tbody').append(rowHtml);
    }

    function reindexPackageRows() {
      $('.package-table tbody tr').each(function(idx) {
        $(this).find('input[name^="package_rows["]').each(function() {
          const name = $(this).attr('name');
          const newName = name.replace(/package_rows\[\d+\]/, `package_rows[${idx}]`);
          $(this).attr('name', newName);
        });
      });
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));
    }

    buildPackageMatrix();

    // Video titles
    function updateVideoTitles() {
      const selected = $('#videoSelect').val() || [];
      const container = $('#videoTitlesContainer');
      container.empty();
      if (selected.length) {
        container.append('<h6>Custom Video Titles (optional)</h6>');
        selected.forEach(id => {
          const videoName = $('#videoSelect option[value="' + id + '"]').text();
          let existingTitle = '';
          if (archiveData?.videos) {
            const vid = archiveData.videos.find(v => v.id == id);
            if (vid && vid.BachelorFarewellVideo) existingTitle = vid.BachelorFarewellVideo.custom_title;
          }
          container.append(`
            <div class="mb-3">
              <label class="form-label">Title for "${videoName}"</label>
              <input type="text" class="form-control" name="video_title_${id}" value="${escapeHtml(existingTitle)}" placeholder="Enter custom title">
            </div>
          `);
        });
      }
    }
    $('#videoSelect').on('change', updateVideoTitles);
    updateVideoTitles();
  });

  function removeItem(btn) {
    $(btn).closest('.repeater-item').remove();
  }
</script>