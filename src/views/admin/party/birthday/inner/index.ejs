<%- contentFor('title') %> Birthday Inner Pages
<%- contentFor('head') %>
<style>
  /* minimal custom styles */
  .bg-gradient-warning {
    background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%);
  }

  .search-box {
    position: relative;
  }

  .search-box i {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: #6c757d;
    pointer-events: none;
  }

  .search-box input {
    padding-left: 2rem;
  }

  .page-card .card-img-top {
    height: 160px;
    object-fit: cover;
  }

  .page-card .card-body {
    padding: 1rem;
  }

  .page-card .card-title {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .page-card .card-text {
    font-size: 0.75rem;
    color: #6c757d;
  }

  .page-card .badge {
    font-size: 0.7rem;
  }

  .btn-group-sm .btn {
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
  }

  @media (max-width: 768px) {
    .page-card .card-img-top {
      height: 140px;
    }
  }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-3">
  <div class="row align-items-center mb-3">
    <div class="col-md-8">
      <h4 class="mb-0 fw-bold">Birthday Inner Pages</h4>
      <p class="text-muted small mb-0">Manage all birthday inner content pages</p>
    </div>
    <div class="col-md-4 text-md-end mt-2 mt-md-0">
      <a href="/admin/party/birthday/create" class="btn btn-primary btn-sm">
        <i class="bx bx-plus-circle me-1"></i> Add New Page
      </a>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="row g-2 mb-3">
    <div class="col-md-4">
      <div class="card bg-gradient-warning text-dark border-0 shadow-sm">
        <div class="card-body py-2">
          <h3 class="card-title mb-0 fs-2" id="totalPages">0</h3>
          <p class="card-text small mb-0">Total Pages</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card bg-gradient-warning text-dark border-0 shadow-sm">
        <div class="card-body py-2">
          <h3 class="card-title mb-0 fs-2" id="activePages">0</h3>
          <p class="card-text small mb-0">Active Pages</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card bg-gradient-warning text-dark border-0 shadow-sm">
        <div class="card-body py-2">
          <h3 class="card-title mb-0 fs-2" id="inactivePages">0</h3>
          <p class="card-text small mb-0">Inactive Pages</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Search and Filter -->
  <div class="row g-2 mb-3">
    <div class="col-md-6">
      <div class="search-box">
        <i class="bx bx-search"></i>
        <input type="text" id="searchPages" class="form-control form-control-sm" placeholder="Search by title or slug...">
      </div>
    </div>
    <div class="col-md-6 text-md-end">
      <div class="btn-group btn-group-sm" role="group">
        <button type="button" class="btn btn-outline-secondary filter-status active" data-status="all">All</button>
        <button type="button" class="btn btn-outline-secondary filter-status" data-status="active">Active</button>
        <button type="button" class="btn btn-outline-secondary filter-status" data-status="inactive">Inactive</button>
      </div>
    </div>
  </div>

  <!-- Pages Grid -->
  <div class="row g-3" id="pagesContainer">
    <% if (pages && pages.length) { %>
    <% pages.forEach(page => { %>
    <div class="col-lg-4 col-md-6 page-card" data-title="<%= page.title.toLowerCase() %>" data-slug="<%= page.slug.toLowerCase() %>" data-status="<%= page.isActive ? 'active' : 'inactive' %>">
      <div class="card h-100 shadow-sm border-0">
        <div class="position-relative">
          <% if (page.image) { %>
          <img src="<%= page.image %>" class="card-img-top" alt="<%= page.title %>">
          <% } else { %>
          <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 160px;">
            <i class="bx bx-image-alt fs-1 text-muted"></i>
          </div>
          <% } %>
        </div>
        <div class="card-body">
          <h5 class="card-title mb-1"><%= page.title %></h5>
          <div class="card-text small text-muted mb-2"><i class="bx bx-link-alt me-1"></i> <%= page.slug %></div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="badge <%= page.isActive ? 'bg-success' : 'bg-secondary' %>"><%= page.isActive ? 'Active' : 'Inactive' %></span>
            <small class="text-muted"><i class="bx bx-calendar me-1"></i> <%= new Date(page.createdAt).toLocaleDateString() %></small>
          </div>
          <div class="d-flex gap-1 justify-content-end">
            <a href="/admin/faqs/slug/<%= page.slug %>" class="bg-primary py-1 px-2 text-white rounded" title="View FAQs" style="font-size: 14px;">
              <i class="bi bi-patch-question"></i>
            </a>
            <a href="/admin/googlereviews/slug/<%= page.slug %>" class="bg-secondary py-1 px-2 text-white rounded" title="View Google Reviews" style="font-size: 14px;">
              <i class="bi bi-google"></i>
            </a>
            <a href="/admin/party/birthday/view/<%= page.id %>" class="btn btn-sm btn-outline-info"><i class="bx bx-show"></i> </a>
            <a href="/admin/party/birthday/edit/<%= page.id %>" class="btn btn-sm btn-outline-warning"><i class="bx bx-edit"></i> </a>
            <a href="/admin/party/birthday/delete/<%= page.id %>" class="btn btn-sm btn-outline-danger delete-page" data-id="<%= page.id %>"><i class="bx bx-trash"></i> </a>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
    <% } else { %>
    <div class="col-12 text-center py-5">
      <i class="bx bx-ghost fs-1 text-muted"></i>
      <h5 class="mt-3">No pages found</h5>
      <p class="text-muted">Get started by creating your first birthday inner page.</p>
      <a href="/admin/party/birthday/create" class="btn btn-primary btn-sm">Add New Page</a>
    </div>
    <% } %>
  </div>
</div>

<%- contentFor('js') %>
<script>
  const pages = document.querySelectorAll('.page-card');
  const totalPages = pages.length;
  const activeCount = Array.from(pages).filter(p => p.dataset.status === 'active').length;
  document.getElementById('totalPages').innerText = totalPages;
  document.getElementById('activePages').innerText = activeCount;
  document.getElementById('inactivePages').innerText = totalPages - activeCount;

  function filterPages() {
    const searchTerm = document.getElementById('searchPages').value.toLowerCase().trim();
    const status = document.querySelector('.filter-status.active').dataset.status;
    let visible = 0;
    pages.forEach(card => {
      const title = card.dataset.title;
      const slug = card.dataset.slug;
      const cardStatus = card.dataset.status;
      const matches = (searchTerm === '' || title.includes(searchTerm) || slug.includes(searchTerm)) &&
        (status === 'all' || cardStatus === status);
      card.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });
    const container = document.getElementById('pagesContainer');
    const existingNoResults = container.querySelector('.no-results');
    if (visible === 0 && pages.length > 0) {
      if (!existingNoResults) {
        const msg = document.createElement('div');
        msg.className = 'col-12 text-center py-5 no-results';
        msg.innerHTML = '<i class="bx bx-search-alt fs-1 text-muted"></i><h5 class="mt-3">No matching pages</h5><p class="text-muted">Try a different search term.</p>';
        container.appendChild(msg);
      }
    } else if (existingNoResults) {
      existingNoResults.remove();
    }
  }

  document.getElementById('searchPages').addEventListener('input', filterPages);
  document.querySelectorAll('.filter-status').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-status').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterPages();
    });
  });

  document.querySelectorAll('.delete-page').forEach(btn => {
    btn.addEventListener('click', async e => {
      e.preventDefault();
      if (!confirm('Delete this page? This action cannot be undone.')) return;

      const id = btn.dataset.id;
      const res = await fetch(`/admin/party/birthday/delete/${id}`, {
        method: 'DELETE'
      });

      // After a redirect, fetch automatically follows it.
      // res.url contains the final URL (the page the backend redirected to).
      if (res.ok) {
        window.location.href = res.url; // navigate to that page
      } else {
        location.reload(); // fallback to reload if something goes wrong
      }
    });
  });
</script>