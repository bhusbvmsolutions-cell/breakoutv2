<% if (page) { %>
    <input type="hidden" name="_method" value="PUT">
  <% } %>
  
  <!-- Basic Information -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-info-circle me-2"></i> Basic Information</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-md-6">
          <label class="form-label small text-muted">Title *</label>
          <input type="text" name="title" id="title" class="form-control form-control-sm" value="<%= page?.title || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label small text-muted">Slug</label>
          <input type="text" name="slug" id="slug" class="form-control form-control-sm" value="<%= page?.slug || '' %>">
          <div class="form-text small">Leave blank to auto-generate</div>
        </div>
        <div class="col-12">
          <label class="form-label small text-muted">Main Image</label>
          <input type="file" name="image" class="form-control form-control-sm" accept="image/*">
          <% if (page?.image) { %>
            <img src="<%= page.image %>" class="img-thumbnail mt-1" style="max-width:80px; max-height:60px;">
          <% } %>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Banner Section -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-image-alt me-2"></i> Banner Section</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12">
          <label class="form-label small text-muted">Heading</label>
          <input type="text" name="banner_heading" class="form-control form-control-sm" value="<%= page?.banner_heading || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label small text-muted">Description</label>
          <input type="text" name="banner_description" class="form-control form-control-sm" value="<%= page?.banner_description || '' %>">
        </div>
        <div class="col-12">
            <label class="form-label small text-muted">Banner Video</label>
            <select name="banner_video_id" class="form-control form-control-sm select2-single">
              <option value="">-- Select a video --</option>
              <% videos.forEach(video => { %>
                <option value="<%= video.id %>" <%= page?.banner_video_id == video.id ? 'selected' : '' %>>
                  <%= video.title || video.filename %>
                </option>
              <% }); %>
            </select>
            <div class="form-text small">Select a video for the banner section</div>
          </div>
      </div>
    </div>
  </div>
  
  <!-- Counters Section -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-stats me-2"></i> Counters Section</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12">
          <label class="form-label small text-muted">Heading</label>
          <input type="text" name="counters_heading" class="form-control form-control-sm" value="<%= page?.counters_heading || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label small text-muted">Content</label>
          <textarea name="counters_content" class="form-control form-control-sm" rows="2"><%= page?.counters_content || '' %></textarea>
        </div>
        <div class="col-12">
          <label class="form-label small text-muted">Note</label>
          <input type="text" name="counters_note" class="form-control form-control-sm" value="<%= page?.counters_note || '' %>">
        </div>
        <div class="col-md-10">
          <label class="form-label small text-muted">Counter Heading</label>
          <input type="text" name="counters_counter_heading" class="form-control form-control-sm" value="<%= page?.counters_counter_heading || '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label small text-muted">Rating (0-5)</label>
          <input type="number" step="0.1" name="counters_rating" class="form-control form-control-sm" value="<%= page?.counters_rating || '' %>" min="0" max="5">
        </div>
      </div>
  
      <label class="form-label small fw-bold mt-2 mb-1">Counter Cards (3 items)</label>
      <div class="row g-2">
        <% for (let i = 0; i < 3; i++) {
          const card = page?.counterCards?.[i];
        %>
        <div class="col-md-4">
          <div class="card border-0 bg-light h-100">
            <div class="card-body p-2">
              <label class="form-label small text-muted">Image</label>
              <input type="file" name="counter_cards[<%= i %>][image]" class="form-control form-control-sm" accept="image/*">
              <% if (card?.image) { %>
                <img src="<%= card.image %>" class="img-thumbnail mt-1" style="max-width:80px;">
              <% } %>
              <input type="hidden" name="counter_cards[<%= i %>][image]" value="<%= card?.image || '' %>">
              <hr class="my-1">
              <label class="form-label small text-muted">Count</label>
              <input type="text" name="counter_cards[<%= i %>][count]" class="form-control form-control-sm" value="<%= card?.count || '' %>">
              <label class="form-label small text-muted mt-1">Description</label>
              <input type="text" name="counter_cards[<%= i %>][description]" class="form-control form-control-sm" value="<%= card?.description || '' %>">
            </div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  
  <!-- Image Card Section (Repeater) -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
      <h6 class="fw-bold mb-0"><i class="bx bx-images me-2"></i> Image Card Section</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2 mb-2">
        <div class="col-12">
          <label class="form-label small text-muted">Section Heading</label>
          <input type="text" name="image_card_heading" class="form-control form-control-sm" value="<%= page?.image_card_heading || '' %>">
        </div>
      </div>
      <div id="imageCardsContainer">
        <% if (page?.imageCards && page.imageCards.length) {
          page.imageCards.forEach((item, idx) => { %>
        <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label small text-muted">Heading</label>
              <input type="text" name="image_cards[<%= idx %>][heading]" class="form-control form-control-sm" value="<%= item.heading %>">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted">Image</label>
              <input type="file" name="image_cards[<%= idx %>][image]" class="form-control form-control-sm" accept="image/*">
              <% if (item.image) { %>
                <img src="<%= item.image %>" class="img-thumbnail mt-1" style="max-width:80px;">
              <% } %>
              <input type="hidden" name="image_cards[<%= idx %>][image]" value="<%= item.image || '' %>">
            </div>
          </div>
        </div>
        <% });
        } else { %>
        <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label small text-muted">Heading</label>
              <input type="text" name="image_cards[0][heading]" class="form-control form-control-sm">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted">Image</label>
              <input type="file" name="image_cards[0][image]" class="form-control form-control-sm" accept="image/*">
              <input type="hidden" name="image_cards[0][image]" value="">
            </div>
          </div>
        </div>
        <% } %>
      </div>
      <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-image-card"><i class="bx bx-plus"></i> Add Card</button>
    </div>
  </div>
  
  <!-- Party Inclusions Section (Repeater) -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-gift me-2"></i> Party Inclusions</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2 mb-2">
        <div class="col-12">
          <label class="form-label small text-muted">Section Heading</label>
          <input type="text" name="party_inclusions_heading" class="form-control form-control-sm" value="<%= page?.party_inclusions_heading || '' %>">
        </div>
      </div>
      <div id="inclusionsContainer">
        <% if (page?.inclusionItems && page.inclusionItems.length) {
          page.inclusionItems.forEach((item, idx) => { %>
        <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label small text-muted">Heading</label>
              <input type="text" name="inclusion_items[<%= idx %>][heading]" class="form-control form-control-sm" value="<%= item.heading %>">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted">Link</label>
              <input type="text" name="inclusion_items[<%= idx %>][link]" class="form-control form-control-sm" value="<%= item.link || '' %>" placeholder="https://example.com">
            </div>
            <div class="col-md-12">
              <label class="form-label small text-muted">Image</label>
              <input type="file" name="inclusion_items[<%= idx %>][image]" class="form-control form-control-sm" accept="image/*">
              <% if (item.image) { %>
                <img src="<%= item.image %>" class="img-thumbnail mt-1" style="max-width:80px;">
              <% } %>
              <input type="hidden" name="inclusion_items[<%= idx %>][image]" value="<%= item.image || '' %>">
            </div>
          </div>
        </div>
        <% });
        } else { %>
        <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label small text-muted">Heading</label>
              <input type="text" name="inclusion_items[0][heading]" class="form-control form-control-sm">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted">Link</label>
              <input type="text" name="inclusion_items[0][link]" class="form-control form-control-sm" placeholder="https://example.com">
            </div>
            <div class="col-md-12">
              <label class="form-label small text-muted">Image</label>
              <input type="file" name="inclusion_items[0][image]" class="form-control form-control-sm" accept="image/*">
              <input type="hidden" name="inclusion_items[0][image]" value="">
            </div>
          </div>
        </div>
        <% } %>
      </div>
      <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-inclusion"><i class="bx bx-plus"></i> Add Inclusion</button>
      <div class="row g-2 mt-2">
        <div class="col-12">
          <label class="form-label small text-muted">Note</label>
          <input type="text" name="party_inclusions_note" class="form-control form-control-sm" value="<%= page?.party_inclusions_note || '' %>">
        </div>
      </div>
    </div>
  </div>
  
  <!-- Slider Section (Repeater) -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-slider me-2"></i> Slider Section</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2 mb-2">
        <div class="col-12">
          <label class="form-label small text-muted">Heading</label>
          <input type="text" name="slider_heading" class="form-control form-control-sm" value="<%= page?.slider_heading || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label small text-muted">Description</label>
          <input type="text" name="slider_description" class="form-control form-control-sm" value="<%= page?.slider_description || '' %>">
        </div>
      </div>
      <div id="sliderContainer">
        <% if (page?.sliderItems && page.sliderItems.length) {
          page.sliderItems.forEach((item, idx) => { %>
        <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label small text-muted">Heading</label>
              <input type="text" name="slider_items[<%= idx %>][heading]" class="form-control form-control-sm" value="<%= item.heading %>">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted">Description</label>
              <textarea name="slider_items[<%= idx %>][description]" class="form-control form-control-sm" rows="2"><%= item.description || '' %></textarea>
            </div>
            <div class="col-md-12">
              <label class="form-label small text-muted">Image</label>
              <input type="file" name="slider_items[<%= idx %>][image]" class="form-control form-control-sm" accept="image/*">
              <% if (item.image) { %>
                <img src="<%= item.image %>" class="img-thumbnail mt-1" style="max-width:80px;">
              <% } %>
              <input type="hidden" name="slider_items[<%= idx %>][image]" value="<%= item.image || '' %>">
            </div>
          </div>
        </div>
        <% });
        } else { %>
        <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label small text-muted">Heading</label>
              <input type="text" name="slider_items[0][heading]" class="form-control form-control-sm">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted">Description</label>
              <textarea name="slider_items[0][description]" class="form-control form-control-sm" rows="2"></textarea>
            </div>
            <div class="col-md-12">
              <label class="form-label small text-muted">Image</label>
              <input type="file" name="slider_items[0][image]" class="form-control form-control-sm" accept="image/*">
              <input type="hidden" name="slider_items[0][image]" value="">
            </div>
          </div>
        </div>
        <% } %>
      </div>
      <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-slider"><i class="bx bx-plus"></i> Add Slider Item</button>
    </div>
  </div>
  
  <!-- Images Section (3 fixed) -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-images me-2"></i> Images Section</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <% for (let i = 1; i <= 3; i++) { %>
        <div class="col-md-4">
          <label class="form-label small text-muted">Image <%= i %></label>
          <input type="file" name="image<%= i %>" class="form-control form-control-sm" accept="image/*">
          <% if (page?.['image' + i]) { %>
            <img src="<%= page['image' + i] %>" class="img-thumbnail mt-1" style="max-width:80px;">
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  
  <!-- Pricing Section (Matrix) -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-dollar-circle me-2"></i> Pricing Section</h6>
    </div>
    <div class="card-body pt-2">
      <div id="packageMatrixContainer"></div>
    </div>
  </div>
  
  <!-- Video Testimonials -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-video me-2"></i> Video Testimonials</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12">
          <label class="form-label small text-muted">Select Testimonial Videos</label>
          <select name="video_ids[]" id="videoSelect" class="form-control select2-multiple" multiple>
            <% videos.forEach(video => { %>
            <option value="<%= video.id %>" <%= page?.videos?.some(v => v.id == video.id) ? 'selected' : '' %>>
              <%= video.title || video.filename %>
            </option>
            <% }); %>
          </select>
          <div class="form-text small">Search and select multiple videos</div>
        </div>
        <div id="videoTitlesContainer" class="col-12 mt-2"></div>
      </div>
    </div>
  </div>
  
  <!-- Footer Section -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0">
      <h6 class="fw-bold mb-0"><i class="bx bx-footer me-2"></i> Footer Section</h6>
    </div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12">
          <label class="form-label small text-muted">Heading</label>
          <input type="text" name="footer_heading" class="form-control form-control-sm" value="<%= page?.footer_heading || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label small text-muted">Content</label>
          <textarea name="footer_content" class="form-control form-control-sm" rows="3"><%= page?.footer_content || '' %></textarea>
        </div>
        <div class="col-12">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="isActive" value="on" <%= page?.isActive !== false ? 'checked' : '' %>>
            <label class="form-check-label small">Active</label>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <button type="submit" class="btn btn-primary btn-sm px-4 mt-2">
    <i class="bx bx-save me-1"></i> <%= page ? 'Update Page' : 'Create Page' %>
  </button>
  
  <script>
    $(document).ready(function() {


        $('.select2-single').select2({
            theme: 'bootstrap-5',
            width: '100%',
            placeholder: 'Select a video',
            allowClear: true
          });
      // ---------- Image Preview for dynamic file inputs ----------
      function setupImagePreview(inputElem, previewElem) {
        inputElem.on('change', function() {
          const file = this.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = function(e) { previewElem.attr('src', e.target.result).show(); };
            reader.readAsDataURL(file);
          } else {
            previewElem.hide().attr('src', '');
          }
        });
      }
  
      // Apply preview to all file inputs that have a sibling img with class "img-thumbnail"
      $('input[type="file"]').each(function() {
        const preview = $(this).next('.img-thumbnail');
        if (preview.length) setupImagePreview($(this), preview);
      });
  
      // ---------- Image Cards Repeater ----------
      let imageCardIndex = $('#imageCardsContainer .repeater-item').length;
      $('.add-image-card').click(function() {
        const newIndex = imageCardIndex++;
        const newItem = `
          <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
            <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
            <div class="row g-2">
              <div class="col-md-6">
                <label class="form-label small text-muted">Heading</label>
                <input type="text" name="image_cards[${newIndex}][heading]" class="form-control form-control-sm">
              </div>
              <div class="col-md-6">
                <label class="form-label small text-muted">Image</label>
                <input type="file" name="image_cards[${newIndex}][image]" class="form-control form-control-sm" accept="image/*">
                <img class="img-thumbnail mt-1" style="display:none; max-width:80px;">
                <input type="hidden" name="image_cards[${newIndex}][image]" value="">
              </div>
            </div>
          </div>
        `;
        $('#imageCardsContainer').append(newItem);
        const fileInput = $(`#imageCardsContainer .repeater-item:last input[type="file"]`);
        const preview = fileInput.next('.img-thumbnail');
        setupImagePreview(fileInput, preview);
      });
  
      // ---------- Inclusions Repeater ----------
      let inclusionIndex = $('#inclusionsContainer .repeater-item').length;
      $('.add-inclusion').click(function() {
        const newIndex = inclusionIndex++;
        const newItem = `
          <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
            <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
            <div class="row g-2">
              <div class="col-md-6">
                <label class="form-label small text-muted">Heading</label>
                <input type="text" name="inclusion_items[${newIndex}][heading]" class="form-control form-control-sm">
              </div>
              <div class="col-md-6">
                <label class="form-label small text-muted">Link</label>
                <input type="text" name="inclusion_items[${newIndex}][link]" class="form-control form-control-sm" placeholder="https://example.com">
              </div>
              <div class="col-md-12">
                <label class="form-label small text-muted">Image</label>
                <input type="file" name="inclusion_items[${newIndex}][image]" class="form-control form-control-sm" accept="image/*">
                <img class="img-thumbnail mt-1" style="display:none; max-width:80px;">
                <input type="hidden" name="inclusion_items[${newIndex}][image]" value="">
              </div>
            </div>
          </div>
        `;
        $('#inclusionsContainer').append(newItem);
        const fileInput = $(`#inclusionsContainer .repeater-item:last input[type="file"]`);
        const preview = fileInput.next('.img-thumbnail');
        setupImagePreview(fileInput, preview);
      });
  
      // ---------- Slider Items Repeater ----------
      let sliderIndex = $('#sliderContainer .repeater-item').length;
      $('.add-slider').click(function() {
        const newIndex = sliderIndex++;
        const newItem = `
          <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
            <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
            <div class="row g-2">
              <div class="col-md-6">
                <label class="form-label small text-muted">Heading</label>
                <input type="text" name="slider_items[${newIndex}][heading]" class="form-control form-control-sm">
              </div>
              <div class="col-md-6">
                <label class="form-label small text-muted">Description</label>
                <textarea name="slider_items[${newIndex}][description]" class="form-control form-control-sm" rows="2"></textarea>
              </div>
              <div class="col-md-12">
                <label class="form-label small text-muted">Image</label>
                <input type="file" name="slider_items[${newIndex}][image]" class="form-control form-control-sm" accept="image/*">
                <img class="img-thumbnail mt-1" style="display:none; max-width:80px;">
                <input type="hidden" name="slider_items[${newIndex}][image]" value="">
              </div>
            </div>
          </div>
        `;
        $('#sliderContainer').append(newItem);
        const fileInput = $(`#sliderContainer .repeater-item:last input[type="file"]`);
        const preview = fileInput.next('.img-thumbnail');
        setupImagePreview(fileInput, preview);
      });
  
      // ---------- Package Matrix ----------
      function buildPackageMatrix() {
        let columns = packageColumns.map(col => ({ ...col }));
        let rows = packageRows.map(row => ({ ...row, cells: row.cells || [] }));
  
        if (columns.length === 0) {
          columns = [{ title: '', duration: '', image: '' }];
          rows = [{ feature: '', cells: [] }];
        }
  
        const html = `
          <div class="table-responsive">
            <table class="package-table table table-bordered table-sm" id="packageTable">
              <thead>
                <tr>
                  <th>Feature</th>
                  ${columns.map((col, colIndex) => `
                    <th>
                      <div class="mb-2">
                        <button type="button" class="btn btn-sm btn-primary select-package-image" data-col="${colIndex}">Image</button>
                        <input type="hidden" name="package_columns[${colIndex}][image]" value="${escapeHtml(col.image || '')}">
                        ${col.image ? `<img src="${col.image}" style="max-width:60px; display:block; margin-top:5px;">` : ''}
                      </div>
                      <input type="text" name="package_columns[${colIndex}][title]" class="form-control form-control-sm mb-1" placeholder="Title" value="${escapeHtml(col.title || '')}">
                      <input type="text" name="package_columns[${colIndex}][duration]" class="form-control form-control-sm" placeholder="Duration" value="${escapeHtml(col.duration || '')}">
                    </th>
                  `).join('')}
                  <th><button type="button" class="btn btn-sm btn-warning add-column">+ Column</button></th>
                </tr>
              </thead>
              <tbody>
                ${rows.map((row, rowIndex) => `
                  <tr>
                    <td><input type="text" name="package_rows[${rowIndex}][feature]" class="form-control form-control-sm" value="${escapeHtml(row.feature || '')}"></td>
                    ${columns.map((col, colIndex) => {
                      const cellValue = row.cells.find(c => c.column_id === col.id)?.value || row[`col${colIndex}`] || 'No';
                      return `<td><input type="text" name="package_rows[${rowIndex}][col${colIndex}]" class="form-control form-control-sm" value="${escapeHtml(cellValue)}"></td>`;
                    }).join('')}
                    <td><button type="button" class="btn btn-sm btn-danger remove-row">Remove</button></td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
          <div class="mt-2 text-end">
            <button type="button" class="btn btn-sm btn-dark add-row">+ Row</button>
          </div>
        `;
  
        $('#packageMatrixContainer').html(html);
  
        $('#packageMatrixContainer').off('click', '.add-column').on('click', '.add-column', addPackageColumn);
        $('#packageMatrixContainer').off('click', '.add-row').on('click', '.add-row', addPackageRow);
        $('#packageMatrixContainer').off('click', '.remove-row').on('click', '.remove-row', function() {
          $(this).closest('tr').remove();
          reindexPackageRows();
        });
        $('#packageMatrixContainer').off('click', '.select-package-image').on('click', '.select-package-image', function() {
          const colIndex = $(this).data('col');
          const fileInput = $('<input type="file" accept="image/*">');
          fileInput.on('change', function(e) {
            const file = e.target.files[0];
            if (file) {
              const reader = new FileReader();
              reader.onload = function(ev) {
                const dataUrl = ev.target.result;
                $(`input[name="package_columns[${colIndex}][image]"]`).val(dataUrl);
                $(this).closest('th').find('img').remove();
                $(this).closest('th').append(`<img src="${dataUrl}" style="max-width:60px; display:block; margin-top:5px;">`);
              }.bind(this);
              reader.readAsDataURL(file);
            }
          });
          fileInput.trigger('click');
        });
      }
  
      function addPackageColumn() {
        const colCount = $('.package-table thead tr th').length - 2;
        const newIndex = colCount;
        const newTh = `
          <th>
            <div class="mb-2">
              <button type="button" class="btn btn-sm btn-primary select-package-image" data-col="${newIndex}">Image</button>
              <input type="hidden" name="package_columns[${newIndex}][image]" value="">
            </div>
            <input type="text" name="package_columns[${newIndex}][title]" class="form-control form-control-sm mb-1" placeholder="Title">
            <input type="text" name="package_columns[${newIndex}][duration]" class="form-control form-control-sm" placeholder="Duration">
          </th>
        `;
        $('.package-table thead tr').find('th:last-child').before(newTh);
  
        $('.package-table tbody tr').each(function(rowIndex) {
          const newTd = `<td><input type="text" name="package_rows[${rowIndex}][col${newIndex}]" class="form-control form-control-sm" value="No"></td>`;
          $(this).find('td:last-child').before(newTd);
        });
        reindexPackageRows();
      }
  
      function addPackageRow() {
        const rowCount = $('.package-table tbody tr').length;
        const newIndex = rowCount;
        const colCount = $('.package-table thead tr th').length - 2;
        let rowHtml = `
          <tr>
            <td><input type="text" name="package_rows[${newIndex}][feature]" class="form-control form-control-sm"></td>
        `;
        for (let i = 0; i < colCount; i++) {
          rowHtml += `<td><input type="text" name="package_rows[${newIndex}][col${i}]" class="form-control form-control-sm" value="No"></td>`;
        }
        rowHtml += `<td><button type="button" class="btn btn-sm btn-danger remove-row">Remove</button></td></tr>`;
        $('.package-table tbody').append(rowHtml);
      }
  
      function reindexPackageRows() {
        $('.package-table tbody tr').each(function(idx) {
          $(this).find('input[name^="package_rows["]').each(function() {
            const name = $(this).attr('name');
            const newName = name.replace(/package_rows\[\d+\]/, `package_rows[${idx}]`);
            $(this).attr('name', newName);
          });
        });
      }
  
      function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));
      }
  
      buildPackageMatrix();
  
      // ---------- Video Titles ----------
      function updateVideoTitles() {
        const selected = $('#videoSelect').val() || [];
        const container = $('#videoTitlesContainer');
        container.empty();
        if (selected.length) {
          container.append('<h6 class="small fw-bold mb-2">Custom Video Titles (optional)</h6>');
          selected.forEach(id => {
            const videoName = $('#videoSelect option[value="' + id + '"]').text();
            let existingTitle = '';
            if (pageData?.videos) {
              const vid = pageData.videos.find(v => v.id == id);
              if (vid && vid.BirthdayInnerVideo) existingTitle = vid.BirthdayInnerVideo.custom_title;
            }
            container.append(`
              <div class="mb-2">
                <label class="form-label small text-muted">Title for "${videoName}"</label>
                <input type="text" class="form-control form-control-sm" name="video_title_${id}" value="${escapeHtml(existingTitle)}" placeholder="Enter custom title">
              </div>
            `);
          });
        }
      }
  
      $('#videoSelect').on('change', updateVideoTitles);
      updateVideoTitles();
    });
  
    function removeItem(btn) {
      $(btn).closest('.repeater-item').remove();
    }
  </script>