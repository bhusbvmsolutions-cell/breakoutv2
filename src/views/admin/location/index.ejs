<%- contentFor('title') %> Locations
<%- contentFor('head') %>
<style>
  body {
    background: #f5f7fb;
  }

  .stats-card {
    background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%);
    border-radius: 10px;
    padding: 0.75rem;
    color: #2c3e50;
    text-align: center;
    transition: transform 0.2s;
  }

  .stats-card:hover {
    transform: translateY(-3px);
  }

  .stats-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0;
  }

  .stats-card p {
    margin-bottom: 0;
    font-size: 0.7rem;
    opacity: 0.9;
  }

  .search-box {
    position: relative;
    max-width: 300px;
  }

  .search-box input {
    padding-left: 2rem;
    border-radius: 20px;
    border: 1px solid #dee2e6;
    font-size: 0.8rem;
    height: 32px;
  }

  .search-box input:focus {
    border-color: #fcad00;
    box-shadow: 0 0 0 0.2rem rgba(252, 173, 0, 0.25);
  }

  .search-box i {
    position: absolute;
    left: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.9rem;
    color: #adb5bd;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .location-card {
    background: #fff;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    transition: all 0.2s;
  }

  .location-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .location-card-image {
    height: 140px;
    background: #f8f9fa;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .location-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s;
  }

  .location-card:hover .location-card-image img {
    transform: scale(1.03);
  }

  .location-card-content {
    padding: 0.75rem;
  }

  .location-card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: #2c3e50;
  }

  .location-card-slug {
    font-size: 0.7rem;
    color: #6c757d;
    margin-bottom: 0.5rem;
    word-break: break-all;
  }

  .location-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .location-card-status {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .location-card-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .no-locations {
    text-align: center;
    padding: 2rem;
    background: #f8f9fa;
    border-radius: 12px;
    color: #6c757d;
  }

  .btn-sm {
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
  }

  @media (max-width: 768px) {
    .locations-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-3">
  <div class="row mb-3 align-items-center">
    <div class="col-md-8">
      <h4 class="mb-0 fw-bold">Locations</h4>
      <p class="text-muted small mb-0">Manage all locations</p>
    </div>
    <div class="col-md-4 text-md-end mt-2 mt-md-0">
      <a href="/admin/location/create" class="btn btn-primary btn-sm"><i class="bx bx-plus-circle me-1"></i> Add New Location</a>
    </div>
  </div>

  <div class="row g-2 mb-3">
    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="totalLocations">0</h3>
        <p>Total Locations</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="activeLocations">0</h3>
        <p>Active Locations</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="inactiveLocations">0</h3>
        <p>Inactive Locations</p>
      </div>
    </div>
  </div>

  <div class="row mb-3 align-items-center">
    <div class="col-md-6">
      <div class="search-box">
        <i class="bx bx-search"></i>
        <input type="text" id="searchLocations" class="form-control" placeholder="Search by title or slug...">
      </div>
    </div>
    <div class="col-md-6 text-md-end">
      <div class="btn-group btn-group-sm me-2">
        <button class="btn btn-outline-secondary filter-status active" data-status="all">All</button>
        <button class="btn btn-outline-secondary filter-status" data-status="active">Active</button>
        <button class="btn btn-outline-secondary filter-status" data-status="inactive">Inactive</button>
      </div>
      <button id="clearFiltersBtn" class="btn btn-outline-secondary btn-sm"><i class="bx bx-eraser"></i> Clear Filters</button>
    </div>
  </div>

  <div id="locationsContainer" class="locations-grid">
    <% if (locations && locations.length) { %>
      <% locations.forEach(loc => { %>
      <div class="location-card" data-title="<%= loc.title.toLowerCase() %>" data-slug="<%= loc.slug.toLowerCase() %>" data-status="<%= loc.isActive ? 'active' : 'inactive' %>">
        <div class="location-card-image">
          <% if (loc.banner_image) { %>
          <img src="<%= loc.banner_image %>" alt="<%= loc.title %>">
          <% } else { %>
          <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted"><i class="bx bx-image-alt fs-3"></i><span class="small mt-1">No image</span></div>
          <% } %>
        </div>
        <div class="location-card-content">
          <h5 class="location-card-title"><%= loc.title %></h5>
          <div class="location-card-slug"><i class="bx bx-link-alt me-1"></i> <%= loc.slug %></div>
          <div class="location-card-meta">
            <span class="location-card-status badge <%= loc.isActive ? 'bg-success' : 'bg-secondary' %>"><%= loc.isActive ? 'Active' : 'Inactive' %></span>
            <span class="small"><i class="bx bx-calendar me-1"></i> <%= new Date(loc.createdAt).toLocaleDateString() %></span>
          </div>
          <div class="location-card-actions">
            <a href="/admin/location/view/<%= loc.id %>" class="btn btn-sm btn-info"><i class="bx bx-show"></i> View</a>
            <a href="/admin/location/edit/<%= loc.id %>" class="btn btn-sm btn-warning"><i class="bx bx-edit"></i> Edit</a>
            <button class="btn btn-sm btn-danger delete-location" data-id="<%= loc.id %>"><i class="bx bx-trash"></i> Delete</button>
          </div>
        </div>
      </div>
      <% }); %>
    <% } else { %>
      <div class="no-locations">
        <i class="bx bx-ghost fs-2"></i>
        <h5 class="mt-2">No locations found</h5>
        <p class="small">Get started by creating your first location.</p>
        <a href="/admin/location/create" class="btn btn-primary btn-sm mt-1">Add New Location</a>
      </div>
    <% } %>
  </div>
</div>

<%- contentFor('js') %>
<script>
  const locationsContainer = document.getElementById('locationsContainer');
  let locationCards = document.querySelectorAll('.location-card');
  let defaultEmptyDiv = document.querySelector('.no-locations');

  // Create a "no results" div for filtering, if not already present
  let noResultsDiv = document.getElementById('noFilterResults');
  if (!noResultsDiv) {
    noResultsDiv = document.createElement('div');
    noResultsDiv.id = 'noFilterResults';
    noResultsDiv.className = 'no-locations';
    noResultsDiv.style.display = 'none';
    noResultsDiv.innerHTML = `
      <i class="bx bx-search-alt fs-2"></i>
      <h5 class="mt-2">No matching locations</h5>
      <p class="small">Try adjusting your search or filters.</p>
      <button id="clearFiltersInline" class="btn btn-outline-secondary btn-sm mt-1"><i class="bx bx-eraser"></i> Clear Filters</button>
    `;
    locationsContainer.appendChild(noResultsDiv);
    // Add event listener to the inline clear button
    document.getElementById('clearFiltersInline')?.addEventListener('click', clearFilters);
  }

  function updateStats() {
    const total = locationCards.length;
    const active = Array.from(locationCards).filter(c => c.dataset.status === 'active').length;
    document.getElementById('totalLocations').innerText = total;
    document.getElementById('activeLocations').innerText = active;
    document.getElementById('inactiveLocations').innerText = total - active;
  }

  function filterLocations() {
    const term = document.getElementById('searchLocations').value.toLowerCase().trim();
    const status = document.querySelector('.filter-status.active').dataset.status;

    let visibleCount = 0;
    locationCards.forEach(card => {
      const title = card.dataset.title,
            slug = card.dataset.slug,
            cardStatus = card.dataset.status;
      const match = (term === '' || title.includes(term) || slug.includes(term)) && (status === 'all' || cardStatus === status);
      card.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    // Handle empty states
    if (locationCards.length === 0) {
      // No locations exist at all
      if (defaultEmptyDiv) defaultEmptyDiv.style.display = '';
      noResultsDiv.style.display = 'none';
    } else {
      // Locations exist, check if any are visible
      if (visibleCount === 0) {
        // Hide all cards (already done), hide default empty div if present, show no results div
        if (defaultEmptyDiv) defaultEmptyDiv.style.display = 'none';
        noResultsDiv.style.display = '';
      } else {
        // Show cards, hide both empty messages
        if (defaultEmptyDiv) defaultEmptyDiv.style.display = 'none';
        noResultsDiv.style.display = 'none';
      }
    }
  }

  function clearFilters() {
    // Clear search input
    const searchInput = document.getElementById('searchLocations');
    if (searchInput) searchInput.value = '';
    // Reset status filter to "All"
    const allBtn = document.querySelector('.filter-status[data-status="all"]');
    if (allBtn) {
      document.querySelectorAll('.filter-status').forEach(btn => btn.classList.remove('active'));
      allBtn.classList.add('active');
    }
    // Re-apply filter to show all
    filterLocations();
  }

  // Event listeners
  document.getElementById('searchLocations')?.addEventListener('input', filterLocations);
  document.querySelectorAll('.filter-status').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-status').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterLocations();
    });
  });
  document.getElementById('clearFiltersBtn')?.addEventListener('click', clearFilters);

  // Delete functionality
  document.querySelectorAll('.delete-location').forEach(btn => {
    btn.addEventListener('click', async e => {
      if (!confirm('Delete this location?')) return;
      const id = btn.dataset.id;
      const res = await fetch(`/admin/location/delete/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.message);
    });
  });

  updateStats();
  filterLocations(); // initial filter to set correct empty state visibility
</script>