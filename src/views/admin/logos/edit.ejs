<%- contentFor('title') %>
<%- contentFor('head') %>
<%- contentFor('body') %>


<div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h4><i class="bi bi-pencil"></i> Edit Logo</h4>
        </div>
      </div>
    </div>
  </div>
  
  <div class="row mt-3">
    <div class="col-md-8 mx-auto">
      <div class="card">
        <div class="card-body">
          <% if (error && error.length > 0) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>
          
          <form action="/admin/logos/<%= logo.id %>" method="POST" id="editForm">
            <div class="mb-3">
              <label for="type" class="form-label">Logo Type <span class="text-danger">*</span></label>
              <select class="form-select" id="type" name="type" required>
                <option value="news" <%= logo.type === 'news' ? 'selected' : '' %>>News Logo</option>
                <option value="brands" <%= logo.type === 'brands' ? 'selected' : '' %>>Brands Logo</option>
              </select>
            </div>
            
            <div class="mb-3">
              <label class="form-label">Current Logo</label>
              <div class="text-center p-3 border rounded bg-light">
                <img src="<%= logo.getImageUrl() %>" alt="<%= logo.title %>" style="max-width: 200px; max-height: 150px; object-fit: contain;">
              </div>
            </div>
            
            <div class="mb-3">
              <label for="link" class="form-label">Link URL <span class="text-danger">*</span></label>
              <input type="url" class="form-control" id="link" name="link" value="<%= logo.link %>" placeholder="https://example.com" required>
              <small class="text-muted">Full URL including http:// or https://</small>
            </div>
            
            <div class="mb-3">
              <label for="title" class="form-label">Title/Alt Text</label>
              <input type="text" class="form-control" id="title" name="title" value="<%= logo.title || '' %>" placeholder="Logo title or description">
            </div>
            
            <div class="mb-3">
              <label for="order" class="form-label">Display Order</label>
              <input type="number" class="form-control" id="order" name="order" value="<%= logo.order %>" min="0">
            </div>
            
            <div class="mb-3">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="status" name="status" <%= logo.status ? 'checked' : '' %>>
                <label class="form-check-label" for="status">Active</label>
              </div>
            </div>
            
            <hr>
            
            <div class="d-flex align-items-center">
              <button type="submit" class="btn btn-primary" id="submitBtn">
                <i class="bi bi-save"></i> Save Changes
              </button>
              
              <div id="loadingSpinner" class="ms-3" style="display: none;">
                <div class="spinner-border spinner-border-sm text-primary" role="status">
                  <span class="visually-hidden">Loading...</span>
                </div>
                <span class="ms-2">Saving...</span>
              </div>
              
              <a href="/admin/logos" class="btn btn-secondary ms-auto">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
  
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const editForm = document.getElementById('editForm');
      const submitBtn = document.getElementById('submitBtn');
      const loadingSpinner = document.getElementById('loadingSpinner');
  
      // Form submission with loading state
      editForm.addEventListener('submit', function() {
        submitBtn.disabled = true;
        loadingSpinner.style.display = 'inline-block';
      });
    });
  </script>