<%- contentFor('title') %>
<%- contentFor('head') %>
<%- contentFor('body') %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <div class="row align-items-center">
          <div class="col-sm-6">
            <h4><i class="bi bi-images"></i> Logo Management</h4>
          </div>
          <div class="col-sm-6">
            <div class="d-flex justify-content-end gap-2">
              <a href="/admin/logos/upload" class="btn btn-primary">
                <i class="bi bi-cloud-upload"></i> Upload Logo
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Flash Messages -->
<% if (success && success.length > 0) { %>
<div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
  <i class="bi bi-check-circle"></i> <%= success %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %> <% if (error && error.length > 0) { %>
<div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
  <i class="bi bi-exclamation-triangle"></i> <%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<!-- Stats Cards -->
<div class="row mt-3">
  <div class="col-md-3">
    <div class="card bg-primary text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">Total Logos</h6>
            <h2 class="mb-0"><%= stats.total %></h2>
          </div>
          <i class="bi bi-images fs-1"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-info text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">News Logos</h6>
            <h2 class="mb-0"><%= stats.news %></h2>
          </div>
          <i class="bi bi-newspaper fs-1"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-success text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">Brands Logos</h6>
            <h2 class="mb-0"><%= stats.brands %></h2>
          </div>
          <i class="bi bi-tag fs-1"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-warning text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">Active / Inactive</h6>
            <h2 class="mb-0"><%= stats.active %> / <%= stats.inactive %></h2>
          </div>
          <i class="bi bi-toggle-on fs-1"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filter Tabs -->
<div class="row mt-3">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <ul class="nav nav-tabs">
          <li class="nav-item">
            <a
              class="nav-link <%= currentType === 'all' ? 'active' : '' %>"
              href="/admin/logos?type=all"
              >All Logos</a
            >
          </li>
          <li class="nav-item">
            <a
              class="nav-link <%= currentType === 'news' ? 'active' : '' %>"
              href="/admin/logos?type=news"
            >
              <i class="bi bi-newspaper"></i> News Logos
            </a>
          </li>
          <li class="nav-item">
            <a
              class="nav-link <%= currentType === 'brands' ? 'active' : '' %>"
              href="/admin/logos?type=brands"
            >
              <i class="bi bi-tag"></i> Brands Logos
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- Bulk Actions -->
<div class="row mt-3">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="d-flex gap-2 align-items-center">
          <button
            type="button"
            class="btn btn-danger"
            id="bulkDeleteBtn"
            style="display: none"
          >
            <i class="bi bi-trash"></i> Delete Selected
          </button>
          <select
            class="form-select w-auto"
            id="bulkStatusSelect"
            style="display: none"
          >
            <option value="true">Activate</option>
            <option value="false">Deactivate</option>
          </select>
          <button
            type="button"
            class="btn btn-info"
            id="bulkUpdateStatusBtn"
            style="display: none"
          >
            <i class="bi bi-check-circle"></i> Update Status
          </button>
          <span class="text-muted" id="selectedCount"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Logos Grid -->
<div class="row mt-3">
  <% if (logos && logos.length > 0) { %> <% logos.forEach(logo => { %>
  <div class="col-md-3 mb-4">
    <div class="card h-100 logo-card">
      <div class="position-relative">
        <input
          type="checkbox"
          class="form-check-input position-absolute top-0 start-0 m-2 logo-checkbox"
          value="<%= logo.id %>"
          style="z-index: 10"
        />
        <span
          class="position-absolute top-0 end-0 m-2 badge bg-<%= logo.status ? 'success' : 'secondary' %>"
        >
          <%= logo.status ? 'Active' : 'Inactive' %>
        </span>
        <span class="position-absolute bottom-0 end-0 m-2 badge bg-info">
          <%= logo.type %>
        </span>
        <a href="<%= logo.link %>" target="_blank">
          <img
            src="<%= logo.getImageUrl() %>"
            class="card-img-top"
            alt="<%= logo.title || 'Logo' %>"
            style="height: 150px; object-fit: contain; padding: 10px"
          />
        </a>
      </div>
      <div class="card-body">
        <h6
          class="card-title text-truncate"
          title="<%= logo.title || 'Untitled' %>"
        >
          <%= logo.title || 'Untitled' %>
        </h6>
        <p class="card-text small text-muted mb-1">
          <i class="bi bi-link"></i>
          <a
            href="<%= logo.link %>"
            target="_blank"
            class="text-truncate d-block"
            ><%= logo.link %></a
          >
        </p>
        <p class="card-text small text-muted mb-1">
          <i class="bi bi-sort-numeric-down"></i> Order: <%= logo.order %>
        </p>
        <p class="card-text small text-muted">
          <i class="bi bi-calendar"></i> <%= new
          Date(logo.createdAt).toLocaleDateString() %>
        </p>
      </div>
      <div class="card-footer bg-transparent">
        <div class="btn-group w-100">
          <a
            href="/admin/logos/<%= logo.id %>/edit"
            class="btn btn-sm btn-outline-primary"
          >
            <i class="bi bi-pencil"></i> Edit
          </a>
          <button
            type="button"
            class="btn btn-sm btn-outline-<%= logo.status ? 'warning' : 'success' %> toggle-status"
            data-id="<%= logo.id %>"
          >
            <i class="bi bi-toggle-<%= logo.status ? 'on' : 'off' %>"></i>
            <%= logo.status ? 'Deactivate' : 'Activate' %>
          </button>
          <button
            type="button"
            class="btn btn-sm btn-outline-danger delete-logo"
            data-id="<%= logo.id %>"
          >
            <i class="bi bi-trash"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
  <% }); %> <% } else { %>
  <div class="col-12">
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="bi bi-images fs-1 text-muted"></i>
        <h5 class="mt-3">No logos found</h5>
        <p class="text-muted">Get started by uploading your first logo</p>
        <a href="/admin/logos/upload" class="btn btn-primary">
          <i class="bi bi-cloud-upload"></i> Upload Logo
        </a>
      </div>
    </div>
  </div>
  <% } %>
</div>

<script>
  $(document).ready(function () {
    let selectedLogos = [];

    // Toggle status
    $(".toggle-status").on("click", function () {
      const logoId = $(this).data("id");
      const btn = $(this);

      $.ajax({
        url: "/admin/logos/" + logoId + "/toggle-status",
        method: "POST",
        success: function (response) {
          if (response.success) {
            window.location.reload();
          } else {
            alert(response.error || "Failed to toggle status");
          }
        },
        error: function () {
          alert("Failed to toggle status");
        },
      });
    });

    // Individual delete
    $(".delete-logo").on("click", function () {
      const logoId = $(this).data("id");

      if (confirm("Are you sure you want to delete this logo?")) {
        $.ajax({
          url: "/admin/logos/" + logoId,
          method: "DELETE",
          success: function (response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || "Failed to delete logo");
            }
          },
          error: function () {
            alert("Failed to delete logo");
          },
        });
      }
    });

    // Handle checkbox selection
    $(".logo-checkbox").on("change", function () {
      const logoId = $(this).val();

      if ($(this).is(":checked")) {
        selectedLogos.push(logoId);
      } else {
        selectedLogos = selectedLogos.filter((id) => id !== logoId);
      }

      // Show/hide bulk action buttons
      if (selectedLogos.length > 0) {
        $("#bulkDeleteBtn").show();
        $("#bulkStatusSelect").show();
        $("#bulkUpdateStatusBtn").show();
        $("#selectedCount").text(selectedLogos.length + " logo(s) selected");
      } else {
        $("#bulkDeleteBtn").hide();
        $("#bulkStatusSelect").hide();
        $("#bulkUpdateStatusBtn").hide();
        $("#selectedCount").text("");
      }
    });

    // Bulk delete
    $("#bulkDeleteBtn").on("click", function () {
      if (selectedLogos.length === 0) return;

      if (
        confirm(
          `Are you sure you want to delete ${selectedLogos.length} logo(s)?`
        )
      ) {
        $.ajax({
          url: "/admin/logos/bulk-delete",
          method: "POST",
          data: { ids: selectedLogos },
          success: function (response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || "Failed to delete logos");
            }
          },
          error: function () {
            alert("Failed to delete logos");
          },
        });
      }
    });

    // Bulk update status
    $("#bulkUpdateStatusBtn").on("click", function () {
      if (selectedLogos.length === 0) return;

      const status = $("#bulkStatusSelect").val();

      if (
        confirm(
          `Are you sure you want to ${
            status === "true" ? "activate" : "deactivate"
          } ${selectedLogos.length} logo(s)?`
        )
      ) {
        $.ajax({
          url: "/admin/logos/bulk-update-status",
          method: "POST",
          data: {
            ids: selectedLogos,
            status: status,
          },
          success: function (response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || "Failed to update logos");
            }
          },
          error: function () {
            alert("Failed to update logos");
          },
        });
      }
    });
  });
</script>

<style>
  .logo-card {
    transition: transform 0.2s;
  }
  .logo-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }
  .logo-checkbox {
    width: 20px;
    height: 20px;
    cursor: pointer;
  }
  .card-img-top {
    background: #f8f9fa;
  }
</style>
