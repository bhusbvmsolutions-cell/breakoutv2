<%- contentFor('title') %>
View Image

<%- contentFor('head') %>
<%- contentFor('body') %>


<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h4><i class="bi bi-eye"></i> View Image</h4>
      </div>
    </div>
  </div>
</div>

<div class="row mt-3">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <div class="card-body">
        <div class="text-center mb-4">
          <img src="<%= image.url %>" alt="<%= image.altText %>" class="img-fluid" style="max-height: 400px;">
        </div>
        
        <table class="table">
          <tr>
            <th style="width: 150px;">ID:</th>
            <td><%= image.id %></td>
          </tr>
          <tr>
            <th>Filename:</th>
            <td><%= image.filename %></td>
          </tr>
          <tr>
            <th>Title:</th>
            <td><%= image.title || '-' %></td>
          </tr>
          <tr>
            <th>Alt Text:</th>
            <td><%= image.altText || '-' %></td>
          </tr>
          <tr>
            <th>Size:</th>
            <td><%= (image.size / 1024).toFixed(2) %> KB</td>
          </tr>
          <tr>
            <th>Dimensions:</th>
            <td><%= image.width %> x <%= image.height %></td>
          </tr>
          <tr>
            <th>MIME Type:</th>
            <td><%= image.mimeType %></td>
          </tr>
          <tr>
            <th>Uploaded:</th>
            <td><%= new Date(image.createdAt).toLocaleString() %></td>
          </tr>
          <tr>
            <th>Last Updated:</th>
            <td><%= new Date(image.updatedAt).toLocaleString() %></td>
          </tr>
          <!-- <tr>
            <th>File Path:</th>
            <td><small class="text-muted"><%= image.path %></small></td>
          </tr> -->
          <tr>
            <th>URL:</th>
            <td><small class="text-muted"><%= image.url %></small></td>
          </tr>
        </table>
        
        <hr>
        <div class="d-flex justify-content-between">
          <a href="/admin/images" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
          </a>
          <button type="button" class="btn btn-danger" id="deleteBtn">
            <i class="bi bi-trash"></i> Delete Image
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  $('#deleteBtn').on('click', function() {
    if (confirm('Are you sure you want to delete this image?')) {
      $.ajax({
        url: '/admin/images/<%= image.id %>',
        method: 'DELETE',
        success: function(response) {
          if (response.success) {
            window.location.href = '/admin/images';
          } else {
            alert(response.error || 'Failed to delete image');
          }
        },
        error: function() {
          alert('Failed to delete image');
        }
      });
    }
  });
</script>