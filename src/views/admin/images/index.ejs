<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <div class="row align-items-center">
          <div class="col-sm-6">
            <h4><i class="bi bi-images"></i> Image Management</h4>
          </div>
          <div class="col-sm-6">
            <div class="d-flex justify-content-end gap-2">
              <a href="/admin/images/upload" class="btn btn-primary">
                <i class="bi bi-cloud-upload"></i> Upload Image
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mt-3">
  <div class="col-md-4">
    <div class="card bg-primary text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">Total Images</h6>
            <h2 class="mb-0"><%= stats.totalImages %></h2>
          </div>
          <i class="bi bi-images fs-1"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card bg-success text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">Total Size</h6>
            <h2 class="mb-0"><%= stats.totalSize %></h2>
          </div>
          <i class="bi bi-hdd-stack fs-1"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card bg-info text-white">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title">File Types</h6>
            <h2 class="mb-0"><%= stats.imagesByType.length %></h2>
          </div>
          <i class="bi bi-file-earmark-image fs-1"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Search and Filter -->
<div class="row mt-3">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <form action="/admin/images" method="GET" class="row g-3">
          <div class="col-md-8">
            <div class="input-group">
              <input type="text" class="form-control" name="search" placeholder="Search by filename, title, or alt text..." value="<%= search %>">
              <button class="btn btn-primary" type="submit">
                <i class="bi bi-search"></i> Search
              </button>
            </div>
          </div>
          <div class="col-md-4 text-end">
            <button type="button" class="btn btn-danger" id="bulkDeleteBtn" style="display: none;">
              <i class="bi bi-trash"></i> Delete Selected
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Images Grid -->
<div class="row mt-3">
  <% if (images && images.length > 0) { %>
    <% images.forEach(image => { %>
      <div class="col-md-3 mb-4">
        <div class="card h-100 image-card">
          <div class="position-relative">
            <input type="checkbox" class="form-check-input position-absolute top-0 start-0 m-2 image-checkbox" value="<%= image.id %>" style="z-index: 10;">
            <a href="/admin/images/<%= image.id %>">
              <img src="<%= image.url %>" class="card-img-top" alt="<%= image.altText %>" style="height: 200px; object-fit: cover;">
            </a>
          </div>
          <div class="card-body">
            <h6 class="card-title text-truncate" title="<%= image.title %>"><%= image.title %></h6>
            <p class="card-text small text-muted mb-1">
              <i class="bi bi-file-earmark"></i> <%= image.filename %>
            </p>
            <p class="card-text small text-muted mb-1">
              <i class="bi bi-calendar"></i> <%= new Date(image.createdAt).toLocaleDateString() %>
            </p>
            <p class="card-text small text-muted mb-1">
              <i class="bi bi-arrows-angle-expand"></i> <%= image.width %>x<%= image.height %>
            </p>
            <p class="card-text small text-muted">
              <i class="bi bi-hdd"></i> <%= (image.size / 1024).toFixed(2) %> KB
            </p>
          </div>
          <div class="card-footer bg-transparent">
            <div class="btn-group w-100">
              <a href="/admin/images/<%= image.id %>" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-eye"></i> View
              </a>
              <button type="button" class="btn btn-sm btn-outline-danger delete-image" data-id="<%= image.id %>">
                <i class="bi bi-trash"></i> Delete
              </button>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col-12">
      <div class="card">
        <div class="card-body text-center py-5">
          <i class="bi bi-images fs-1 text-muted"></i>
          <h5 class="mt-3">No images found</h5>
          <p class="text-muted">Get started by uploading your first image</p>
          <a href="/admin/images/upload" class="btn btn-primary">
            <i class="bi bi-cloud-upload"></i> Upload Image
          </a>
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (pagination.pages > 1) { %>
  <nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.page - 1 %><%= search ? '&search=' + search : '' %>">Previous</a>
      </li>
      
      <% for (let i = 1; i <= pagination.pages; i++) { %>
        <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %>"><%= i %></a>
        </li>
      <% } %>
      
      <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.page + 1 %><%= search ? '&search=' + search : '' %>">Next</a>
      </li>
    </ul>
  </nav>
<% } %>

<script>
  $(document).ready(function() {
    // Individual delete
    $('.delete-image').on('click', function() {
      const imageId = $(this).data('id');
      
      if (confirm('Are you sure you want to delete this image?')) {
        $.ajax({
          url: '/admin/images/' + imageId,
          method: 'DELETE',
          success: function(response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || 'Failed to delete image');
            }
          },
          error: function() {
            alert('Failed to delete image');
          }
        });
      }
    });

    // Bulk delete
    let selectedImages = [];
    
    $('.image-checkbox').on('change', function() {
      const imageId = $(this).val();
      
      if ($(this).is(':checked')) {
        selectedImages.push(imageId);
      } else {
        selectedImages = selectedImages.filter(id => id !== imageId);
      }
      
      $('#bulkDeleteBtn').toggle(selectedImages.length > 0);
    });

    $('#bulkDeleteBtn').on('click', function() {
      if (selectedImages.length === 0) return;
      
      if (confirm(`Are you sure you want to delete ${selectedImages.length} image(s)?`)) {
        $.ajax({
          url: '/admin/images/bulk-delete',
          method: 'POST',
          data: { imageIds: selectedImages },
          success: function(response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || 'Failed to delete images');
            }
          },
          error: function() {
            alert('Failed to delete images');
          }
        });
      }
    });
  });
</script>

<style>
  .image-card {
    transition: transform 0.2s;
  }
  .image-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }
  .image-checkbox {
    width: 20px;
    height: 20px;
    cursor: pointer;
  }
</style>