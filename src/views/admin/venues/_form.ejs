<% if (venue) { %>
  <input type="hidden" name="_method" value="PUT">
<% } %>

<div class="row g-3">
  <div class="col-md-6">
    <label class="form-label">Name *</label>
    <input type="text" name="name" id="name" class="form-control" value="<%= venue?.name || '' %>" required>
  </div>
  <div class="col-md-6">
    <label class="form-label">Slug</label>
    <input type="text" name="slug" id="slug" class="form-control" value="<%= venue?.slug || '' %>">
    <div class="form-text small">Leave blank to auto-generate</div>
  </div>
  <div class="col-md-4">
    <label class="form-label">Price</label>
    <input type="text" name="price" class="form-control" value="<%= venue?.price || '' %>">
  </div>
  <div class="col-md-4">
    <label class="form-label">Rating (0-5)</label>
    <input type="number" step="0.1" name="rating" class="form-control" value="<%= venue?.rating || '' %>" min="0" max="5">
  </div>
  <div class="col-md-4">
    <label class="form-label">Capacity</label>
    <input type="text" name="capacity" class="form-control" value="<%= venue?.capacity || '' %>" placeholder="50-100">
  </div>

  <!-- Cover Image -->
  <div class="col-md-6">
    <label class="form-label">Cover Image</label>
    <input type="file" name="cover_image" class="form-control" accept="image/*">
    <% if (venue?.cover_image) { %>
    <img src="<%= venue.cover_image %>" class="img-thumbnail mt-2" style="max-width:120px;">
    <% } %>
  </div>
  <div class="col-md-6">
    <div class="form-check mt-4">
      <input type="checkbox" name="is_featured" class="form-check-input" value="on" <%= venue?.is_featured ? 'checked' : '' %>>
      <label class="form-check-label">Is Featured</label>
    </div>
  </div>

  <div class="col-md-4">
    <label class="form-label">Time</label>
    <input type="text" name="time" class="form-control" value="<%= venue?.time || '' %>">
  </div>
  <div class="col-md-4">
    <label class="form-label">Phone</label>
    <input type="text" name="phone" class="form-control" value="<%= venue?.phone || '' %>">
  </div>
  <div class="col-md-4">
    <label class="form-label">Website</label>
    <input type="url" name="website" class="form-control" value="<%= venue?.website || '' %>">
  </div>
  <div class="col-12">
    <label class="form-label">Address</label>
    <input type="text" name="address" class="form-control" value="<%= venue?.address || '' %>">
  </div>
  <div class="col-12">
    <label class="form-label">Google Map URL</label>
    <input type="text" name="google_map" class="form-control" value="<%= venue?.google_map || '' %>">
  </div>
  <div class="col-md-6">
    <label class="form-label">Locations (Multi-select)</label>
    <select name="locations[]" class="form-control select2-multiple" multiple>
      <% locations.forEach(loc => { %>
      <option value="<%= loc.id %>" <%= venue?.locations?.some(l => l.id == loc.id) ? 'selected' : '' %>><%= loc.title %></option>
      <% }); %>
    </select>
    <div class="form-text small">Select one or more locations where this venue is available</div>
  </div>

  <!-- Multi-selects -->
  <div class="col-md-6">
    <label class="form-label">Categories</label>
    <select name="categories[]" class="form-control select2-multiple" multiple>
      <% categories.forEach(cat => { %>
      <option value="<%= cat.id %>" <%= venue?.categories?.some(c => c.id == cat.id) ? 'selected' : '' %>><%= cat.name %></option>
      <% }); %>
    </select>
  </div>
  <div class="col-md-6">
    <label class="form-label">Experience Types</label>
    <select name="experienceTypes[]" class="form-control select2-multiple" multiple>
      <% experienceTypes.forEach(et => { %>
      <option value="<%= et.id %>" <%= venue?.experienceTypes?.some(e => e.id == et.id) ? 'selected' : '' %>><%= et.name %></option>
      <% }); %>
    </select>
  </div>
  <div class="col-md-6">
    <label class="form-label">Experience Looking For</label>
    <select name="lookingFor[]" class="form-control select2-multiple" multiple>
      <% lookingFor.forEach(lf => { %>
      <option value="<%= lf.id %>" <%= venue?.lookingFor?.some(l => l.id == lf.id) ? 'selected' : '' %>><%= lf.name %></option>
      <% }); %>
    </select>
  </div>
  <div class="col-md-6">
    <label class="form-label">Party Types</label>
    <select name="partyTypes[]" class="form-control select2-multiple" multiple>
      <% partyTypes.forEach(pt => { %>
      <option value="<%= pt.id %>" <%= venue?.partyTypes?.some(p => p.id == pt.id) ? 'selected' : '' %>><%= pt.name %></option>
      <% }); %>
    </select>
  </div>
  <div class="col-md-6">
    <label class="form-label">Suitable Times</label>
    <select name="suitableTimes[]" class="form-control select2-multiple" multiple>
      <% suitableTimes.forEach(st => { %>
      <option value="<%= st.id %>" <%= venue?.suitableTimes?.some(s => s.id == st.id) ? 'selected' : '' %>><%= st.name %></option>
      <% }); %>
    </select>
  </div>
  <div class="col-md-6">
    <label class="form-label">Budget Ranges</label>
    <select name="budgetRanges[]" class="form-control select2-multiple" multiple>
      <% budgetRanges.forEach(br => { %>
      <option value="<%= br.id %>" <%= venue?.budgetRanges?.some(b => b.id == br.id) ? 'selected' : '' %>><%= br.name %></option>
      <% }); %>
    </select>
  </div>

  <!-- Gallery Images (Repeater) -->
  <div class="col-12 py-4">
    <h5 class="form-label bg-primary text-white p-2 rounded card-header-custom">Gallery Images</h5>
    <div id="galleryContainer">
      <% if (venue?.galleryImages && venue.galleryImages.length) {
          venue.galleryImages.forEach((img, idx) => { %>
      <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
        <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
        <div class="row g-2">
          <div class="col-12">
            <input type="file" name="gallery_images[<%= idx %>][image_file]" class="form-control" accept="image/*">
            <% if (img.image) { %>
            <img src="<%= img.image %>" class="img-thumbnail mt-2" style="max-width:80px;">
            <% } %>
            <input type="hidden" name="gallery_images[<%= idx %>][image]" value="<%= img.image || '' %>">
          </div>
        </div>
      </div>
      <% });
        } else { %>
      <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
        <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
        <div class="row g-2">
          <div class="col-12">
            <input type="file" name="gallery_images[0][image_file]" class="form-control" accept="image/*">
            <img class="img-thumbnail mt-2" style="display:none;">
            <input type="hidden" name="gallery_images[0][image]" value="">
          </div>
        </div>
      </div>
      <% } %>
    </div>
    <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-gallery-image"><i class="bx bx-plus"></i> Add Image</button>
  </div>

  <!-- Content Sections (Repeater) -->
  <div class="col-12 py-4">
    <h5 class="form-label bg-primary text-white p-2 rounded card-header-custom">Content Sections</h5>
    <p class="text-muted small mb-2">Add multiple content sections with heading (optional) and rich text content</p>
    <div id="contentSectionsContainer">
      <% if (venue?.contentSections && venue.contentSections.length > 0) {
          venue.contentSections.forEach((section, idx) => { %>
      <div class="repeater-item bg-light p-3 rounded mb-3 position-relative" data-section-id="<%= idx %>">
        <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">Heading (Optional)</label>
            <input type="text" name="content_sections[<%= idx %>][heading]" class="form-control" value="<%= section.heading || '' %>" placeholder="Section heading">
          </div>
          <div class="col-12">
            <label class="form-label">Content *</label>
            <textarea name="content_sections[<%= idx %>][content]" class="form-control summernote-init" rows="5"><%= section.content || '' %></textarea>
          </div>
          <div class="col-12">
            <div class="form-check">
              <input type="checkbox" name="content_sections[<%= idx %>][isActive]" class="form-check-input" value="on" <%= section.isActive !== false ? 'checked' : '' %>>
              <label class="form-check-label small">Active</label>
              </div>
          </div>
        </div>
      </div>
      <% });
      } else { %>
      <div class="repeater-item bg-light p-3 rounded mb-3 position-relative" data-section-id="0">
        <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">Heading (Optional)</label>
            <input type="text" name="content_sections[0][heading]" class="form-control" placeholder="Section heading">
          </div>
          <div class="col-12">
            <label class="form-label">Content *</label>
            <textarea name="content_sections[0][content]" class="form-control summernote-init" rows="5"></textarea>
          </div>
          <div class="col-12">
            <div class="form-check">
              <input type="checkbox" name="content_sections[0][isActive]" class="form-check-input" value="on" checked>
              <label class="form-check-label small">Active</label>
            </div>
          </div>
        </div>
      </div>
      <% } %>
    </div>
    <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-content-section">
      <i class="bx bx-plus"></i> Add Content Section
    </button>
  </div>

  <div class="col-12">
    <div class="form-check">
      <input type="checkbox" name="isActive" class="form-check-input" value="on" <%= venue?.isActive !== false ? 'checked' : '' %>>
      <label class="form-check-label">Active</label>
    </div>
  </div>
</div>

<button type="submit" class="btn btn-primary mt-3"><i class="bx bx-save me-1"></i> <%= venue ? 'Update Venue' : 'Create Venue' %></button>

<script>
  // Function to initialize Summernote on a textarea
  function initSummernote(textarea) {
    if (!textarea || textarea.length === 0) return;
    
    // Check if Summernote is already initialized by looking for the .note-editor container
    if (textarea.next('.note-editor').length === 0) {
      textarea.summernote({
        placeholder: 'Write your content here...',
        tabsize: 2,
        height: 200,
        fontNames: [
          'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New',
          'Georgia', 'Tahoma', 'Times New Roman', 'Verdana',
          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontNamesIgnoreCheck: [
          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontSizes: ['8', '10', '12', '14', '16', '18', '20', '24', '28', '32', '36', '48', '64'],
        toolbar: [
          ['style', ['style']],
          ['font', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
          ['fontname', ['fontname']],
          ['fontsize', ['fontsize']],
          ['color', ['forecolor', 'backcolor']],
          ['para', ['ul', 'ol', 'paragraph', 'height']],
          ['insert', ['link', 'picture', 'video', 'table']],
          ['view', ['fullscreen', 'codeview']]
        ],
        lineHeights: ['0.8', '1.0', '1.2', '1.5', '2.0', '3.0']
      });
    }
  }

  $(document).ready(function() {
    // Initialize Select2 on multi-selects
    $('.select2-multiple').select2({
      theme: 'bootstrap-5',
      width: '100%',
      placeholder: 'Select options...',
      allowClear: true
    });

    // Initialize Summernote for all elements with class 'summernote-init'
    $('.summernote-init').each(function() {
      initSummernote($(this));
    });

    // Slug generation
    $('#name').on('blur', function() {
      if ($('#slug').val() === '') {
        let slug = $(this).val().toLowerCase().replace(/[^\w\s-]/g, '').replace(/[\s_-]+/g, '-').replace(/^-+|-+$/g, '');
        $('#slug').val(slug);
      }
    });

    // Image preview for file inputs
    function setupImagePreview(inputElem, previewElem) {
      inputElem.on('change', function() {
        const file = this.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) {
            previewElem.attr('src', e.target.result).show();
          };
          reader.readAsDataURL(file);
        } else {
          previewElem.hide().attr('src', '');
        }
      });
    }
    
    $('input[type="file"]').each(function() {
      const preview = $(this).next('.img-thumbnail');
      if (preview.length) setupImagePreview($(this), preview);
    });

    // Gallery repeater
    let galleryIndex = $('#galleryContainer .repeater-item').length;
    $('.add-gallery-image').click(function() {
      const newIndex = galleryIndex++;
      const newItem = `
        <div class="repeater-item bg-light p-2 rounded mb-2 position-relative">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-2">
            <div class="col-12">
              <input type="file" name="gallery_images[${newIndex}][image_file]" class="form-control" accept="image/*">
              <img class="img-thumbnail mt-2" style="display:none;">
              <input type="hidden" name="gallery_images[${newIndex}][image]" value="">
            </div>
          </div>
        </div>
      `;
      $('#galleryContainer').append(newItem);
      const fileInput = $(`#galleryContainer .repeater-item:last input[type="file"]`);
      const preview = fileInput.next('.img-thumbnail');
      setupImagePreview(fileInput, preview);
    });

    // Content Sections repeater
    let contentSectionIndex = $('#contentSectionsContainer .repeater-item').length;
    $('.add-content-section').click(function() {
      const newIndex = contentSectionIndex++;
      const newItem = `
        <div class="repeater-item bg-light p-3 rounded mb-3 position-relative" data-section-id="${newIndex}">
          <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Heading (Optional)</label>
              <input type="text" name="content_sections[${newIndex}][heading]" class="form-control" placeholder="Section heading">
            </div>
            <div class="col-12">
              <label class="form-label">Content *</label>
              <textarea name="content_sections[${newIndex}][content]" class="form-control summernote-init" rows="5" required></textarea>
            </div>
            <div class="col-12">
              <div class="form-check">
                <input type="checkbox" name="content_sections[${newIndex}][isActive]" class="form-check-input" value="on" checked>
                <label class="form-check-label small">Active</label>
              </div>
            </div>
          </div>
        </div>
      `;
      $('#contentSectionsContainer').append(newItem);
      
      // Initialize Summernote for the new textarea
      const newTextarea = $(`#contentSectionsContainer .repeater-item:last textarea`);
      initSummernote(newTextarea);
    });
  });

  function removeItem(btn) {
    $(btn).closest('.repeater-item').remove();
  }
</script>