<%- contentFor('title') %> Pricing Package Categories
<%- contentFor('head') %>
<style>
  body { background: #f5f7fb; }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .categories-grid-empty {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100%, 1fr));
    gap: 1rem;
  }
  .category-card {
    background: #fff;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 0px 10px rgba(0,0,0,0.6) !important;
    transition: all 0.2s;
  }
  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.8) !important;
  }
  .category-card-content {
    padding: 0.75rem;
  }
  .category-card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: #2c3e50;
  }
  .category-card-slug {
    font-size: 0.7rem;
    color: #6c757d;
    margin-bottom: 0.5rem;
    word-break: break-all;
  }
  .category-card-status {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
    font-weight: 500;
  }
  .category-card-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }
  .btn-sm {
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
  }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-3">
  <div class="row mb-3 align-items-center">
    <div class="col-md-8">
      <h4 class="mb-0 fw-bold">Pricing Package Categories</h4>
      <p class="text-muted small mb-0">Manage categories for pricing packages</p>
    </div>
    <div class="col-md-4 text-md-end mt-2 mt-md-0">
      <a href="/admin/pricing/category/create" class="btn btn-primary btn-sm">
        <i class="bx bx-plus-circle me-1"></i> Add New Category
      </a>
    </div>
  </div>
  
  <% if (categories && categories.length > 0) { %>    
  <div id="categoriesContainer" class="categories-grid">
      <% categories.forEach(cat => { %>
      <div class="category-card">
        <div class="category-card-content">
          <h5 class="category-card-title"><%= cat.name %></h5>
          <div class="category-card-slug"><i class="bx bx-link-alt me-1"></i> <%= cat.slug %></div>
          <div class="mb-1">
            <span class="category-card-status badge <%= cat.isActive ? 'bg-success' : 'bg-secondary' %>">
              <%= cat.isActive ? 'Active' : 'Inactive' %>
            </span>
          </div>
          <div class="category-card-actions">
            <a href="/admin/pricing/category/edit/<%= cat.id %>" class="btn btn-sm btn-warning">
              <i class="bx bx-edit"></i> Edit
            </a>
            <button class="btn btn-sm btn-danger delete-category" data-id="<%= cat.id %>">
              <i class="bx bx-trash"></i> Delete
            </button>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } else { %>

      <div id="categoriesContainer" class="categories-grid-empty text-center">
        <div class="category-card bg-primar">
          <div class="category-card-content">
            <h5 class="category-card-title mb-3">No Categories Found</h5>
            <div class="text-center">
              <a href="/admin/pricing/category/create" class="btn btn-primary">
                <i class="bx bx-plus"></i> Add First Category
              </a>
            </div>
          </div>
        </div>
      </div>
      <% } %>

</div>

<%- contentFor('js') %>
<script>
  document.querySelectorAll('.delete-category').forEach(btn => {
    btn.addEventListener('click', async e => {
      if (!confirm('Delete this category? This action cannot be undone.')) return;
      const id = btn.dataset.id;
      const res = await fetch(`/admin/pricing/category/delete/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.message);
    });
  });
</script>