<%- contentFor('title') %> Edit Pricing Package
<%- contentFor('head') %>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<style>/* same as create */</style>

<%- contentFor('body') %>
<div class="container py-3">
  <div class="form-container">
    <div class="card shadow-sm border-0">
      <div class="card-header-custom rounded-top">
        <h4><i class="bx bx-edit me-2"></i> Edit Pricing Package</h4>
        <p class="mb-0">Update pricing package details</p>
      </div>
      <div class="card-body p-3">
        <form action="/admin/pricing/packages/update/<%= package.id %>" method="POST">
          <%- include('_form', { package: package, categories: categories }); %>
        </form>
      </div>
    </div>
  </div>
</div>

<%- contentFor('js') %>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>