<div class="row">
    <div class="col-12 col-lg-12">
      <div class="card">
        <div class="card-header">
          <h4><i class="bi bi-people"></i> User Management</h4>
        </div>
      </div>
    </div>
  </div>
  
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle"></i> <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle"></i> <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  
  <div class="card">
    <div class="card-header">
      <div class="row align-items-center">
        <div class="col-sm-6">
          <h5 class="mb-0">All Users</h5>
        </div>
        <div class="col-sm-6">
          <div class="d-flex justify-content-end gap-2">
            <form action="/admin/users" method="GET" class="d-flex">
              <input type="text" name="search" class="form-control form-control-sm me-2" placeholder="Search users..." value="<%= search || '' %>" style="width: 200px;">
              <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-search fs-6"></i>
              </button>
            </form>
            <% if (canCreateUser) { %>
              <a href="/admin/users/create" class="btn btn-sm btn-success">
                <i class="bi bi-plus"></i> Add User
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>User</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Roles</th>
              <th>Status</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (users && users.length > 0) { %>
              <% users.forEach(userItem => { %>
                <tr>
                  <td><%= userItem.id %></td>
                  <td>
                    <div class="d-flex align-items-center">
                      <% if (userItem.avatar) { %>
                        <img src="<%= userItem.avatar %>" class="rounded-circle" width="40" height="40" alt="Avatar">
                      <% } else { %>
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white" 
                             style="width: 40px; height: 40px; font-size: 16px;">
                          <%= (userItem.firstName?.charAt(0) || '').toUpperCase() %><%= (userItem.lastName?.charAt(0) || '').toUpperCase() %>
                        </div>
                      <% } %>
                      <div class="ms-2">
                        <h6 class="mb-0"><%= userItem.firstName || '' %> <%= userItem.lastName || '' %></h6>
                        <small class="text-muted">@<%= userItem.username || 'N/A' %></small>
                      </div>
                    </div>
                  </td>
                  <td><%= userItem.email %></td>
                  <td><%= userItem.phone || 'N/A' %></td>
                  <td>
                    <% if (userItem.roles && userItem.roles.length > 0) { %>
                      <% userItem.roles.forEach(role => { %>
                        <span class="badge bg-info"><%= role.displayName %></span>
                      <% }); %>
                    <% } else { %>
                      <span class="badge bg-secondary">No Role</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (userItem.isActive) { %>
                      <span class="badge bg-success">Active</span>
                    <% } else { %>
                      <span class="badge bg-danger">Inactive</span>
                    <% } %>
                  </td>
                  <td><%= new Date(userItem.createdAt).toLocaleDateString() %></td>
                  <td>
                    <div class="btn-group btn-group-sm">
                      <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#viewUserModal<%= userItem.id %>">
                        <i class="bi bi-eye"></i>
                      </button>
                      
                      <% if (userItem.canManage) { %>
                        <a href="/admin/users/<%= userItem.id %>/edit" class="btn btn-outline-warning">
                          <i class="bi bi-pencil"></i>
                        </a>
                        
                        <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#assignRolesModal<%= userItem.id %>">
                          <i class="bi bi-shield"></i>
                        </button>
                        
                        <% if (userItem.canDelete) { %>
                          <button type="button" class="btn btn-outline-danger delete-user" data-id="<%= userItem.id %>">
                            <i class="bi bi-trash"></i>
                          </button>
                        <% } %>
                      <% } %>
                    </div>
  
                    <!-- View User Modal -->
                    <div class="modal fade" id="viewUserModal<%= userItem.id %>" tabindex="-1">
                      <div class="modal-dialog">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title">User Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                          </div>
                          <div class="modal-body">
                            <div class="text-center mb-3">
                              <% if (userItem.avatar) { %>
                                <img src="<%= userItem.avatar %>" class="rounded-circle" width="100" height="100" alt="Avatar">
                              <% } else { %>
                                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white mx-auto" 
                                     style="width: 100px; height: 100px; font-size: 36px;">
                                  <%= (userItem.firstName?.charAt(0) || '').toUpperCase() %><%= (userItem.lastName?.charAt(0) || '').toUpperCase() %>
                                </div>
                              <% } %>
                              <h5 class="mt-3"><%= userItem.firstName || '' %> <%= userItem.lastName || '' %></h5>
                              <p class="text-muted">@<%= userItem.username || 'N/A' %></p>
                            </div>
                            
                            <table class="table table-bordered">
                              <tr>
                                <th width="40%">Email</th>
                                <td><%= userItem.email %></td>
                              </tr>
                              <tr>
                                <th>Phone</th>
                                <td><%= userItem.phone || 'N/A' %></td>
                              </tr>
                              <tr>
                                <th>Status</th>
                                <td>
                                  <% if (userItem.isActive) { %>
                                    <span class="badge bg-success">Active</span>
                                  <% } else { %>
                                    <span class="badge bg-danger">Inactive</span>
                                  <% } %>
                                </td>
                              </tr>
                              <tr>
                                <th>Email Verified</th>
                                <td>
                                  <% if (userItem.isEmailVerified) { %>
                                    <span class="badge bg-success">Yes</span>
                                  <% } else { %>
                                    <span class="badge bg-warning">No</span>
                                  <% } %>
                                </td>
                              </tr>
                              <tr>
                                <th>Roles</th>
                                <td>
                                  <% if (userItem.roles && userItem.roles.length > 0) { %>
                                    <% userItem.roles.forEach(role => { %>
                                      <span class="badge bg-info"><%= role.displayName %></span>
                                    <% }); %>
                                  <% } else { %>
                                    <span class="badge bg-secondary">No Role</span>
                                  <% } %>
                                </td>
                              </tr>
                              <tr>
                                <th>Last Login</th>
                                <td><%= userItem.lastLogin ? new Date(userItem.lastLogin).toLocaleString() : 'Never' %></td>
                              </tr>
                              <tr>
                                <th>Joined</th>
                                <td><%= new Date(userItem.createdAt).toLocaleString() %></td>
                              </tr>
                            </table>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                          </div>
                        </div>
                      </div>
                    </div>
  
                    <!-- Assign Roles Modal -->
                    <div class="modal fade" id="assignRolesModal<%= userItem.id %>" tabindex="-1">
                      <div class="modal-dialog">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title">Assign Roles to <%= userItem.firstName || '' %> <%= userItem.lastName || '' %></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                          </div>
                          <form action="/admin/users/<%= userItem.id %>/assign-roles" method="POST">
                            <div class="modal-body">
                              <div class="mb-3">
                                <label class="form-label">Select Roles</label>
                                <div class="border p-3 rounded" style="max-height: 300px; overflow-y: auto;">
                                  <% allRoles.forEach(role => { %>
                                    <div class="form-check mb-2">
                                      <input class="form-check-input" type="checkbox" name="roleIds" value="<%= role.id %>" 
                                             id="role<%= userItem.id %>_<%= role.id %>"
                                             <%= userItem.roles?.some(r => r.id === role.id) ? 'checked' : '' %>>
                                      <label class="form-check-label" for="role<%= userItem.id %>_<%= role.id %>">
                                        <strong><%= role.displayName %></strong> 
                                        <small class="text-muted">(Level: <%= role.level %>)</small>
                                        <br>
                                        <small class="text-muted"><%= role.description || '' %></small>
                                      </label>
                                    </div>
                                  <% }); %>
                                </div>
                              </div>
                            </div>
                            <div class="modal-footer">
                              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                              <button type="submit" class="btn btn-primary">Save Changes</button>
                            </div>
                          </form>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="8" class="text-center py-4">No users found</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
  
      <!-- Pagination -->
      <% if (pagination.pages > 1) { %>
        <nav aria-label="Page navigation" class="mt-3">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page - 1 %><%= search ? '&search=' + search : '' %>">Previous</a>
            </li>
            
            <% for (let i = 1; i <= pagination.pages; i++) { %>
              <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %>"><%= i %></a>
              </li>
            <% } %>
            
            <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page + 1 %><%= search ? '&search=' + search : '' %>">Next</a>
            </li>
          </ul>
        </nav>
      <% } %>
    </div>
  </div>
  
  <script>
    $(document).ready(function() {
      // Delete user
      $('.delete-user').on('click', function() {
        const userId = $(this).data('id');
        
        if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
          $.ajax({
            url: '/admin/users/' + userId,
            type: 'DELETE',
            success: function(response) {
              if (response.success) {
                window.location.reload();
              } else {
                alert(response.error || 'Failed to delete user');
              }
            },
            error: function(xhr) {
              alert(xhr.responseJSON?.error || 'Failed to delete user');
            }
          });
        }
      });
    });
  </script>
