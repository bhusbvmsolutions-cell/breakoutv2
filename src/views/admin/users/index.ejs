<%- contentFor('title') %>
<%- contentFor('head') %>
<%- contentFor('body') %>



<div class="row">
  <div class="col-12">
    <div class="card shadow-sm border-0">
      <div class="card-body py-3">
        <h4 class="mb-0"><i class="bi bi-people me-2"></i>User Management</h4>
      </div>
    </div>
  </div>
</div>
<div class="card shadow-sm border-0 mt-3">
  <div class="card-header bg-white border-0 py-2">
    <div class="row align-items-center g-2">
      <div class="col-sm-6">
        <h5 class="mb-0 fw-semibold">All Users</h5>
      </div>
      <div class="col-sm-6">
        <div class="d-flex justify-content-end gap-2">
          <form action="/admin/users" method="GET" class="d-flex">
            <input type="text" name="search" class="form-control form-control-sm me-2" 
                   placeholder="Search users..." value="<%= search || '' %>" 
                   style="width: 180px;">
            <button type="submit" class="btn btn-sm btn-primary px-3">
              <i class="bi bi-search"></i>
            </button>
          </form>
          <% if (canCreateUser) { %>
            <a href="/admin/users/create" class="btn btn-sm btn-success">
              <i class="bi bi-plus me-1"></i>Add User
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 small">
        <thead class="table-light small">
          <tr>
            <th class="ps-3">ID</th>
            <th>User</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Roles</th>
            <th>Status</th>
            <th>Joined</th>
            <th class="pe-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users && users.length > 0) { %>
            <% users.forEach(userItem => { %>
              <tr class="align-middle">
                <td class="ps-3 fw-semibold"><%= userItem.id %></td>
                <td>
                  <div class="d-flex align-items-center">
                    <% if (userItem.avatar) { %>
                      <img src="<%= userItem.avatar %>" class="rounded-circle" 
                           width="32" height="32" alt="Avatar">
                    <% } else { %>
                      <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center 
                                  justify-content-center text-black fw-semibold" 
                           style="width: 32px; height: 32px; font-size: 14px;">
                        <%= (userItem.firstName?.charAt(0) || '').toUpperCase() %><%= (userItem.lastName?.charAt(0) || '').toUpperCase() %>
                      </div>
                    <% } %>
                    <div class="ms-2 lh-1">
                      <div class="fw-semibold"><%= userItem.firstName || '' %> <%= userItem.lastName || '' %></div>
                      <small class="text-secondary">@<%= userItem.username || 'N/A' %></small>
                    </div>
                  </div>
                </td>
                <td><%= userItem.email %></td>
                <td><%= userItem.phone || '—' %></td>
                <td>
                  <% if (userItem.roles && userItem.roles.length > 0) { %>
                    <% userItem.roles.slice(0, 2).forEach(role => { %>
                      <span class="badge bg-info bg-opacity-10 text-white fw-normal me-1"><%= role.displayName %></span>
                    <% }); %>
                    <% if (userItem.roles.length > 2) { %>
                      <span class="badge bg-secondary bg-opacity-10 text-black fw-normal">+<%= userItem.roles.length-2 %></span>
                    <% } %>
                  <% } else { %>
                    <span class="badge bg-secondary bg-opacity-10 text-black fw-normal">No Role</span>
                  <% } %>
                </td>
                <td>
                  <% if (userItem.isActive) { %>
                    <span class="badge bg-success bg-opacity-10 text-white fw-normal">Active</span>
                  <% } else { %>
                    <span class="badge bg-danger bg-opacity-10 text-white fw-normal">Inactive</span>
                  <% } %>
                </td>
                <td class="text-secondary"><%= new Date(userItem.createdAt).toLocaleDateString() %></td>
                <td class="pe-3">
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" 
                            data-bs-target="#viewUserModal<%= userItem.id %>" title="View">
                      <i class="bi bi-eye"></i>
                    </button>
                    
                    <% if (userItem.canManage) { %>
                      <a href="/admin/users/<%= userItem.id %>/edit" class="btn btn-outline-warning" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </a>
                      
                      <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" 
                              data-bs-target="#assignRolesModal<%= userItem.id %>" title="Assign roles">
                        <i class="bi bi-shield"></i>
                      </button>
                      
                      <% if (userItem.canDelete) { %>
                        <button type="button" class="btn btn-outline-danger delete-user" 
                                data-id="<%= userItem.id %>" title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      <% } %>
                    <% } %>
                  </div>

                  <!-- View User Modal (compact) -->
                  <div class="modal fade" id="viewUserModal<%= userItem.id %>" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                      <div class="modal-content border-0 shadow">
                        <div class="modal-header border-0 pb-0">
                          <h6 class="modal-title fw-semibold">User Details</h6>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body pt-2">
                          <div class="text-center mb-3">
                            <% if (userItem.avatar) { %>
                              <img src="<%= userItem.avatar %>" class="rounded-circle" 
                                   width="64" height="64" alt="Avatar">
                            <% } else { %>
                              <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center 
                                          justify-content-center text-white mx-auto fw-semibold" 
                                   style="width: 64px; height: 64px; font-size: 24px;">
                                <%= (userItem.firstName?.charAt(0) || '').toUpperCase() %><%= (userItem.lastName?.charAt(0) || '').toUpperCase() %>
                              </div>
                            <% } %>
                            <h6 class="mt-2 mb-0 fw-semibold"><%= userItem.firstName || '' %> <%= userItem.lastName || '' %></h6>
                            <small class="text-secondary">@<%= userItem.username || 'N/A' %></small>
                          </div>
                          
                          <table class="table table-sm table-borderless small">
                            <tr>
                              <th class="ps-0 text-secondary fw-normal">Email</th>
                              <td class="text-dark fw-semibold"><%= userItem.email %></td>
                            </tr>
                            <tr>
                              <th class="ps-0 text-secondary fw-normal">Phone</th>
                              <td class="text-dark"><%= userItem.phone || '—' %></td>
                            </tr>
                            <tr>
                              <th class="ps-0 text-secondary fw-normal">Status</th>
                              <td>
                                <% if (userItem.isActive) { %>
                                  <span class="badge bg-success bg-opacity-10 text-white fw-normal">Active</span>
                                <% } else { %>
                                  <span class="badge bg-danger bg-opacity-10 text-white fw-normal">Inactive</span>
                                <% } %>
                              </td>
                            </tr>
                            <tr>
                              <th class="ps-0 text-secondary fw-normal">Email Verified</th>
                              <td>
                                <% if (userItem.isEmailVerified) { %>
                                  <span class="badge bg-success bg-opacity-10 text-white fw-normal">Yes</span>
                                <% } else { %>
                                  <span class="badge bg-warning bg-opacity-10 text-white fw-normal">No</span>
                                <% } %>
                              </td>
                            </tr>
                            <tr>
                              <th class="ps-0 text-secondary fw-normal">Roles</th>
                              <td>
                                <% if (userItem.roles && userItem.roles.length > 0) { %>
                                  <% userItem.roles.forEach(role => { %>
                                    <span class="badge bg-info bg-opacity-10 text-white fw-normal me-1"><%= role.displayName %></span>
                                  <% }); %>
                                <% } else { %>
                                  <span class="badge bg-secondary bg-opacity-10 text-black fw-normal">No Role</span>
                                <% } %>
                              </td>
                            </tr>
                            <tr>
                              <th class="ps-0 text-secondary fw-normal">Last Login</th>
                              <td class="text-dark"><%= userItem.lastLogin ? new Date(userItem.lastLogin).toLocaleString() : 'Never' %></td>
                            </tr>
                            <tr>
                              <th class="ps-0 text-secondary fw-normal">Joined</th>
                              <td class="text-dark"><%= new Date(userItem.createdAt).toLocaleString() %></td>
                            </tr>
                          </table>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Assign Roles Modal (compact) -->
                  <div class="modal fade" id="assignRolesModal<%= userItem.id %>" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered modal-md">
                      <div class="modal-content border-0 shadow">
                        <div class="modal-header border-0 pb-0">
                          <h6 class="modal-title fw-semibold">Assign Roles to <%= userItem.firstName || '' %> <%= userItem.lastName || '' %></h6>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form action="/admin/users/<%= userItem.id %>/assign-roles" method="POST">
                          <div class="modal-body pt-2">
                            <div class="mb-2 small fw-semibold text-secondary">Select Roles</div>
                            <div class="border rounded p-2 bg-light" style="max-height: 240px; overflow-y: auto;">
                              <% allRoles.forEach(role => { %>
                                <div class="form-check mb-2">
                                  <input class="form-check-input" type="checkbox" name="roleIds" 
                                         value="<%= role.id %>" id="role<%= userItem.id %>_<%= role.id %>"
                                         <%= userItem.roles?.some(r => r.id === role.id) ? 'checked' : '' %>>
                                  <label class="form-check-label small" for="role<%= userItem.id %>_<%= role.id %>">
                                    <span class="fw-semibold"><%= role.displayName %></span> 
                                    <span class="text-secondary">(Level: <%= role.level %>)</span>
                                    <% if (role.description) { %>
                                      <br><small class="text-secondary"><%= role.description %></small>
                                    <% } %>
                                  </label>
                                </div>
                              <% }); %>
                            </div>
                          </div>
                          <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-sm btn-primary px-4">Save</button>
                          </div>
                        </form>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="8" class="text-center py-4 text-secondary">No users found</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination (smaller) -->
    <% if (pagination.pages > 1) { %>
      <nav aria-label="Page navigation" class="mt-3 pb-2">
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= pagination.page - 1 %><%= search ? '&search=' + search : '' %>">Previous</a>
          </li>
          
          <% for (let i = 1; i <= pagination.pages; i++) { %>
            <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %>"><%= i %></a>
            </li>
          <% } %>
          
          <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= pagination.page + 1 %><%= search ? '&search=' + search : '' %>">Next</a>
          </li>
        </ul>
      </nav>
    <% } %>
  </div>
</div>

<script>
  $(document).ready(function() {
    // Delete user
    $('.delete-user').on('click', function() {
      const userId = $(this).data('id');
      
      if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
        $.ajax({
          url: '/admin/users/' + userId,
          type: 'DELETE',
          success: function(response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || 'Failed to delete user');
            }
          },
          error: function(xhr) {
            alert(xhr.responseJSON?.error || 'Failed to delete user');
          }
        });
      }
    });
  });
</script>