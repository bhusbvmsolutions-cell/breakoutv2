<%- contentFor('title') %> <%= title %>
<%- contentFor('head') %>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<style>
  body { background: #f5f7fb; }
  .form-container { max-width: 100%; margin: 0 auto; }
  .card-custom { border-radius: 1rem; overflow: hidden; border: none; box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.08); }
  .card-header-custom { background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%); padding: 0.75rem 1.25rem; }
  .card-header-custom h4 { margin: 0; color: #2c3e50; font-weight: 600; font-size: 1.1rem; }
  .card-header-custom p { margin: 0; font-size: 0.8rem; color: #2c3e50; opacity: 0.9; }
  .form-label { font-weight: 500; margin-bottom: 0.25rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; }
  .form-control, .form-select { border-radius: 0.5rem; border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; font-size: 0.9rem; transition: all 0.2s; }
  .form-control:focus, .form-select:focus { border-color: #fcad00; box-shadow: 0 0 0 0.2rem rgba(252,173,0,0.25); }
  .btn-submit { background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%); border: none; border-radius: 2rem; padding: 0.5rem 1.5rem; font-weight: 600; transition: transform 0.2s; }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 0.5rem 1rem rgba(252,173,0,0.3); }
  .btn-cancel { background: #6c757d; border: none; border-radius: 2rem; padding: 0.5rem 1.5rem; font-weight: 500; }
  
  /* Custom Select2 Styling */
  .select2-container--bootstrap-5 .select2-selection--multiple {
    min-height: 45px;
    height: auto !important;
    max-height: 150px;
    overflow-y: auto;
    padding: 0.25rem 0.5rem;
    border: 2px solid #e2e8f0 !important;
    border-radius: 0.5rem;
    transition: all 0.2s;
  }
  .select2-container--bootstrap-5.select2-container--focus .select2-selection--multiple {
    border-color: #fcad00 !important;
    box-shadow: 0 0 0 0.2rem rgba(252,173,0,0.25) !important;
  }
  .select2-container--bootstrap-5 .select2-selection--multiple .select2-selection__choice {
    background-color: #fcad00;
    border: 1px solid #e09c00;
    color: #2c3e50;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.25rem 1.8rem 0.25rem 0.6rem;
    margin: 0.2rem;
    border-radius: 2rem;
    position: relative;
  }
  .select2-container--bootstrap-5 .select2-selection--multiple .select2-selection__choice__remove {
    position: absolute;
    right: 0.4rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(0,0,0,0.6);
    font-size: 1rem;
    font-weight: bold;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
  }
  .select2-container--bootstrap-5 .select2-selection--multiple .select2-selection__choice__remove:hover {
    color: #000;
    background: transparent;
  }
  .select2-container--bootstrap-5 .select2-dropdown {
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1);
    margin-top: 0.25rem;
  }
  .select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field {
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 0.5rem;
    font-size: 0.85rem;
  }
  .select2-container--bootstrap-5 .select2-results__option {
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .select2-container--bootstrap-5 .select2-results__option--highlighted {
    background-color: #fcad00;
    color: #2c3e50;
  }
  .select2-container--bootstrap-5 .select2-results__option[aria-selected="true"] {
    background-color: rgba(252,173,0,0.1);
    color: #2c3e50;
    position: relative;
    padding-left: 1.8rem;
  }
  .select2-container--bootstrap-5 .select2-results__option[aria-selected="true"]:before {
    content: "✓";
    position: absolute;
    left: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    color: #fcad00;
    font-weight: bold;
    font-size: 0.9rem;
  }
  .select2-container--bootstrap-5 .select2-results__options {
    max-height: 250px;
    overflow-y: auto;
    scrollbar-width: thin;
  }
  .select2-container--bootstrap-5 .select2-results__options::-webkit-scrollbar {
    width: 6px;
  }
  .select2-container--bootstrap-5 .select2-results__options::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
  }
  .select2-container--bootstrap-5 .select2-results__options::-webkit-scrollbar-thumb {
    background: #fcad00;
    border-radius: 10px;
  }
  .select2-container--bootstrap-5 .select2-selection__placeholder {
    color: #6c757d;
    font-size: 0.85rem;
  }
  .select2-container--bootstrap-5 .select2-selection--multiple .select2-selection__clear {
    margin-right: 0.5rem;
    font-size: 1rem;
    color: #6c757d;
    cursor: pointer;
  }
  .select2-container--bootstrap-5 .select2-selection--multiple .select2-selection__clear:hover {
    color: #dc3545;
  }
</style>

<%- contentFor('body') %>
<div class="container py-4">
  <div class="form-container">
    <div class="card card-custom">
      <div class="card-header-custom">
        <h4><i class="bx bx-edit me-2"></i> Edit Venue Mapping</h4>
        <p class="mb-0">Update venue mapping for <%= blog.title %></p>
      </div>
      <div class="card-body p-4">
        <form action="/admin/birthday-blog/venue-mappings/update/<%= mapping.id %>" method="POST">
          <input type="hidden" name="_method" value="PUT">
          <div class="row g-4">
            <div class="col-12">
              <label class="form-label">Title *</label>
              <input type="text" name="title" class="form-control" value="<%= mapping.title %>" required>
              <div class="form-text small mt-1">Give this mapping a descriptive title (e.g., "Best Birthday Venues", "Luxury Options")</div>
            </div>
            <div class="col-12">
              <label class="form-label">Select Venues *</label>
              <select name="venue_ids[]" class="form-control select2-multiple" multiple required>
                <% venues.forEach(venue => { %>
                  <option value="<%= venue.id %>" <%= mapping.venue_ids && mapping.venue_ids.includes(venue.id) ? 'selected' : '' %>>
                    <%= venue.name %>
                  </option>
                <% }); %>
              </select>
              <div class="form-text small mt-1">
                <i class="bx bx-info-circle"></i> Select one or more venues. You can search, select multiple, or remove selected items.
              </div>
            </div>
            <div class="col-12">
              <div class="form-check">
                <input type="checkbox" name="isActive" class="form-check-input" value="on" <%= mapping.isActive ? 'checked' : '' %>>
                <label class="form-check-label small">Active</label>
              </div>
            </div>
          </div>
          <div class="d-flex justify-content-end mt-4">
            <a href="/admin/birthday-blog/<%= blog.id %>/venue-mappings" class="btn btn-cancel btn-sm me-2">
              <i class="bx bx-x-circle me-1"></i> Cancel
            </a>
            <button type="submit" class="btn btn-submit btn-sm">
              <i class="bx bx-save me-1"></i> Update Mapping
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- contentFor('js') %>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
  $(document).ready(function() {
    $('.select2-multiple').select2({
      theme: 'bootstrap-5',
      width: '100%',
      placeholder: '🔍 Search and select venues...',
      allowClear: true,
      closeOnSelect: false,
      language: {
        noResults: function() {
          return 'No venues found';
        },
        searching: function() {
          return 'Searching...';
        }
      },
      templateResult: function(data) {
        if (data.loading) return data.text;
        return $('<span><i class="bx bx-location-plus me-1"></i> ' + data.text + '</span>');
      },
      templateSelection: function(data) {
        return data.text;
      }
    });
  });
</script>