<%- contentFor('title') %> <%= title %>
<%- contentFor('head') %>
<style>
  body { background: #f5f7fb; }
  .mappings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1rem; }
  .mapping-card { background: #fff; border-radius: 0.75rem; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); transition: all 0.2s; }
  .mapping-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
  .mapping-card-content { padding: 0.75rem; }
  .mapping-card-title { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: #2c3e50; }
  .mapping-card-venues { font-size: 0.75rem; color: #6c757d; margin-bottom: 0.5rem; }
  .mapping-card-venues ul { margin: 0; padding-left: 1.2rem; }
  .mapping-card-venues li { margin-bottom: 0.2rem; }
  .mapping-card-status { font-size: 0.65rem; padding: 0.2rem 0.5rem; border-radius: 20px; font-weight: 500; display: inline-block; }
  .mapping-card-actions { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 0.75rem; }
  .btn-sm { padding: 0.2rem 0.5rem; font-size: 0.7rem; }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-3">
  <div class="row mb-3 align-items-center">
    <div class="col-md-6">
      <h4 class="mb-0 fw-bold">Venue Mappings - <%= blog.title %></h4>
      <p class="text-muted small mb-0">Manage venue mappings for this blog</p>
    </div>
    <div class="col-md-6 text-md-end mt-2 mt-md-0">
      <a href="/admin/birthday-blog/<%= blog.id %>/venue-mappings/create" class="btn btn-primary btn-sm">
        <i class="bx bx-plus-circle me-1"></i> Add New Mapping
      </a>
      <a href="/admin/birthday-blog" class="btn btn-secondary btn-sm ms-2">
        <i class="bx bx-arrow-back me-1"></i> Back to Blogs
      </a>
    </div>
  </div>

  <div class="mappings-grid">
    <% if (mappings && mappings.length) { %>
      <% mappings.forEach(mapping => { %>
        <div class="mapping-card" data-id="<%= mapping.id %>" data-status="<%= mapping.isActive %>">
          <div class="mapping-card-content">
            <h5 class="mapping-card-title"><%= mapping.title %></h5>
            <div class="mapping-card-venues">
              <strong>Venues (<%= mapping.venues.length %>):</strong>
              <ul>
                <% mapping.venues.forEach(venue => { %>
                  <li><%= venue.name %></li>
                <% }); %>
              </ul>
            </div>
            <div class="mt-1">
              <span class="mapping-card-status badge <%= mapping.isActive ? 'bg-success' : 'bg-secondary' %>">
                <%= mapping.isActive ? 'Active' : 'Inactive' %>
              </span>
            </div>
            <div class="mapping-card-actions">
              <a href="/admin/birthday-blog/venue-mappings/edit/<%= mapping.id %>" class="btn btn-sm btn-warning">
                <i class="bx bx-edit"></i> Edit
              </a>
              <button class="btn btn-sm btn-danger delete-mapping" data-id="<%= mapping.id %>">
                <i class="bx bx-trash"></i> Delete
              </button>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="bx bx-folder-open fs-1 text-muted"></i>
        <h5 class="mt-3">No venue mappings found</h5>
        <p class="text-muted">Click "Add New Mapping" to create your first venue mapping.</p>
        <a href="/admin/birthday-blog/<%= blog.id %>/venue-mappings/create" class="btn btn-primary btn-sm">
          Add New Mapping
        </a>
      </div>
    <% } %>
  </div>
</div>

<%- contentFor('js') %>
<script>
  document.querySelectorAll('.delete-mapping').forEach(btn => {
    btn.addEventListener('click', async e => {
      if (!confirm('Delete this mapping? This will remove all venues under this title.')) return;
      const id = btn.dataset.id;
      const res = await fetch(`/admin/birthday-blog/venue-mappings/delete/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.message);
    });
  });
</script>