<%- contentFor('title') %> Birthday Blogs
<%- contentFor('head') %>
<style>
  body {
    background: #f5f7fb;
  }

  .stats-card {
    background: linear-gradient(135deg, #fcad00 0%, #ffd966 100%);
    border-radius: 10px;
    padding: 0.75rem;
    color: #2c3e50;
    text-align: center;
    transition: transform 0.2s;
  }

  .stats-card:hover {
    transform: translateY(-3px);
  }

  .stats-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0;
  }

  .stats-card p {
    margin-bottom: 0;
    font-size: 0.7rem;
    opacity: 0.9;
  }

  .search-box {
    position: relative;
    max-width: 300px;
  }

  .search-box input {
    padding-left: 2rem;
    border-radius: 20px;
    border: 1px solid #dee2e6;
    font-size: 0.8rem;
    height: 32px;
  }

  .search-box input:focus {
    border-color: #fcad00;
    box-shadow: 0 0 0 0.2rem rgba(252, 173, 0, 0.25);
  }

  .search-box i {
    position: absolute;
    left: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.9rem;
    color: #adb5bd;
  }

  .blogs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .blog-card {
    background: #fff;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    transition: all 0.2s;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .blog-card-image {
    height: 140px;
    overflow: hidden;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-card-content {
    padding: 0.75rem;
  }

  .blog-card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .blog-card-slug {
    font-size: 0.7rem;
    color: #6c757d;
    margin-bottom: 0.5rem;
    word-break: break-all;
  }

  .blog-card-status {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .blog-card-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }
  .blog-card-actions a{
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
  }

  .btn-sm {
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
  }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-3">
  <div class="row mb-3 align-items-center">
    <div class="col-md-8">
      <h4 class="mb-0 fw-bold">SEO/Places Blogs</h4>
      <p class="text-muted small mb-0">Manage SEO/Places blog posts</p>
    </div>
    <div class="col-md-4 text-md-end mt-2 mt-md-0">
      <a href="/admin/birthday-blog/create" class="btn btn-primary btn-sm"><i class="bx bx-plus-circle me-1"></i> Add New Blog</a>
    </div>
  </div>

  <div class="row g-2 mb-3">
    <div class="col-md-3">
      <div class="stats-card">
        <h3 id="totalBlogs"><%= pagination.totalCount %></h3>
        <p>Total Blogs</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stats-card">
        <h3 id="activeBlogs"><%= blogs.filter(b => b.isActive).length %></h3>
        <p>Active</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stats-card">
        <h3 id="inactiveBlogs"><%= blogs.filter(b => !b.isActive).length %></h3>
        <p>Inactive</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stats-card">
        <h3 id="published"><%= new Date().getFullYear() %></h3>
        <p>Published</p>
      </div>
    </div>
  </div>

  <form method="GET" action="/admin/birthday-blog" class="row mb-3 g-2">
    <div class="col-md-5">
      <div class="search-box"><i class="bx bx-search"></i><input type="text" name="search" value="<%= filters.search %>" class="form-control" placeholder="Search by title or slug..."></div>
    </div>
    <div class="col-md-3">
      <select name="status" class="form-select form-select-sm">
        <option value="">All Status</option>
        <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
      </select>
    </div>
    <div class="col-md-2">
      <select name="sort" class="form-select form-select-sm">
        <option value="latest" <%= filters.sort === 'latest' ? 'selected' : '' %>>Latest</option>
        <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
        <option value="title_asc" <%= filters.sort === 'title_asc' ? 'selected' : '' %>>Title A-Z</option>
        <option value="title_desc" <%= filters.sort === 'title_desc' ? 'selected' : '' %>>Title Z-A</option>
      </select>
    </div>
    <div class="col-md-2">
      <button type="submit" class="btn btn-primary btn-sm w-100">Filter</button>
    </div>
  </form>

  <div class="blogs-grid">
    <% blogs.forEach(blog => { %>
    <div class="blog-card">
      <div class="blog-card-image">
        <% if (blog.featured_image) { %>
        <img src="<%= blog.featured_image %>" alt="<%= blog.title %>">
        <% } else { %>
        <div class="bg-light d-flex align-items-center justify-content-center h-100"><i class="bx bx-image-alt fs-1 text-muted"></i></div>
        <% } %>
      </div>
      <div class="blog-card-content">
        <h5 class="blog-card-title"><%= blog.title %></h5>
        <div class="blog-card-slug"><i class="bx bx-link-alt me-1"></i> <%= blog.slug %></div>
        <div class="mt-1"><span class="blog-card-status badge <%= blog.isActive ? 'bg-success' : 'bg-secondary' %>"><%= blog.isActive ? 'Active' : 'Inactive' %></span></div>
        <div class="blog-card-actions">
          <a href="/admin/faqs/slug/seo:<%= blog.slug %>" class="bg-primary py-1 px-2 text-white rounded" title="View FAQs" style="font-size: 14px;">
            <i class="bi bi-patch-question"></i>
          </a>
          <a href="/admin/googlereviews/slug/seo:<%= blog.slug %>" class="bg-secondary py-1 px-2 text-white rounded" title="View Google Reviews" style="font-size: 14px;">
            <i class="bi bi-google"></i>
          </a>
          <a href="/admin/birthday-blog/view/<%= blog.id %>" class="btn btn-sm btn-info"><i class="bx bx-show"></i> </a>
          <a href="/admin/birthday-blog/edit/<%= blog.id %>" class="btn btn-sm btn-warning"><i class="bx bx-edit"></i> </a>
          <a href="/admin/birthday-blog/<%= blog.id %>/venue-mappings" class="btn btn-sm btn-primary"><i class="bx bx-map"></i> </a>
          <button class="btn btn-sm btn-danger delete-blog" data-id="<%= blog.id %>"><i class="bx bx-trash"></i> </button>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

  <% if (pagination.totalPages > 1) { %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.page - 1 %>&search=<%= filters.search %>&status=<%= filters.status %>&sort=<%= filters.sort %>">Previous</a>
      </li>
      <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&search=<%= filters.search %>&status=<%= filters.status %>&sort=<%= filters.sort %>"><%= i %></a>
      </li>
      <% } %>
      <li class="page-item <%= pagination.page === pagination.totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.page + 1 %>&search=<%= filters.search %>&status=<%= filters.status %>&sort=<%= filters.sort %>">Next</a>
      </li>
    </ul>
  </nav>
  <% } %>
</div>

<%- contentFor('js') %>
<script>
  document.querySelectorAll('.delete-blog').forEach(btn => {
    btn.addEventListener('click', async e => {
      if (!confirm('Delete this blog?')) return;
      const id = btn.dataset.id;
      const res = await fetch(`/admin/birthday-blog/delete/${id}`, {
        method: 'DELETE'
      });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.message);
    });
  });
</script>