<% if (blog) { %>
    <input type="hidden" name="_method" value="PUT">
  <% } %>
  
  <div class="row g-3">
    <div class="col-md-6">
      <label class="form-label">Title *</label>
      <input type="text" name="title" id="title" class="form-control" value="<%= blog?.title || '' %>" required>
    </div>
    <div class="col-md-6">
      <label class="form-label">Slug</label>
      <input type="text" name="slug" id="slug" class="form-control" value="<%= blog?.slug || '' %>">
      <div class="form-text small">Leave blank to auto-generate</div>
    </div>
    <div class="col-12">
      <label class="form-label">Featured Image</label>
      <input type="file" name="featured_image" class="form-control" accept="image/*">
      <% if (blog?.featured_image) { %>
        <img src="<%= blog.featured_image %>" class="img-thumbnail mt-2" style="max-width:120px;">
      <% } %>
    </div>
  </div>
  
  <hr>
  
  <!-- Banner Section -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0"><h6 class="fw-bold mb-0"><i class="bx bx-image-alt me-2"></i> Banner Section</h6></div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12"><label class="form-label small text-muted">Heading</label><input type="text" name="banner_heading" class="form-control form-control-sm" value="<%= blog?.banner_heading || '' %>"></div>
        <div class="col-12"><label class="form-label small text-muted">Description</label><input type="text" name="banner_description" class="form-control form-control-sm" value="<%= blog?.banner_description || '' %>"></div>
        <div class="col-12"><label class="form-label small text-muted">Image</label><input type="file" name="banner_image" class="form-control form-control-sm" accept="image/*"><% if (blog?.banner_image) { %><img src="<%= blog.banner_image %>" class="img-thumbnail mt-2" style="max-width:80px;"><% } %></div>
        <div class="col-12"><label class="form-label small text-muted">Content</label><textarea name="banner_content" class="form-control form-control-sm summernote" rows="5"><%= blog?.banner_content || '' %></textarea></div>
      </div>
    </div>
  </div>
  
  <!-- At a Glance Section -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0"><h6 class="fw-bold mb-0"><i class="bx bx-glance me-2"></i> At a Glance Section</h6></div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12"><label class="form-label small text-muted">Heading</label><input type="text" name="glance_heading" class="form-control form-control-sm" value="<%= blog?.glance_heading || '' %>"></div>
        <div class="col-12"><label class="form-label small text-muted">Content</label><textarea name="glance_content" class="form-control form-control-sm summernote" rows="5"><%= blog?.glance_content || '' %></textarea></div>
      </div>
    </div>
  </div>
  
  <!-- Icons Section (Repeater) -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0"><h6 class="fw-bold mb-0"><i class="bx bx-images me-2"></i> Icons Section</h6></div>
    <div class="card-body pt-2">
      <div class="row g-2 mb-2">
        <div class="col-12"><label class="form-label small text-muted">Section Heading</label><input type="text" name="icons_heading" class="form-control form-control-sm" value="<%= blog?.icons_heading || '' %>"></div>
        <div class="col-12"><label class="form-label small text-muted">Section Description</label><textarea name="icons_description" class="form-control form-control-sm" rows="3"><%= blog?.icons_description || '' %></textarea></div>
      </div>
      <div id="iconsContainer">
        <% if (blog?.iconItems && blog.iconItems.length) {
          blog.iconItems.forEach((item, idx) => { %>
            <div class="repeater-item bg-light p-2 rounded mb-2 position-relative border">
              <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
              <div class="row g-2">
                <div class="col-md-6"><label class="form-label small text-muted">Heading</label><input type="text" name="icon_items[<%= idx %>][heading]" class="form-control form-control-sm" value="<%= item.heading %>"></div>
                <div class="col-md-6"><label class="form-label small text-muted">Link</label><input type="text" name="icon_items[<%= idx %>][link]" class="form-control form-control-sm" value="<%= item.link || '' %>" placeholder="https://example.com"></div>
                <div class="col-md-12"><label class="form-label small text-muted">Image</label><input type="file" name="icon_items[<%= idx %>][image]" class="form-control form-control-sm" accept="image/*"><% if (item.image) { %><img src="<%= item.image %>" class="img-thumbnail mt-1" style="max-width:60px;"><% } %><input type="hidden" name="icon_items[<%= idx %>][image]" value="<%= item.image || '' %>"></div>
              </div>
            </div>
          <% });
        } else { %>
          <div class="repeater-item bg-light p-2 rounded mb-2 position-relative border">
            <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
            <div class="row g-2">
              <div class="col-md-6"><label class="form-label small text-muted">Heading</label><input type="text" name="icon_items[0][heading]" class="form-control form-control-sm"></div>
              <div class="col-md-6"><label class="form-label small text-muted">Link</label><input type="text" name="icon_items[0][link]" class="form-control form-control-sm" placeholder="https://example.com"></div>
              <div class="col-md-12"><label class="form-label small text-muted">Image</label><input type="file" name="icon_items[0][image]" class="form-control form-control-sm" accept="image/*"><img class="img-thumbnail mt-1"><input type="hidden" name="icon_items[0][image]" value=""></div>
            </div>
          </div>
        <% } %>
      </div>
      <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-icon-item"><i class="bx bx-plus"></i> Add Icon Item</button>
    </div>
  </div>
  
  <!-- Footer Section -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0"><h6 class="fw-bold mb-0"><i class="bx bx-footer me-2"></i> Footer Section</h6></div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12"><label class="form-label small text-muted">Heading</label><input type="text" name="footer_heading" class="form-control form-control-sm" value="<%= blog?.footer_heading || '' %>"></div>
        <div class="col-12"><label class="form-label small text-muted">Content</label><textarea name="footer_content" class="form-control form-control-sm" rows="3"><%= blog?.footer_content || '' %></textarea></div>
      </div>
    </div>
  </div>
  
  <!-- SEO Section -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3 pb-0"><h6 class="fw-bold mb-0"><i class="bx bx-search-alt me-2"></i> SEO Settings</h6></div>
    <div class="card-body pt-2">
      <div class="row g-2">
        <div class="col-12"><label class="form-label small text-muted">Meta Title</label><input type="text" name="meta_title" class="form-control form-control-sm" value="<%= blog?.meta_title || '' %>"></div>
        <div class="col-12"><label class="form-label small text-muted">Meta Description</label><textarea name="meta_description" class="form-control form-control-sm" rows="2"><%= blog?.meta_description || '' %></textarea></div>
        <div class="col-12"><label class="form-label small text-muted">Meta Keywords</label><input type="text" name="meta_keywords" class="form-control form-control-sm" value="<%= blog?.meta_keywords || '' %>" placeholder="Separate with commas"></div>
        <div class="col-12"><label class="form-label small text-muted">OG Title</label><input type="text" name="og_title" class="form-control form-control-sm" value="<%= blog?.og_title || '' %>"></div>
        <div class="col-12"><label class="form-label small text-muted">OG Description</label><textarea name="og_description" class="form-control form-control-sm" rows="2"><%= blog?.og_description || '' %></textarea></div>
      </div>
    </div>
  </div>
  
  <div class="col-12">
    <div class="form-check">
      <input type="checkbox" name="isActive" class="form-check-input" value="on" <%= blog?.isActive !== false ? 'checked' : '' %>>
      <label class="form-check-label">Active</label>
    </div>
  </div>
  
  <button type="submit" class="btn btn-primary mt-3"><i class="bx bx-save me-1"></i> <%= blog ? 'Update Blog' : 'Create Blog' %></button>
  
  <script>
    $(document).ready(function() {
      $('.summernote').summernote({
        placeholder: 'Write your content here...',
        tabsize: 2,
        height: 300,
        fontNames: [
          'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New',
          'Georgia', 'Tahoma', 'Times New Roman', 'Verdana',

          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontNamesIgnoreCheck: [
          'Poppins', 'Roboto', 'Open Sans', 'Lato',
          'Montserrat', 'Raleway', 'Nunito',
          'Playfair Display', 'Merriweather'
        ],
        fontSizes: ['8', '10', '12', '14', '16', '18', '20', '24', '28', '32', '36', '48', '64'],
        toolbar: [
          ['style', ['style']],
          ['font', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
          ['fontname', ['fontname']],
          ['fontsize', ['fontsize']],
          ['color', ['forecolor', 'backcolor']],
          ['para', ['ul', 'ol', 'paragraph', 'height']],
          ['insert', ['link', 'picture', 'video', 'table']],
          ['view', ['fullscreen', 'codeview']]
        ],
        lineHeights: ['0.8', '1.0', '1.2', '1.5', '2.0', '3.0'],
        callbacks: {
          onChange: function(contents) {
            // Update the hidden textarea when content changes
            const textarea = $(this).closest('.text-editor').find('.text-content');
            textarea.val(contents);
          }
        }
      });
  
      function setupImagePreview(inputElem, previewElem) {
        inputElem.on('change', function() {
          const file = this.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = function(e) { previewElem.attr('src', e.target.result).show(); };
            reader.readAsDataURL(file);
          } else {
            previewElem.hide().attr('src', '');
          }
        });
      }
      $('input[type="file"]').each(function() {
        const preview = $(this).next('.img-thumbnail');
        if (preview.length) setupImagePreview($(this), preview);
      });
  
      $('#title').on('blur', function() {
        if ($('#slug').val() === '') {
          let slug = $(this).val().toLowerCase().replace(/[^\w\s-]/g, '').replace(/[\s_-]+/g, '-').replace(/^-+|-+$/g, '');
          $('#slug').val(slug);
        }
      });
  
      let iconIndex = $('#iconsContainer .repeater-item').length;
      $('.add-icon-item').click(function() {
        const newIndex = iconIndex++;
        const newItem = `
          <div class="repeater-item bg-light p-2 rounded mb-2 position-relative border">
            <div class="remove-item" onclick="removeItem(this)"><i class="bx bx-trash"></i></div>
            <div class="row g-2">
              <div class="col-md-6"><label class="form-label small text-muted">Heading</label><input type="text" name="icon_items[${newIndex}][heading]" class="form-control form-control-sm"></div>
              <div class="col-md-6"><label class="form-label small text-muted">Link</label><input type="text" name="icon_items[${newIndex}][link]" class="form-control form-control-sm" placeholder="https://example.com"></div>
              <div class="col-md-12"><label class="form-label small text-muted">Image</label><input type="file" name="icon_items[${newIndex}][image]" class="form-control form-control-sm" accept="image/*"><img class="img-thumbnail mt-1"><input type="hidden" name="icon_items[${newIndex}][image]" value=""></div>
            </div>
          </div>
        `;
        $('#iconsContainer').append(newItem);
        const fileInput = $(`#iconsContainer .repeater-item:last input[type="file"]`);
        const preview = fileInput.next('.img-thumbnail');
        setupImagePreview(fileInput, preview);
      });
    });
  
    function removeItem(btn) {
      $(btn).closest('.repeater-item').remove();
    }
  </script>