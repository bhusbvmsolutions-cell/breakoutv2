<%- contentFor('title') %> Edit: <%= blog.title %>
<%- contentFor('head') %>
<!-- Summernote CSS -->
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
<style>
  .blog-editor {
    min-height: 300px;
  }

  .block-editor {
    margin-bottom: 20px;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 15px;
    position: relative;
    background: #fff;
  }

  .block-editor .block-controls {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 10;
  }

  .block-editor .block-type-selector {
    margin-bottom: 15px;
    max-width: 200px;
  }

  .image-preview {
    max-width: 200px;
    max-height: 200px;
    margin-top: 10px;
  }

  .current-image {
    max-width: 200px;
    max-height: 200px;
    margin-bottom: 10px;
  }

  .block-arrow-button {
    border: solid 1px #fcad00;
    color: #fcad00;
    background: transparent;
    border-radius: 4px;
    margin-top: 6px;
    transition: all 0.3s ease;
  }

  .block-arrow-button:hover {
    color: #ffffff;
    background: #fcad00;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
  }

  .block-remove-button {
    border: solid 1px #f73757;
    color: #f73757;
    background: transparent;
    border-radius: 4px;
    margin-top: 6px;
    transition: all 0.3s ease;
  }

  .block-remove-button:hover {
    color: #ffffff;
    background: #f73757;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
  }

  /* Hero Block Styles */
  .hero-preview {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 4px;
    margin-top: 10px;
  }

  /* Gallery Styles */
  .gallery-images {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 10px;
    margin-top: 10px;
  }

  .gallery-image-item {
    position: relative;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 5px;
  }

  .gallery-image-item img {
    width: 100%;
    height: 80px;
    object-fit: cover;
  }

  .gallery-image-item .remove-image {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #dc3545;
    color: white;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  /* Cards Styles */
  .card-item {
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 15px;
    margin-bottom: 15px;
    position: relative;
    background: #f8f9fa;
  }

  .card-item .remove-card {
    position: absolute;
    top: 10px;
    right: 10px;
  }

  /* FAQ Styles */
  .faq-item {
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 15px;
    margin-bottom: 15px;
    position: relative;
    background: #f8f9fa;
  }

  /* Locations Styles */
  .location-item {
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 15px;
    margin-bottom: 15px;
    position: relative;
    background: #f8f9fa;
  }

  /* CTA Styles */
  .cta-preview {
    background: #e9ecef;
    padding: 30px;
    border-radius: 8px;
    text-align: center;
  }

  .block-settings {
    margin-top: 15px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 4px;
  }

  .note-editor {
    margin-bottom: 10px;
  }
</style>

<%- contentFor('body') %>
<div class="">
  <div class="row">
    <div class="col-12">
      <div class="">
        <div class="card-header">
          <h5><i class="bi bi-pencil"></i> Edit Blog: <%= blog.title %></h5>
        </div>
        <div class="card-body">
          <form method="POST" action="/admin/blogs/<%= blog.id %>?_method=PUT" enctype="multipart/form-data" id="blogForm">
            <!-- Basic Information -->
            <div class="row mb-3">
              <div class="col-md-8">
                <div class="mb-3">
                  <label for="title" class="form-label">Title *</label>
                  <input type="text" class="form-control <%= errors.title ? 'is-invalid' : '' %>" id="title" name="title" value="<%= blog.title %>" required>
                  <% if (errors.title) { %>
                  <div class="invalid-feedback"><%= errors.title.message || errors.title %></div>
                  <% } %>
                </div>

                <div class="mb-3">
                  <label for="excerpt" class="form-label">Excerpt</label>
                  <textarea class="form-control <%= errors.excerpt ? 'is-invalid' : '' %>" id="excerpt" name="excerpt" rows="3"><%= blog.excerpt || '' %></textarea>
                  <% if (errors.excerpt) { %>
                  <div class="invalid-feedback"><%= errors.excerpt.message || errors.excerpt %></div>
                  <% } %>
                  <small class="text-muted">A brief summary of your blog post</small>
                </div>

                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label for="author" class="form-label">Author</label>
                      <input type="text" class="form-control <%= errors.author ? 'is-invalid' : '' %>" id="author" name="author" value="<%= blog.author || '' %>">
                      <% if (errors.author) { %>
                      <div class="invalid-feedback"><%= errors.author.message || errors.author %></div>
                      <% } %>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label for="readTime" class="form-label">Read Time (minutes)</label>
                      <input type="number" class="form-control <%= errors.readTime ? 'is-invalid' : '' %>" id="readTime" name="readTime" value="<%= blog.readTime || '' %>" min="1">
                      <% if (errors.readTime) { %>
                      <div class="invalid-feedback"><%= errors.readTime.message || errors.readTime %></div>
                      <% } %>
                    </div>
                  </div>
                </div>

                <div class="mb-3">
                  <label for="status" class="form-label">Status</label>
                  <select class="form-select" id="status" name="status">
                    <option value="draft" <%= blog.status === 'draft' ? 'selected' : '' %>>Draft</option>
                    <option value="published" <%= blog.status === 'published' ? 'selected' : '' %>>Published</option>
                  </select>
                </div>
                <div class="py-3">
                <div class="card">
                  <div class="card-header">
                    <h6>Hero Image</h6>
                  </div>
                  <div class="card-body">
                    <% if (blog.heroImage) { %>
                    <div class="current-image mb-3">
                      <img src="<%= blog.heroImage %>" class="img-fluid rounded" alt="Current hero image">
                      <small class="text-muted d-block mt-1">Current image</small>
                    </div>
                    <% } %>

                    <div class="mb-3">
                      <label for="heroImage" class="form-label">Upload New Image</label>
                      <input type="file" class="form-control <%= errors.heroImage ? 'is-invalid' : '' %>" id="heroImage" name="heroImage" accept="image/*">
                      <% if (errors.heroImage) { %>
                      <div class="invalid-feedback"><%= errors.heroImage.message || errors.heroImage %></div>
                      <% } %>
                    </div>
                    <div id="imagePreview" class="image-preview"></div>
                    <small class="text-muted">Leave empty to keep current image</small>
                  </div>
                </div>
              </div>
                
              </div>

              <div class="col-md-4">
                <% if (blog.createdAt) { %>
                  <div class="mb-3">
                    <label class="form-label">Created At</label>
                    <p class="form-control-plaintext"><%= new Date(blog.createdAt).toLocaleString() %></p>
                  </div>
                  <% } %>
                <div class="mb-3">
                  <label class="form-label">Slug</label>
                  <p class="form-control-plaintext">/<%= blog.slug %></p>
                </div>
                <div class="row py-2">
                  <div class="col-12">
                    <div class="card">
                      <div class="card-header">
                        <h6>Filter Fields</h6>
                        <small>These filters will work in website to filter blogs</small>
                      </div>
                      <div class="card-body">
                        <div class="row">
                          <div class="col-md-12">
                            <div class="mb-3">
                              <label for="tags" class="form-label">Tags</label>
                              <textarea class="form-control <%= errors.tags ? 'is-invalid' : '' %>" id="tags" name="tags" rows="1"><%= blog.tags || '' %></textarea>
                              <% if (errors.tags) { %>
                              <div class="invalid-feedback"><%= errors.tags.message || errors.tags %></div>
                              <% } %>
                              <small class="text-muted">Add comma seperated words (tags)</small>
                            </div>
                          </div>
                          <div class="col-md-12">
                            <div class="mb-3">
                              <label for="locations" class="form-label">Locations</label>
                              <textarea class="form-control <%= errors.excerpt ? 'is-invalid' : '' %>" id="locations" name="locations" rows="1"><%= blog.locations || '' %></textarea>
                              <% if (errors.locations) { %>
                              <div class="invalid-feedback"><%= errors.locations.message || errors.locations %></div>
                              <% } %>
                              <small class="text-muted">Add comma seperated words (locations)</small>
                            </div>
                          </div>
                          <div class="col-md-12">
                            <div class="mb-3">
                              <label for="looking_for" class="form-label">Looking For</label>
                              <textarea class="form-control <%= errors.looking_for ? 'is-invalid' : '' %>" id="looking_for" name="looking_for" rows="1"><%= blog.looking_for || '' %></textarea>
                              <% if (errors.looking_for) { %>
                              <div class="invalid-feedback"><%= errors.looking_for.message || errors.looking_for %></div>
                              <% } %>
                              <small class="text-muted">Add comma seperated words (Looking For)</small>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                
              </div>
            </div>

            <!-- Content Blocks -->
            <div class="card mt-3">
              <div class="card-header d-flex justify-content-between align-items-center">
                <h6>Content Blocks</h6>
                <button type="button" class="btn btn-primary btn-sm" id="addBlockBtn">
                  <i class="bi bi-plus"></i> Add Block
                </button>
              </div>
              <div class="card-body" id="blocksContainer">
                <!-- Existing blocks will be loaded here -->
              </div>
            </div>

            <!-- Form Actions -->
            <div class="mt-3">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Update Blog
              </button>
              <a href="/admin/blogs/<%= blog.id %>" class="btn btn-info">
                <i class="bi bi-eye"></i> View
              </a>
              <a href="/admin/blogs" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Block Templates -->
<template id="blockTemplate">
  <div class="block-editor">
    <div class="block-controls me-5">
      <button type="button" class="block-arrow-button move-up" title="Move Up">
        <i class="bi bi-arrow-up fs-6"></i>
      </button>
      <button type="button" class="block-arrow-button move-down" title="Move Down">
        <i class="bi bi-arrow-down fs-6"></i>
      </button>
      <button type="button" class="block-remove-button remove-block" title="Remove">
        <i class="bi bi-trash fs-6"></i>
      </button>
    </div>

    <div class="block-type-selector">
      <select class="form-select form-select-sm block-type">
        <option value="hero">Hero Section</option>
        <option value="text">Text Content</option>
        <option value="image">Single Image</option>
        <option value="gallery">Image Gallery</option>
        <option value="cards">Cards Grid</option>
        <option value="faq">FAQ Section</option>
        <option value="locations">Locations</option>
        <option value="cta">Call to Action</option>
      </select>
    </div>

    <div class="block-content">
      <!-- Hero Block -->
      <div class="hero-editor d-none">
        <div class="row">
          <div class="col-md-6">
            <div class="mb-3">
              <label class="form-label">Hero Title</label>
              <input type="text" class="form-control hero-title" placeholder="Enter hero title">
            </div>
            <div class="mb-3">
              <label class="form-label">Hero Subtitle</label>
              <textarea class="form-control hero-subtitle" rows="2" placeholder="Enter hero subtitle"></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">Hero Image</label>
              <input type="file" class="form-control hero-image" accept="image/*">
              <input type="hidden" class="hero-image-url">
              <div class="hero-image-preview mt-2"></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="mb-3">
              <label class="form-label">Button Text (Optional)</label>
              <input type="text" class="form-control hero-btn-text" placeholder="e.g., Learn More">
            </div>
            <div class="mb-3">
              <label class="form-label">Button Link</label>
              <input type="text" class="form-control hero-btn-link" placeholder="/about">
            </div>
            <div class="mb-3">
              <label class="form-label">Overlay Opacity</label>
              <input type="range" class="form-range hero-overlay" min="0" max="100" value="50">
            </div>
          </div>
        </div>
      </div>

      <!-- Text Block (with Summernote) -->
      <div class="text-editor d-none">
        <div class="summernote-editor"></div>
        <textarea class="d-none text-content" name="content"></textarea>
      </div>

      <!-- Image Block -->
      <div class="image-editor d-none">
        <div class="row">
          <div class="col-md-8">
            <div class="mb-3">
              <label class="form-label">Upload Image</label>
              <input type="file" class="form-control block-image" accept="image/*">
              <input type="hidden" class="image-url">
              <div class="image-preview-container mt-2"></div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="mb-3">
              <label class="form-label">Image Caption</label>
              <input type="text" class="form-control image-caption" placeholder="Optional caption">
            </div>
            <div class="mb-3">
              <label class="form-label">Image Alt Text</label>
              <input type="text" class="form-control image-alt" placeholder="SEO alt text">
            </div>
          </div>
        </div>
      </div>

      <!-- Gallery Block -->
      <div class="gallery-editor d-none">
        <div class="mb-3">
          <label class="form-label">Gallery Images</label>
          <input type="file" class="form-control gallery-upload" accept="image/*" multiple>
        </div>
        <div class="gallery-images-container"></div>
        <div class="mt-3">
          <label class="form-label">Gallery Layout</label>
          <select class="form-select gallery-layout">
            <option value="grid-3">3 Columns Grid</option>
            <option value="grid-4">4 Columns Grid</option>
            <option value="masonry">Masonry Layout</option>
            <option value="slider">Image Slider</option>
          </select>
        </div>
      </div>

      <!-- Cards Block -->
      <div class="cards-editor d-none">
        <div class="mb-3">
          <button type="button" class="btn btn-sm btn-success add-card">
            <i class="bi bi-plus"></i> Add Card
          </button>
        </div>
        <div class="cards-container"></div>
        <div class="mt-3">
          <label class="form-label">Cards per Row</label>
          <select class="form-select cards-per-row">
            <option value="2">2 Cards</option>
            <option value="3">3 Cards</option>
            <option value="4">4 Cards</option>
          </select>
        </div>
      </div>

      <!-- FAQ Block -->
      <div class="faq-editor d-none">
        <div class="mb-3">
          <label class="form-label">FAQ Title</label>
          <input type="text" class="form-control faq-title" placeholder="Frequently Asked Questions">
        </div>
        <div class="mb-3">
          <button type="button" class="btn btn-sm btn-success add-faq">
            <i class="bi bi-plus"></i> Add FAQ Item
          </button>
        </div>
        <div class="faq-items-container"></div>
      </div>

      <!-- Locations Block -->
      <div class="locations-editor d-none">
        <div class="mb-3">
          <label class="form-label">Locations Title</label>
          <input type="text" class="form-control locations-title" placeholder="Our Locations">
        </div>
        <div class="mb-3">
          <button type="button" class="btn btn-sm btn-success add-location">
            <i class="bi bi-plus"></i> Add Location
          </button>
        </div>
        <div class="locations-container"></div>
        <div class="mt-3">
          <label class="form-label">Show Map</label>
          <div class="form-check">
            <input type="checkbox" class="form-check-input show-map" id="showMap">
            <label class="form-check-label" for="showMap">Display Google Map</label>
          </div>
        </div>
      </div>

      <!-- CTA Block -->
      <div class="cta-editor d-none">
        <div class="row">
          <div class="col-md-8">
            <div class="mb-3">
              <label class="form-label">CTA Title</label>
              <input type="text" class="form-control cta-title" placeholder="Ready to get started?">
            </div>
            <div class="mb-3">
              <label class="form-label">CTA Description</label>
              <textarea class="form-control cta-description" rows="2" placeholder="Describe your call to action"></textarea>
            </div>
          </div>
          <div class="col-md-4">
            <div class="mb-3">
              <label class="form-label">Button Text</label>
              <input type="text" class="form-control cta-btn-text" value="Contact Us">
            </div>
            <div class="mb-3">
              <label class="form-label">Button Link</label>
              <input type="text" class="form-control cta-btn-link" value="/contact">
            </div>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Background Color</label>
          <input type="color" class="form-control form-control-color cta-bg-color" value="#007bff">
        </div>
        <div class="mb-3">
          <label class="form-label">Background Image</label>
          <input type="file" class="form-control cta-bg-image" accept="image/*">
          <input type="hidden" class="cta-bg-image-url">
        </div>
      </div>
    </div>

    <!-- Block Settings (Common for all blocks) -->
    <div class="block-settings">
      <div class="row">
        <div class="col-md-4">
          <label class="form-label">Padding</label>
          <select class="form-select form-select-sm block-padding">
            <option value="small">Small</option>
            <option value="medium" selected>Medium</option>
            <option value="large">Large</option>
            <option value="none">None</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Background Color</label>
          <input type="color" class="form-control form-control-color block-bg-color" value="#ffffff">
        </div>
        <div class="col-md-4">
          <label class="form-label">Text Color</label>
          <input type="color" class="form-control form-control-color block-text-color" value="#000000">
        </div>
      </div>
    </div>
  </div>
</template>

<!-- Card Item Template -->
<template id="cardItemTemplate">
  <div class="card-item">
    <button type="button" class="btn btn-sm btn-danger remove-card">×</button>
    <div class="row">
      <div class="col-md-4">
        <div class="mb-2">
          <label class="form-label">Card Image</label>
          <input type="file" class="form-control form-control-sm card-image" accept="image/*">
          <input type="hidden" class="card-image-url">
          <div class="card-image-preview mt-1"></div>
        </div>
      </div>
      <div class="col-md-8">
        <div class="mb-2">
          <input type="text" class="form-control form-control-sm card-title" placeholder="Card Title">
        </div>
        <div class="mb-2">
          <textarea class="form-control form-control-sm card-description" rows="2" placeholder="Card Description"></textarea>
        </div>
        <div class="row">
          <div class="col">
            <input type="text" class="form-control form-control-sm card-btn-text" placeholder="Button Text">
          </div>
          <div class="col">
            <input type="text" class="form-control form-control-sm card-btn-link" placeholder="Button Link">
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<!-- FAQ Item Template -->
<template id="faqItemTemplate">
  <div class="faq-item">
    <button type="button" class="btn btn-sm btn-danger remove-faq float-end">×</button>
    <div class="mb-2">
      <input type="text" class="form-control form-control-sm faq-question" placeholder="Question">
    </div>
    <div class="mb-2">
      <textarea class="form-control form-control-sm faq-answer" rows="2" placeholder="Answer"></textarea>
    </div>
  </div>
</template>

<!-- Location Item Template -->
<template id="locationItemTemplate">
  <div class="location-item">
    <button type="button" class="btn btn-sm btn-danger remove-location float-end">×</button>
    <div class="row">
      <div class="col-md-6">
        <div class="mb-2">
          <input type="text" class="form-control form-control-sm location-name" placeholder="Location Name">
        </div>
        <div class="mb-2">
          <input type="text" class="form-control form-control-sm location-address" placeholder="Address">
        </div>
      </div>
      <div class="col-md-6">
        <div class="mb-2">
          <input type="text" class="form-control form-control-sm location-phone" placeholder="Phone">
        </div>
        <div class="mb-2">
          <input type="text" class="form-control form-control-sm location-hours" placeholder="Business Hours">
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col">
        <input type="text" class="form-control form-control-sm location-map" placeholder="Google Maps URL">
      </div>
    </div>
  </div>
</template>
<%- contentFor('js') %>
<!-- Summernote JS -->
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const blocksContainer = document.getElementById('blocksContainer');
    const addBlockBtn = document.getElementById('addBlockBtn');
    const template = document.getElementById('blockTemplate');
    const heroImageInput = document.getElementById('heroImage');
    const imagePreview = document.getElementById('imagePreview');
    let blockCounter = 0;
    const summernoteInstances = [];

    function setupBlockEventListeners(blockDiv) {
      // Type change handler
      const typeSelect = blockDiv.querySelector('.block-type');
      typeSelect.addEventListener('change', function() {
        showEditorForType(blockDiv, this.value);
      });

      // Move up handler
      const moveUpBtn = blockDiv.querySelector('.move-up');
      if (moveUpBtn) {
        moveUpBtn.addEventListener('click', function() {
          moveBlock(blockDiv, 'up');
        });
      }

      // Move down handler
      const moveDownBtn = blockDiv.querySelector('.move-down');
      if (moveDownBtn) {
        moveDownBtn.addEventListener('click', function() {
          moveBlock(blockDiv, 'down');
        });
      }

      // Remove handler
      const removeBtn = blockDiv.querySelector('.remove-block');
      if (removeBtn) {
        removeBtn.addEventListener('click', function() {
          // Destroy summernote instance if exists
          const summernoteDiv = blockDiv.querySelector('.summernote-editor');
          if (summernoteDiv && $(summernoteDiv).data('summernote')) {
            $(summernoteDiv).summernote('destroy');
          }
          blockDiv.remove();
          updateBlockOrder();
        });
      }

      // Setup image upload handlers for this block
      setupImageUpload(blockDiv);
      setupHeroImageUpload(blockDiv);
      setupGalleryUpload(blockDiv);
      setupCardHandlers(blockDiv);
      setupFaqHandlers(blockDiv);
      setupLocationHandlers(blockDiv);
      setupCtaHandlers(blockDiv);
    }

    // Load existing blocks from database
    <% if (blog.blocks && blog.blocks.length > 0) { %>
    const blocksData = <%- JSON.stringify(blog.blocks) %>;
    blocksData.forEach((blockData, index) => {
      // Create block element
      const clone = template.content.cloneNode(true);
      const blockDiv = clone.querySelector('.block-editor');
      const blockId = `block-${Date.now()}-${index}`;
      blockDiv.dataset.id = blockId;

      // Set block type
      const typeSelect = blockDiv.querySelector('.block-type');
      typeSelect.value = blockData.type;

      // Set common settings
      if (blockData.settings) {
        const paddingSelect = blockDiv.querySelector('.block-padding');
        if (paddingSelect) paddingSelect.value = blockData.settings.padding || 'medium';

        const bgColor = blockDiv.querySelector('.block-bg-color');
        if (bgColor) bgColor.value = blockData.settings.bgColor || '#ffffff';

        const textColor = blockDiv.querySelector('.block-text-color');
        if (textColor) textColor.value = blockData.settings.textColor || '#000000';
      }

      // Fill data based on block type
      if (blockData.type === 'hero') {
        const titleInput = blockDiv.querySelector('.hero-title');
        if (titleInput) titleInput.value = blockData.title || '';

        const subtitleInput = blockDiv.querySelector('.hero-subtitle');
        if (subtitleInput) subtitleInput.value = blockData.subtitle || '';

        const imageUrlInput = blockDiv.querySelector('.hero-image-url');
        if (imageUrlInput && blockData.content) {
          imageUrlInput.value = blockData.content;
          const previewContainer = blockDiv.querySelector('.hero-image-preview');
          previewContainer.innerHTML = `<img src="${blockData.content}" class="img-fluid" style="max-height: 100px;">`;
        }

        const btnText = blockDiv.querySelector('.hero-btn-text');
        if (btnText && blockData.settings?.buttonText) btnText.value = blockData.settings.buttonText;

        const btnLink = blockDiv.querySelector('.hero-btn-link');
        if (btnLink && blockData.settings?.buttonLink) btnLink.value = blockData.settings.buttonLink;

        const overlay = blockDiv.querySelector('.hero-overlay');
        if (overlay && blockData.settings?.overlay) overlay.value = blockData.settings.overlay;
      }

      if (blockData.type === 'text') {
        const summernoteDiv = blockDiv.querySelector('.summernote-editor');
        const textarea = blockDiv.querySelector('.text-content');
        if (textarea) textarea.value = blockData.content || '';

        // Initialize Summernote after adding to DOM
        setTimeout(() => {
          if (summernoteDiv) {
            $(summernoteDiv).summernote({
              placeholder: 'Write your content here...',
              tabsize: 2,
              height: 300,
              fontNames: [
                'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New',
                'Georgia', 'Tahoma', 'Times New Roman', 'Verdana',

                'Poppins', 'Roboto', 'Open Sans', 'Lato',
                'Montserrat', 'Raleway', 'Nunito',
                'Playfair Display', 'Merriweather'
              ],
              fontNamesIgnoreCheck: [
                'Poppins', 'Roboto', 'Open Sans', 'Lato',
                'Montserrat', 'Raleway', 'Nunito',
                'Playfair Display', 'Merriweather'
              ],
              fontSizes: ['8', '10', '12', '14', '16', '18', '20', '24', '28', '32', '36', '48', '64'],
              toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
                ['fontname', ['fontname']],
                ['fontsize', ['fontsize']],
                ['color', ['forecolor', 'backcolor']],
                ['para', ['ul', 'ol', 'paragraph', 'height']],
                ['insert', ['link', 'picture', 'video', 'table']],
                ['view', ['fullscreen', 'codeview']]
              ],
              lineHeights: ['0.8', '1.0', '1.2', '1.5', '2.0', '3.0'],
              callbacks: {
                onChange: function(contents) {
                  const textarea = $(this).closest('.text-editor').find('.text-content');
                  textarea.val(contents);
                }
              }
            });
            if (blockData.content) {
              $(summernoteDiv).summernote('code', blockData.content);
            }
            summernoteInstances.push({
              id: blockId,
              editor: summernoteDiv
            });
          }
        }, 100);
      }

      if (blockData.type === 'image') {
        const imageUrlInput = blockDiv.querySelector('.image-url');
        if (imageUrlInput && blockData.content) {
          imageUrlInput.value = blockData.content;
          const previewContainer = blockDiv.querySelector('.image-preview-container');
          previewContainer.innerHTML = `<img src="${blockData.content}" class="img-fluid" style="max-height: 100px;">`;
        }

        const caption = blockDiv.querySelector('.image-caption');
        if (caption && blockData.settings?.caption) caption.value = blockData.settings.caption;

        const alt = blockDiv.querySelector('.image-alt');
        if (alt && blockData.settings?.alt) alt.value = blockData.settings.alt;
      }

      if (blockData.type === 'cta') {
        const title = blockDiv.querySelector('.cta-title');
        if (title) title.value = blockData.title || '';

        const description = blockDiv.querySelector('.cta-description');
        if (description) description.value = blockData.subtitle || '';

        const btnText = blockDiv.querySelector('.cta-btn-text');
        if (btnText && blockData.settings?.buttonText) btnText.value = blockData.settings.buttonText;

        const btnLink = blockDiv.querySelector('.cta-btn-link');
        if (btnLink && blockData.settings?.buttonLink) btnLink.value = blockData.settings.buttonLink;

        const bgColor = blockDiv.querySelector('.cta-bg-color');
        if (bgColor && blockData.settings?.bgColor) bgColor.value = blockData.settings.bgColor;

        const bgImage = blockDiv.querySelector('.cta-bg-image-url');
        if (bgImage && blockData.settings?.bgImage) bgImage.value = blockData.settings.bgImage;
      }

      // Load nested items
      if (blockData.type === 'cards' && blockData.items) {
        const cardsContainer = blockDiv.querySelector('.cards-container');
        blockData.items.forEach(item => {
          const cardTemplate = document.getElementById('cardItemTemplate');
          const cardClone = cardTemplate.content.cloneNode(true);
          const cardItem = cardClone.querySelector('.card-item');

          if (item.title) cardItem.querySelector('.card-title').value = item.title;
          if (item.description) cardItem.querySelector('.card-description').value = item.description;
          if (item.extraData?.buttonText) cardItem.querySelector('.card-btn-text').value = item.extraData.buttonText;
          if (item.link) cardItem.querySelector('.card-btn-link').value = item.link;
          if (item.image) {
            cardItem.querySelector('.card-image-url').value = item.image;
            const preview = cardItem.querySelector('.card-image-preview');
            preview.innerHTML = `<img src="${item.image}" class="img-fluid" style="max-height: 50px;">`;
          }

          cardsContainer.appendChild(cardItem);
        });
      }

      if (blockData.type === 'faq' && blockData.items) {
        const faqContainer = blockDiv.querySelector('.faq-items-container');
        blockData.items.forEach(item => {
          const faqTemplate = document.getElementById('faqItemTemplate');
          const faqClone = faqTemplate.content.cloneNode(true);
          const faqItem = faqClone.querySelector('.faq-item');

          if (item.title) faqItem.querySelector('.faq-question').value = item.title;
          if (item.description) faqItem.querySelector('.faq-answer').value = item.description;

          faqContainer.appendChild(faqItem);
        });
      }

      if (blockData.type === 'locations' && blockData.items) {
        const locationsContainer = blockDiv.querySelector('.locations-container');
        blockData.items.forEach(item => {
          const locationTemplate = document.getElementById('locationItemTemplate');
          const locationClone = locationTemplate.content.cloneNode(true);
          const locationItem = locationClone.querySelector('.location-item');

          if (item.title) locationItem.querySelector('.location-name').value = item.title;
          if (item.description) locationItem.querySelector('.location-address').value = item.description;
          if (item.extraData?.phone) locationItem.querySelector('.location-phone').value = item.extraData.phone;
          if (item.extraData?.hours) locationItem.querySelector('.location-hours').value = item.extraData.hours;
          if (item.extraData?.map) locationItem.querySelector('.location-map').value = item.extraData.map;

          locationsContainer.appendChild(locationItem);
        });
      }

      if (blockData.type === 'gallery' && blockData.items) {
        const galleryContainer = blockDiv.querySelector('.gallery-images-container');
        blockData.items.forEach(item => {
          if (item.image) {
            const imageItem = document.createElement('div');
            imageItem.className = 'gallery-image-item';
            imageItem.innerHTML = `
              <img src="${item.image}" class="img-fluid">
              <button type="button" class="remove-image">×</button>
              <input type="hidden" name="gallery_image" value="${item.image}">
            `;
            galleryContainer.appendChild(imageItem);
          }
        });
      }

      // Show the correct editor
      showEditorForType(blockDiv, blockData.type);

      // Add to container
      blocksContainer.appendChild(blockDiv);

      setupBlockEventListeners(blockDiv);
      blockCounter++;
    });
    <% } %>

    // Hero image preview
    if (heroImageInput) {
      heroImageInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) {
            imagePreview.innerHTML = `<img src="${e.target.result}" class="img-fluid rounded">`;
          };
          reader.readAsDataURL(file);
        } else {
          imagePreview.innerHTML = '';
        }
      });
    }

    // Initialize Summernote in a div
    function initSummernote(container) {
      $(container).summernote({
        placeholder: 'Write your content here...',
        tabsize: 2,
        height: 200,
        toolbar: [
          ['style', ['style']],
          ['font', ['bold', 'underline', 'clear']],
          ['fontname', ['fontname']],
          ['color', ['color']],
          ['para', ['ul', 'ol', 'paragraph']],
          ['table', ['table']],
          ['insert', ['link', 'picture', 'video']],
          ['view', ['fullscreen', 'codeview', 'help']]
        ],
        callbacks: {
          onChange: function(contents) {
            // Update the hidden textarea when content changes
            const textarea = $(this).closest('.text-editor').find('.text-content');
            textarea.val(contents);
          }
        }
      });

      return container;
    }

    // Add new block
    addBlockBtn.addEventListener('click', function() {
      const clone = template.content.cloneNode(true);
      const blockDiv = clone.querySelector('.block-editor');
      const blockId = `block-${blockCounter++}`;
      blockDiv.dataset.id = blockId;

      // Setup block type change handler
      const typeSelect = blockDiv.querySelector('.block-type');
      typeSelect.addEventListener('change', function() {
        showEditorForType(blockDiv, this.value);
      });

      // Setup move handlers
      blockDiv.querySelector('.move-up').addEventListener('click', function() {
        moveBlock(blockDiv, 'up');
      });

      blockDiv.querySelector('.move-down').addEventListener('click', function() {
        moveBlock(blockDiv, 'down');
      });

      // Setup remove handler
      blockDiv.querySelector('.remove-block').addEventListener('click', function() {
        // Destroy summernote instance if exists
        const summernoteDiv = blockDiv.querySelector('.summernote-editor');
        if (summernoteDiv && $(summernoteDiv).data('summernote')) {
          $(summernoteDiv).summernote('destroy');
        }
        blockDiv.remove();
        updateBlockOrder();
      });

      blocksContainer.appendChild(blockDiv);
      showEditorForType(blockDiv, 'hero'); // Default to hero

      // Initialize Summernote for text blocks
      const summernoteDiv = blockDiv.querySelector('.summernote-editor');
      if (summernoteDiv) {
        initSummernote(summernoteDiv);
        summernoteInstances.push({
          id: blockId,
          editor: summernoteDiv
        });
      }

      // Setup image upload handlers
      setupImageUpload(blockDiv);
      setupHeroImageUpload(blockDiv);
      setupGalleryUpload(blockDiv);
      setupCardHandlers(blockDiv);
      setupFaqHandlers(blockDiv);
      setupLocationHandlers(blockDiv);
      setupCtaHandlers(blockDiv);

      updateBlockOrder();
    });

    function showEditorForType(blockDiv, type) {
      const editors = blockDiv.querySelectorAll('.block-content > div');
      editors.forEach(editor => editor.classList.add('d-none'));

      const selectedEditor = blockDiv.querySelector(`.${type}-editor`);
      if (selectedEditor) {
        selectedEditor.classList.remove('d-none');
      }
    }

    function moveBlock(blockDiv, direction) {
      if (direction === 'up' && blockDiv.previousElementSibling) {
        blockDiv.parentNode.insertBefore(blockDiv, blockDiv.previousElementSibling);
      } else if (direction === 'down' && blockDiv.nextElementSibling) {
        blockDiv.parentNode.insertBefore(blockDiv.nextElementSibling, blockDiv);
      }
      updateBlockOrder();
    }

    function updateBlockOrder() {
      // Update any order-related data if needed
    }

    // Setup image upload for image blocks
    function setupImageUpload(blockDiv) {
      const imageInput = blockDiv.querySelector('.block-image');
      if (imageInput) {
        imageInput.addEventListener('change', async function(e) {
          const file = e.target.files[0];
          if (file) {
            const formData = new FormData();
            formData.append('image', file);

            try {
              const response = await fetch('/admin/blogs/blocks/upload-image', {
                method: 'POST',
                body: formData
              });
              const data = await response.json();
              if (data.url) {
                const hiddenInput = blockDiv.querySelector('.image-url');
                hiddenInput.value = data.url;

                // Show preview
                const previewContainer = blockDiv.querySelector('.image-preview-container');
                previewContainer.innerHTML = `<img src="${data.url}" class="img-fluid" style="max-height: 100px;">`;
              }
            } catch (error) {
              console.error('Error uploading image:', error);
            }
          }
        });
      }
    }

    // Setup hero image upload
    function setupHeroImageUpload(blockDiv) {
      const heroImageInput = blockDiv.querySelector('.hero-image');
      if (heroImageInput) {
        heroImageInput.addEventListener('change', async function(e) {
          const file = e.target.files[0];
          if (file) {
            const formData = new FormData();
            formData.append('image', file);

            try {
              const response = await fetch('/admin/blogs/blocks/upload-image', {
                method: 'POST',
                body: formData
              });
              const data = await response.json();
              if (data.url) {
                const hiddenInput = blockDiv.querySelector('.hero-image-url');
                hiddenInput.value = data.url;

                // Show preview
                const previewContainer = blockDiv.querySelector('.hero-image-preview');
                previewContainer.innerHTML = `<img src="${data.url}" class="img-fluid" style="max-height: 100px;">`;
              }
            } catch (error) {
              console.error('Error uploading image:', error);
            }
          }
        });
      }
    }

    // Setup gallery upload
    function setupGalleryUpload(blockDiv) {
      const galleryInput = blockDiv.querySelector('.gallery-upload');
      if (galleryInput) {
        galleryInput.addEventListener('change', async function(e) {
          const files = Array.from(e.target.files);
          const container = blockDiv.querySelector('.gallery-images-container');

          for (const file of files) {
            const formData = new FormData();
            formData.append('image', file);

            try {
              const response = await fetch('/admin/blogs/blocks/upload-image', {
                method: 'POST',
                body: formData
              });
              const data = await response.json();
              if (data.url) {
                const imageItem = document.createElement('div');
                imageItem.className = 'gallery-image-item';
                imageItem.innerHTML = `
                <img src="${data.url}" class="img-fluid">
                <button type="button" class="remove-image">×</button>
                <input type="hidden" name="gallery_image" value="${data.url}">
              `;

                imageItem.querySelector('.remove-image').addEventListener('click', function() {
                  imageItem.remove();
                });

                container.appendChild(imageItem);
              }
            } catch (error) {
              console.error('Error uploading image:', error);
            }
          }
        });
      }
    }

    // Setup card handlers
    function setupCardHandlers(blockDiv) {
      const addCardBtn = blockDiv.querySelector('.add-card');
      const cardsContainer = blockDiv.querySelector('.cards-container');
      const cardTemplate = document.getElementById('cardItemTemplate');

      if (addCardBtn && cardsContainer) {
        addCardBtn.addEventListener('click', function() {
          const clone = cardTemplate.content.cloneNode(true);
          const cardItem = clone.querySelector('.card-item');

          // Setup remove handler
          cardItem.querySelector('.remove-card').addEventListener('click', function() {
            cardItem.remove();
          });

          // Setup image upload for card
          const cardImage = cardItem.querySelector('.card-image');
          cardImage.addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (file) {
              const formData = new FormData();
              formData.append('image', file);

              try {
                const response = await fetch('/admin/blogs/blocks/upload-image', {
                  method: 'POST',
                  body: formData
                });
                const data = await response.json();
                if (data.url) {
                  const hiddenInput = cardItem.querySelector('.card-image-url');
                  hiddenInput.value = data.url;

                  // Show preview
                  const previewContainer = cardItem.querySelector('.card-image-preview');
                  previewContainer.innerHTML = `<img src="${data.url}" class="img-fluid" style="max-height: 50px;">`;
                }
              } catch (error) {
                console.error('Error uploading image:', error);
              }
            }
          });

          cardsContainer.appendChild(cardItem);
        });
      }
    }

    // Setup FAQ handlers
    function setupFaqHandlers(blockDiv) {
      const addFaqBtn = blockDiv.querySelector('.add-faq');
      const faqContainer = blockDiv.querySelector('.faq-items-container');
      const faqTemplate = document.getElementById('faqItemTemplate');

      if (addFaqBtn && faqContainer) {
        addFaqBtn.addEventListener('click', function() {
          const clone = faqTemplate.content.cloneNode(true);
          const faqItem = clone.querySelector('.faq-item');

          faqItem.querySelector('.remove-faq').addEventListener('click', function() {
            faqItem.remove();
          });

          faqContainer.appendChild(faqItem);
        });
      }
    }

    // Setup location handlers
    function setupLocationHandlers(blockDiv) {
      const addLocationBtn = blockDiv.querySelector('.add-location');
      const locationsContainer = blockDiv.querySelector('.locations-container');
      const locationTemplate = document.getElementById('locationItemTemplate');

      if (addLocationBtn && locationsContainer) {
        addLocationBtn.addEventListener('click', function() {
          const clone = locationTemplate.content.cloneNode(true);
          const locationItem = clone.querySelector('.location-item');

          locationItem.querySelector('.remove-location').addEventListener('click', function() {
            locationItem.remove();
          });

          locationsContainer.appendChild(locationItem);
        });
      }
    }

    // Setup CTA handlers
    function setupCtaHandlers(blockDiv) {
      const ctaBgImage = blockDiv.querySelector('.cta-bg-image');
      if (ctaBgImage) {
        ctaBgImage.addEventListener('change', async function(e) {
          const file = e.target.files[0];
          if (file) {
            const formData = new FormData();
            formData.append('image', file);

            try {
              const response = await fetch('/admin/blogs/blocks/upload-image', {
                method: 'POST',
                body: formData
              });
              const data = await response.json();
              if (data.url) {
                const hiddenInput = blockDiv.querySelector('.cta-bg-image-url');
                hiddenInput.value = data.url;
              }
            } catch (error) {
              console.error('Error uploading image:', error);
            }
          }
        });
      }
    }

    // Handle form submission
    document.getElementById('blogForm').addEventListener('submit', function(e) {
      // Update all Summernote textareas before submit
      summernoteInstances.forEach(instance => {
        const summernoteDiv = instance.editor;
        const content = $(summernoteDiv).summernote('code');
        const textarea = $(summernoteDiv).closest('.text-editor').find('.text-content');
        textarea.val(content);
      });

      // Remove existing block inputs
      const existingBlockInputs = document.querySelectorAll('input[name^="blocks["]');
      existingBlockInputs.forEach(input => input.remove());

      // Collect all blocks data
      const blocks = [];
      document.querySelectorAll('.block-editor').forEach((blockDiv, index) => {
        const typeSelect = blockDiv.querySelector('.block-type');
        if (!typeSelect) return;

        const type = typeSelect.value;
        const blockData = {
          type: type,
          order: index,
          settings: {
            padding: blockDiv.querySelector('.block-padding')?.value || 'medium',
            bgColor: blockDiv.querySelector('.block-bg-color')?.value || '#ffffff',
            textColor: blockDiv.querySelector('.block-text-color')?.value || '#000000'
          }
        };

        // Collect data based on block type
        if (type === 'hero') {
          blockData.title = blockDiv.querySelector('.hero-title')?.value || '';
          blockData.subtitle = blockDiv.querySelector('.hero-subtitle')?.value || '';
          blockData.content = blockDiv.querySelector('.hero-image-url')?.value || '';
          blockData.settings.buttonText = blockDiv.querySelector('.hero-btn-text')?.value || '';
          blockData.settings.buttonLink = blockDiv.querySelector('.hero-btn-link')?.value || '';
          blockData.settings.overlay = blockDiv.querySelector('.hero-overlay')?.value || '50';
        } else if (type === 'text') {
          blockData.content = blockDiv.querySelector('.text-content')?.value || '';
        } else if (type === 'image') {
          blockData.content = blockDiv.querySelector('.image-url')?.value || '';
          blockData.settings.caption = blockDiv.querySelector('.image-caption')?.value || '';
          blockData.settings.alt = blockDiv.querySelector('.image-alt')?.value || '';
        } else if (type === 'gallery') {
          blockData.images = [];
          blockDiv.querySelectorAll('.gallery-image-item input[name="gallery_image"]').forEach(input => {
            blockData.images.push(input.value);
          });
          blockData.settings.layout = blockDiv.querySelector('.gallery-layout')?.value || 'grid-3';
        } else if (type === 'cards') {
          blockData.cards = [];
          blockDiv.querySelectorAll('.card-item').forEach(cardItem => {
            blockData.cards.push({
              title: cardItem.querySelector('.card-title')?.value || '',
              description: cardItem.querySelector('.card-description')?.value || '',
              image: cardItem.querySelector('.card-image-url')?.value || '',
              buttonText: cardItem.querySelector('.card-btn-text')?.value || '',
              buttonLink: cardItem.querySelector('.card-btn-link')?.value || ''
            });
          });
          blockData.settings.cardsPerRow = blockDiv.querySelector('.cards-per-row')?.value || '3';
        } else if (type === 'faq') {
          blockData.title = blockDiv.querySelector('.faq-title')?.value || '';
          blockData.items = [];
          blockDiv.querySelectorAll('.faq-item').forEach(faqItem => {
            blockData.items.push({
              question: faqItem.querySelector('.faq-question')?.value || '',
              answer: faqItem.querySelector('.faq-answer')?.value || ''
            });
          });
        } else if (type === 'locations') {
          blockData.title = blockDiv.querySelector('.locations-title')?.value || '';
          blockData.locations = [];
          blockDiv.querySelectorAll('.location-item').forEach(locationItem => {
            blockData.locations.push({
              name: locationItem.querySelector('.location-name')?.value || '',
              address: locationItem.querySelector('.location-address')?.value || '',
              phone: locationItem.querySelector('.location-phone')?.value || '',
              hours: locationItem.querySelector('.location-hours')?.value || '',
              map: locationItem.querySelector('.location-map')?.value || ''
            });
          });
          blockData.settings.showMap = blockDiv.querySelector('.show-map')?.checked || false;
        } else if (type === 'cta') {
          blockData.title = blockDiv.querySelector('.cta-title')?.value || '';
          blockData.subtitle = blockDiv.querySelector('.cta-description')?.value || '';
          blockData.settings.buttonText = blockDiv.querySelector('.cta-btn-text')?.value || '';
          blockData.settings.buttonLink = blockDiv.querySelector('.cta-btn-link')?.value || '';
          blockData.settings.bgColor = blockDiv.querySelector('.cta-bg-color')?.value || '#007bff';
          blockData.settings.bgImage = blockDiv.querySelector('.cta-bg-image-url')?.value || '';
        }

        blocks.push(blockData);
      });

      // Add blocks to form as hidden inputs
      blocks.forEach((block, index) => {
        const blockInput = document.createElement('input');
        blockInput.type = 'hidden';
        blockInput.name = `blocks[${index}]`;
        blockInput.value = JSON.stringify(block);
        this.appendChild(blockInput);
      });
    });
  });
</script>