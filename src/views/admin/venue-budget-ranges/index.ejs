<%- contentFor('title') %> Venue Budget Ranges
<%- contentFor('head') %>
<style>
  body { background: #f5f7fb; }
  .categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .category-card { background: #fff; border-radius: 0.75rem; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); transition: all 0.2s; }
  .category-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
  .category-card-content { padding: 0.75rem; }
  .category-card-title { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; color: #2c3e50; }
  .category-card-slug { font-size: 0.7rem; color: #6c757d; margin-bottom: 0.5rem; word-break: break-all; }
  .category-card-status { font-size: 0.65rem; padding: 0.2rem 0.5rem; border-radius: 20px; font-weight: 500; }
  .category-card-actions { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 0.5rem; }
  .btn-sm { padding: 0.2rem 0.5rem; font-size: 0.7rem; }
</style>

<%- contentFor('body') %>
<div class="container-fluid py-3">
  <div class="row mb-3 align-items-center">
    <div class="col-md-8">
      <h4 class="mb-0 fw-bold">Venue Budget Ranges</h4>
      <p class="text-muted small mb-0">Manage budget ranges for venues</p>
    </div>
    <div class="col-md-4 text-md-end mt-2 mt-md-0">
      <a href="/admin/venue-budget-ranges/create" class="btn btn-primary btn-sm"><i class="bx bx-plus-circle me-1"></i> Add New Range</a>
    </div>
  </div>


  <%  if (items && items.length > 0) { %>
  <div class="categories-grid">
    <% items.forEach(cat => { %>
      <div class="category-card shadow-lg p-2">
        <div class="category-card-content">
          <div class="row">
            <div class="col-6">
              <h5 class="category-card-title"><%= cat.name %></h5>
            </div>
            <div class="col-6 text-end">
              <div class="mb-1"><span class="category-card-status badge <%= cat.isActive ? 'bg-success' : 'bg-secondary' %>"><%= cat.isActive ? 'Active' : 'Inactive' %></span></div>
            </div>
          </div>
          <div class="category-card-slug"><i class="bx bx-link-alt me-1"></i> <%= cat.slug %></div>
          <% if (cat.description) { %>
              <div class="description-preview">
                <i class="bx bx-file-blank me-1 opacity-50"></i> <%= cat.description.length > 90 ? cat.description.substring(0, 90) + '…' : cat.description %>
              </div>
            <% } else { %>
              <div class="description-preview text-muted fst-italic">No description provided</div>
            <% } %>
          
          <div class="category-card-actions">
            <a href="/admin/venue-experience-types/edit/<%= cat.id %>" class="btn btn-sm btn-warning"><i class="bx bx-edit"></i> Edit</a>
            <button class="btn btn-sm btn-danger delete-category" data-id="<%= cat.id %>"><i class="bx bx-trash"></i> Delete</button>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="bx bx-info-circle text-muted" style="font-size: 3rem;"></i>
      <h5 class="mt-3">No budget ranges found</h5>
      <p class="text-muted">Create your first budget range to get started.</p>
      <a href="/admin/venue-budget-ranges/create" class="btn btn-sm btn-primary"><i class="bi bi-plus-square"></i>Create Budget Range</a>
    </div>
  <% } %>
</div>

<%- contentFor('js') %>
<script>
  document.querySelectorAll('.delete-category').forEach(btn => {
    btn.addEventListener('click', async e => {
      if (!confirm('Delete this range?')) return;
      const id = btn.dataset.id;
      const res = await fetch(`/admin/venue-budget-ranges/delete/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) location.reload(); else alert(data.message);
    });
  });
</script>