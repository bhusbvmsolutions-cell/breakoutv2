<div class="row">
  <div class="col-12 col-lg-12">
    <div class="card">
      <div class="card-header">
        <h4><i class="bi bi-shield"></i> Role Management</h4>
      </div>
    </div>
  </div>
</div>


<div class="card">
  <div class="card-header">
    <div class="row align-items-center">
      <div class="col-sm-6">
        <h5 class="mb-0">All Roles</h5>
      </div>
      <div class="col-sm-6">
        <div class="d-flex justify-content-end gap-2">
          <form action="/admin/roles" method="GET" class="d-flex">
            <input type="text" name="search" class="form-control form-control-sm me-2" placeholder="Search roles..." value="<%= search || '' %>" style="width: 200px;">
            <button type="submit" class="btn btn-sm btn-primary">
              <i class="bi bi-search"></i>
            </button>
          </form>
          <% if (canCreateRole) { %>
          <a href="/admin/roles/create" class="btn btn-sm btn-success">
            <i class="bi bi-plus"></i> Add Role
          </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Role Name</th>
            <th>Display Name</th>
            <th>Level</th>
            <th>Users Count</th>
            <th>Permissions</th>
            <th>Type</th>
            <th>Created By</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (roles && roles.length > 0) { %>
          <% roles.forEach(role => { %>
          <tr>
            <td><%= role.id %></td>
            <td><code><%= role.name %></code></td>
            <td><strong><%= role.displayName %></strong></td>
            <td><span class="badge bg-info">Level <%= role.level %></span></td>
            <td>
              <span class="badge bg-secondary"><%= role.userCount || 0 %></span>
            </td>
            <td>
              <button type="button" class="btn btn-sm btn-outline-info view-permissions" data-role-id="<%= role.id %>" data-role-name="<%= role.displayName %>">
                <i class="bi bi-key"></i> View
              </button>
            </td>
            <td>
              <% if (role.isSystem) { %>
              <span class="badge bg-danger">System</span>
              <% } else { %>
              <span class="badge bg-success">Custom</span>
              <% } %>
            </td>
            <td>
              <% if (role.creator) { %>
              <%= role.creator.firstName || '' %> <%= role.creator.lastName || '' %>
              <% } else { %>
              <span class="text-muted">System</span>
              <% } %>
            </td>
            <td>
              <div class="btn-group btn-group-sm">
                <% if (role.canManage) { %>
                <a href="/admin/roles/<%= role.id %>/edit" class="btn btn-outline-warning">
                  <i class="bi bi-pencil"></i>
                </a>

                <button type="button" class="btn btn-outline-primary manage-permissions" data-role-id="<%= role.id %>" data-role-name="<%= role.displayName %>">
                  <i class="bi bi-key"></i>
                </button>

                <% if (role.canDelete) { %>
                <button type="button" class="btn btn-outline-danger delete-role" data-id="<%= role.id %>">
                  <i class="bi bi-trash"></i>
                </button>
                <% } %>
                <% } %>
              </div>
            </td>
          </tr>
          <% }); %>
          <% } else { %>
          <tr>
            <td colspan="9" class="text-center py-4">No roles found</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.pages > 1) { %>
    <nav aria-label="Page navigation" class="mt-3">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= pagination.page - 1 %><%= search ? '&search=' + search : '' %>">Previous</a>
        </li>

        <% for (let i = 1; i <= pagination.pages; i++) { %>
        <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %>"><%= i %></a>
        </li>
        <% } %>

        <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= pagination.page + 1 %><%= search ? '&search=' + search : '' %>">Next</a>
        </li>
      </ul>
    </nav>
    <% } %>
  </div>
</div>

<!-- View Permissions Modal -->
<div class="modal fade" id="viewPermissionsModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Permissions for <span id="viewRoleName"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="viewPermissionsList" class="row">
          <!-- Permissions will be loaded here -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Manage Permissions Modal -->
<div class="modal fade" id="managePermissionsModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Manage Permissions for <span id="manageRoleName"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="permissionsForm">
        <div class="modal-body">
          <input type="hidden" id="roleId" name="roleId">
          <div class="row">
            <% Object.keys(groupedPermissions).forEach(resource => { %>
            <div class="col-md-6 mb-3">
              <div class="card">
                <div class="card-header bg-light">
                  <div class="form-check">
                    <input class="form-check-input resource-checkall" type="checkbox" data-resource="<%= resource %>" id="checkAll_<%= resource %>">
                    <label class="form-check-label fw-bold" for="checkAll_<%= resource %>">
                      <%= resource.charAt(0).toUpperCase() + resource.slice(1) %>
                    </label>
                  </div>
                </div>
                <div class="card-body">
                  <% groupedPermissions[resource].forEach(perm => { %>
                  <div class="form-check mb-2">
                    <input class="form-check-input permission-check" type="checkbox" name="permissionIds" value="<%= perm.id %>" id="perm_<%= perm.id %>" data-resource="<%= resource %>">
                    <label class="form-check-label" for="perm_<%= perm.id %>">
                      <span class="badge bg-secondary"><%= perm.action %></span>
                      <small class="text-muted d-block"><%= perm.description || perm.name %></small>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
            </div>
            <% }); %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Permissions</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  $(document).ready(function() {
    // View permissions
    $('.view-permissions').on('click', function() {
      const roleId = $(this).data('role-id');
      const roleName = $(this).data('role-name');

      $('#viewRoleName').text(roleName);
      $('#viewPermissionsList').html('<div class="text-center"><div class="spinner-border"></div></div>');
      $('#viewPermissionsModal').modal('show');

      $.ajax({
        url: '/admin/roles/' + roleId + '/permissions',
        method: 'GET',
        success: function(response) {
          if (response.success) {
            let html = '';

            if (response.permissions.length === 0) {
              html = '<div class="col-12"><p class="text-center text-muted">No permissions assigned</p></div>';
            } else {
              // Group permissions by resource
              const grouped = {};
              response.permissions.forEach(perm => {
                if (!grouped[perm.resource]) {
                  grouped[perm.resource] = [];
                }
                grouped[perm.resource].push(perm);
              });

              Object.keys(grouped).sort().forEach(resource => {
                html += `<div class="col-12 mb-3">
                    <h6 class="border-bottom pb-2">${resource.charAt(0).toUpperCase() + resource.slice(1)}</h6>`;

                grouped[resource].forEach(perm => {
                  html += `<span class="badge bg-info me-2 mb-2">${perm.action}</span>`;
                });

                html += '</div>';
              });
            }

            $('#viewPermissionsList').html(html);
          }
        },
        error: function() {
          $('#viewPermissionsList').html('<p class="text-danger text-center">Failed to load permissions</p>');
        }
      });
    });

    // Manage permissions
    $('.manage-permissions').on('click', function() {
      const roleId = $(this).data('role-id');
      const roleName = $(this).data('role-name');

      $('#manageRoleName').text(roleName);
      $('#roleId').val(roleId);

      // Reset all checkboxes
      $('.permission-check').prop('checked', false);

      // Load current permissions
      $.ajax({
        url: '/admin/roles/' + roleId + '/permissions',
        method: 'GET',
        success: function(response) {
          if (response.success) {
            response.permissions.forEach(perm => {
              $('#perm_' + perm.id).prop('checked', true);
            });

            // Update checkall checkboxes
            $('.resource-checkall').each(function() {
              const resource = $(this).data('resource');
              const total = $('.permission-check[data-resource="' + resource + '"]').length;
              const checked = $('.permission-check[data-resource="' + resource + '"]:checked').length;
              $(this).prop('checked', total === checked);
            });
          }
        }
      });

      $('#managePermissionsModal').modal('show');
    });

    // Resource checkall
    $('.resource-checkall').on('change', function() {
      const resource = $(this).data('resource');
      $('.permission-check[data-resource="' + resource + '"]').prop('checked', $(this).prop('checked'));
    });

    // Individual permission check
    $('.permission-check').on('change', function() {
      const resource = $(this).data('resource');
      const total = $('.permission-check[data-resource="' + resource + '"]').length;
      const checked = $('.permission-check[data-resource="' + resource + '"]:checked').length;
      $('.resource-checkall[data-resource="' + resource + '"]').prop('checked', total === checked);
    });

    // Submit permissions form
    $('#permissionsForm').on('submit', function(e) {
      e.preventDefault();

      const roleId = $('#roleId').val();
      const permissionIds = $('.permission-check:checked').map(function() {
        return $(this).val();
      }).get();

      $.ajax({
        url: '/admin/roles/' + roleId + '/permissions',
        method: 'POST',
        data: {
          permissionIds
        },
        success: function(response) {
          if (response.success) {
            $('#managePermissionsModal').modal('hide');
            window.location.reload();
          } else {
            alert(response.error || 'Failed to update permissions');
          }
        },
        error: function() {
          alert('Failed to update permissions');
        }
      });
    });

    // Delete role
    $('.delete-role').on('click', function() {
      const roleId = $(this).data('id');

      if (confirm('Are you sure you want to delete this role? This action cannot be undone.')) {
        $.ajax({
          url: '/admin/roles/' + roleId,
          type: 'DELETE',
          success: function(response) {
            if (response.success) {
              window.location.reload();
            } else {
              alert(response.error || 'Failed to delete role');
            }
          },
          error: function(xhr) {
            alert(xhr.responseJSON?.error || 'Failed to delete role');
          }
        });
      }
    });
  });
</script>